    <section class="banner-area">
      <div class="banner-main" id="bannerMain">
        <% if (typeof banners !== 'undefined' && banners.length) { %>
          <div class="banner-slider" id="bannerSlider">
            <% banners.forEach(function(b, i) { %>
            <a href="<%= b.link_url || '#' %>" class="banner-slide <%= i === 0 ? 'active' : '' %>">
              <img src="<%= b.image_url %>" alt="Banner" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
            </a>
            <% }); %>
          </div>
          <div class="banner-dots" id="bannerDots"></div>
          <button class="banner-arrow banner-prev" id="bannerPrev">&#8249;</button>
          <button class="banner-arrow banner-next" id="bannerNext">&#8250;</button>
        <% } %>
      </div>
      <div class="banner-side">
        <% if (typeof banners !== 'undefined' && banners.length > 1) { %>
          <a href="<%= banners[1] ? banners[1].link_url || '#' : '#' %>" class="banner-side-item">
            <img src="<%= banners[1] ? banners[1].image_url : '' %>" alt="Promo" loading="lazy">
