        <li data-filter="providers" data-tooltip="Provedores" onclick="window.location='/games'"><img src="/public/img/novo/4.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Provedores</span></li>
        <li data-filter="mines" data-tooltip="Mines" onclick="window.location='/games?category=mines'"><img src="/public/img/novo/5.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Mines</span></li>
        <li data-filter="fortune" data-tooltip="Fortune Tiger" onclick="window.location='/games?category=pg'"><img src="/public/img/novo/6.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Fortune Tiger</span></li>
        <li data-filter="aviator" data-tooltip="Aviator" onclick="window.location='/games?category=crash'"><img src="/public/img/novo/7.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Aviator</span></li>
        <li data-filter="spaceman" data-tooltip="Spaceman" onclick="window.location='/games?category=crash'"><img src="/public/img/novo/8.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Spaceman</span></li>
        <li data-filter="blackjack" data-tooltip="Infinite Blackjack" onclick="window.location='/games?category=live'"><img src="/public/img/novo/9.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Infinite Blackjack</span></li>
        <li data-filter="roleta" data-tooltip="Roleta brasileira" onclick="window.location='/games?category=live'"><img src="/public/img/novo/10.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Roleta brasileira</span></li>
        <li data-filter="footbal" data-tooltip="Footbal Studio" onclick="window.location='/games?category=live'"><img src="/public/img/novo/11.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Footbal Studio</span></li>
        <li data-filter="fruits" data-tooltip="Fortune Fruits" onclick="window.location='/games?category=pg'"><img src="/public/img/novo/12.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Fortune Fruits</span></li>
        <li data-filter="pirates" data-tooltip="Fortune Pirates" onclick="window.location='/games?category=pg'"><img src="/public/img/novo/13.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Fortune Pirates</span></li>
      </ul>
    </div>

    <!-- ESPORTES (group: Esportes + Popular + Top5) -->
    <div class="sidebar-menu sidebar-section-border" id="esportesGroup">
      <div class="menu-title sb-full" id="menuEsportesToggle">
        ESPORTES
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <ul class="menu-list" id="menuEsportesList">
        <li data-tooltip="Jogos ao Vivo"><img src="/public/img/novo/esportes1.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Jogos ao Vivo</span></li>
        <li data-tooltip="Começa em breve"><img src="/public/img/novo/esportes2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Começa em breve</span></li>
