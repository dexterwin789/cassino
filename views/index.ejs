<%- include('partials/head', { title: 'Cassino', extraCss: ['/public/css/account.css','/public/css/ranking.css','/public/css/bonus.css'] }) %>

<div class="shell">
<div class="app is-guest" id="app">

  <!-- MENU FIXED -->
  <div class="menu-fixed" id="menuFixed">
    <header class="header">
      <button class="menu-plain" id="openOffcanvas" aria-label="Menu">
        <img src="/public/img/iconmenu.png" alt="">
      </button>
      <img class="logo" src="/public/img/logo.webp" alt="Cassino">

      <!-- GUEST HEADER -->
      <div class="header-right header-guest" id="headerGuest">
        <button class="h-auth-btn light" id="openLoginTop" type="button">Entrar</button>
        <button class="h-auth-btn gold" id="openRegisterTop" type="button">Registrar</button>
        <img class="hdr-badge" src="/public/img/icon2.png" alt="">
      </div>

      <!-- LOGGED HEADER -->
      <div class="header-right header-logged" id="headerLogged">
        <div class="wallet">
          <img class="wallet-ico" src="/public/img/baixados.webp" alt="">
          <span class="wallet-val" id="walletBonus">0R$</span>
          <span class="wallet-sep">|</span>
          <span class="wallet-val" id="walletBalance">0.00</span>
          <button class="wallet-refresh" id="walletRefresh" aria-label="Atualizar">
            <img src="/public/img/svg1.svg" alt="">
          </button>
          <button class="wallet-plus" id="openDepositPlus" aria-label="Adicionar saldo">
            <img src="/public/img/+.png" alt="">
          </button>
        </div>
        <button class="hbtn-plain" id="openBonusTop" aria-label="Presente" type="button">
          <img src="/public/img/icon1.png" alt="">
        </button>
        <button class="avatar" aria-label="Conta">
          <img src="/public/img/icon2.png" alt="">
        </button>
      </div>
    </header>

    <!-- QUICK ICONS -->
    <section class="quick">
      <a class="qitem" href="#"><span class="qouter"><span class="qinner"><img src="/public/img/icon3.png" alt=""></span></span><span class="qlabel">Tesouro</span></a>
      <a class="qitem" href="#"><span class="qouter"><span class="qinner"><img src="/public/img/icon4.png" alt=""></span></span><span class="qlabel">Slot</span></a>
      <a class="qitem" href="#"><span class="qouter"><span class="qinner"><img src="/public/img/icon5.png" alt=""></span></span><span class="qlabel">Agente</span></a>
      <a class="qitem" href="#"><span class="qouter"><span class="qinner"><img src="/public/img/icon6.png" alt=""></span></span><span class="qlabel">Convite</span></a>
      <a class="qitem" href="#"><span class="qouter"><span class="qinner"><img src="/public/img/icon7.png" alt=""></span></span><span class="qlabel">Cupom</span></a>
      <a class="qitem" href="#"><span class="qouter"><span class="qinner"><img src="/public/img/icon8.png" alt=""></span></span><span class="qlabel">VIP</span></a>
    </section>
  </div>

  <div class="menu-spacer" id="menuSpacer"></div>

  <!-- BANNER -->
  <section class="banner">
    <div class="banner-viewport" id="bannerViewport">
      <div class="banner-track" id="bannerTrack"></div>
      <div class="banner-dots" id="bannerDots"></div>
    </div>
  </section>

  <section class="cards">
    <a class="card" href="#"><img src="/public/img/card1.png" alt=""></a>
    <a class="card" href="#"><img src="/public/img/card2.png" alt=""></a>
    <a class="card" href="#"><img src="/public/img/card3.png" alt=""></a>
  </section>

  <section class="winners">
    <img class="wico" src="/public/img/voice.png" alt="">
    <div class="marquee" aria-label="Ganhadores recentes">
      <div class="marquee__inner" id="marqueeInner"></div>
    </div>
    <img class="wico" src="/public/img/search.png" alt="">
  </section>

  <section class="tabs tabs-under-winners">
    <div class="tabs-viewport" id="tabsViewport">
      <div class="tabs-row" id="tabsRow"></div>
    </div>
  </section>

  <main class="content" id="content"></main>

  <footer class="site-footer">
    <img class="foot-img" src="/public/img/footer1.png" alt="">
    <img class="foot-logo" src="/public/img/logo.webp" alt="Cassino">
    <p class="foot-text">
      <strong>Cassino</strong> irá responder todas as suas dúvidas.<br>
      Entre em contato usando a forma de contato abaixo.
    </p>
    <img class="foot-img" src="/public/img/footer2.png" alt="">
    <img class="foot-img" src="/public/img/footer3.webp" alt="">
    <img class="foot-img" src="/public/img/footer4.png" alt="">
    <p class="foot-legal">
      Direitos autorais &copy; 2025 Cassino. Todos os direitos reservados<br><br>
      Isenção de responsabilidade: O ganho final não é garantido
    </p>
  </footer>

  <a class="telegram-fab" href="#" aria-label="Telegram">
    <img src="/public/img/telegram.png" alt="Telegram">
  </a>

  <!-- Bottom Nav -->
  <nav class="bottom" id="bottomNav">
    <a class="bitem active" href="#" id="goHomeBottom"><img src="/public/img/menu1.png" alt=""><small>Início</small></a>
    <a class="bitem" href="#" id="openRankingBottom"><img src="/public/img/menu2.png" alt=""><small>Ranking</small></a>
    <a class="bitem center" href="#" id="openDepositWallet"><img class="menu-center" src="/public/img/menu3.gif" alt=""><small>Carteira</small></a>
    <a class="bitem" href="#" id="openBonusBottom"><img src="/public/img/menu4.png" alt=""><small>Bônus</small></a>
    <a class="bitem" href="#" id="openAuthBottom"><img src="/public/img/menu5.png" alt=""><small>Conta</small></a>
  </nav>

  <!-- DEPOSIT MODAL -->
  <div class="deposit-modal" id="depositModal" aria-hidden="true">
    <div class="deposit-sheet" role="dialog" aria-modal="true" aria-label="Depósito">
      <div class="dep-top">
        <button class="dep-back" id="closeDeposit" aria-label="Voltar"><img src="/public/img/seta.png" alt=""></button>
        <div class="dep-title">Depósito</div>
        <div class="dep-balance"><span class="dep-rs">R$</span><span class="dep-val" id="depositBalance">0,00</span></div>
      </div>
      <div class="dep-tabs">
        <div class="dep-tab active">
          <img class="dep-tab-ico" src="/public/img/tel.svg" alt="">
          <span>Depósito online</span>
          <div class="dep-underline"></div>
        </div>
        <div class="dep-actions">
          <button class="dep-ico" aria-label="Suporte"><img src="/public/img/fones.svg" alt=""></button>
          <button class="dep-ico" aria-label="Arquivo"><img src="/public/img/file.svg" alt=""></button>
        </div>
      </div>
      <div class="dep-body">
        <div class="dep-select">
          <div class="dep-pill"><img class="dep-pill-ico" src="/public/img/pix.png" alt=""><span>PIX</span></div>
        </div>
        <div class="dep-card">
          <div class="dep-row"><div class="dep-mini-select"><span>pix08</span><span class="dep-mini-corner"></span></div></div>
          <div class="dep-amount-line"><div class="dep-amount-label">Depósito:</div><div class="dep-amount-value" id="depositShown">R$0,00</div></div>
          <div class="dep-grid" id="depositGrid">
            <button class="dep-chip" data-val="30" type="button">R$30</button>
            <button class="dep-chip" data-val="100" type="button">R$100</button>
            <button class="dep-chip" data-val="200" type="button">R$200</button>
            <button class="dep-chip" data-val="500" type="button">R$500</button>
            <button class="dep-chip" data-val="1000" type="button">R$1000</button>
            <button class="dep-chip" data-val="3000" type="button">R$3000</button>
            <button class="dep-chip" data-val="10000" type="button">R$10000</button>
            <button class="dep-chip" data-val="50000" type="button">R$50000</button>
          </div>
          <div class="dep-input-wrap">
            <div class="dep-input-prefix">R$</div>
            <input class="dep-input" id="depositAmount" inputmode="numeric" placeholder="Minimo30, Máximo50000" />
            <button class="dep-clear" id="depositClear" aria-label="Limpar" type="button"><img src="/public/img/x.svg" alt=""></button>
          </div>
          <div class="dep-sep"></div>
          <div class="dep-reminder">
            <div class="dep-rem-title">Reminder:</div>
            <div class="dep-rem-text">Se você não receber fundos dentro de três minutos após a cobrança, entre em contato com o atendimento ao cliente.</div>
          </div>
          <button class="dep-cta" id="btnRechargeNow" type="button">Recarregue Agora</button>
          <div class="pix-result" id="pixResult" style="display:none;">
            <div class="pix-qr" id="pixQr"></div>
            <textarea class="pix-copy" id="pixCopy" readonly></textarea>
            <div class="pix-actions"><button class="pix-btn" id="btnCopyPix" type="button">Copiar PIX</button></div>
            <div class="pix-meta" id="pixMeta"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- OFFCANVAS -->
  <div class="offcanvas" id="offcanvas" aria-hidden="true">
    <div class="offcanvas-panel" role="dialog" aria-modal="true" aria-label="Menu">
      <div class="oc-top">
        <button class="oc-back" id="closeOffcanvas" aria-label="Voltar"><img src="/public/img/seta.png" alt=""></button>
        <img class="oc-logo" src="/public/img/logo.webp" alt="Cassino">
      </div>
      <div class="oc-usercard oc-usercard-logged" id="ocUserCardLogged">
        <div class="oc-user-left">
          <img class="oc-avatar" src="/public/img/usert.png" alt="">
          <div class="oc-userinfo">
            <div class="oc-name" id="ocUserName">User</div>
            <div class="oc-idrow">
              <div class="oc-id">ID:<span id="ocUserId">-</span></div>
              <button class="oc-copy" id="copyUserId" aria-label="Copiar ID" type="button"><img src="/public/img/copiar.png" alt=""></button>
            </div>
          </div>
        </div>
        <img class="oc-crown" src="/public/img/coroa.png" alt="">
      </div>
      <div class="oc-usercard oc-usercard-guest" id="ocUserCardGuest">
        <div class="oc-auth-row">
          <button class="oc-auth-btn oc-auth-btn-login" id="openLoginFromMenu" type="button">Entrar</button>
          <button class="oc-auth-btn oc-auth-btn-register" id="openRegisterFromMenu" type="button">Registrar</button>
        </div>
      </div>
      <div class="oc-actions">
        <button class="oc-action dep" id="openDepositFromMenu" type="button"><img class="oc-action-ico" src="/public/img/porc.png" alt=""><span>Depósito</span></button>
        <button class="oc-action saque" id="openWithdraw" type="button"><img class="oc-action-ico" src="/public/img/card.png" alt=""><span>Saque</span></button>
      </div>
      <div class="oc-grid">
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/icon8.png" alt=""></span></span><span class="oc-label">VIP</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/icon6.png" alt=""></span></span><span class="oc-label">Convite</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/icon5.png" alt=""></span></span><span class="oc-label">Agente</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/icon4.png" alt=""></span></span><span class="oc-label">Slot</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/icon3.png" alt=""></span></span><span class="oc-label">Tesouro</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/icon7.png" alt=""></span></span><span class="oc-label">Cupom</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/coin.png" alt=""></span></span><span class="oc-label">Resgatar</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/tel2.png" alt=""></span></span><span class="oc-label">Acumulada</span></a>
        <a class="oc-item" href="#"><span class="oc-outer"><span class="oc-inner"><img src="/public/img/calendar.png" alt=""></span></span><span class="oc-label">Check-in</span></a>
      </div>
      <img class="oc-footer-img" src="/public/img/footer2.png" alt="">
      <button class="oc-download" type="button"><img class="oc-download-ico" src="/public/img/down.png" alt=""><span>Baixar o APP</span></button>
    </div>
  </div>

</div>
</div>

<!-- AUTH MODAL -->
<div class="auth" id="authModal" aria-hidden="true">
  <div class="auth-blur"></div>
  <div class="auth-card" role="dialog" aria-modal="true" aria-label="Login e Registro">
    <button class="auth-close" id="authClose" aria-label="Fechar" type="button"><img src="/public/img/xxx.svg" alt=""></button>
    <div class="auth-tabs">
      <button class="auth-tab active" id="tabRegister" type="button">Registro</button>
      <button class="auth-tab" id="tabLogin" type="button">Login</button>
    </div>
    <div class="auth-line"></div>
    <!-- REGISTRO -->
    <div class="auth-pane show" id="paneRegister">
      <div class="auth-hint">Suporta apenas Conta Registro</div>
      <div class="fgroup">
        <div class="finput no-eye">
          <span class="fico left"><img src="/public/img/user.svg" alt=""></span>
          <input id="regUser" type="text" placeholder="* Digite o Conta" autocomplete="off">
          <button class="fico right clear" data-clear="#regUser" type="button" aria-label="Limpar"><img src="/public/img/xx.svg" alt=""></button>
        </div>
        <div class="ferror" id="errRegUser"><img src="/public/img/warn.svg" alt=""><span>Digite o Conta</span></div>
      </div>
      <div class="fgroup">
        <div class="finput no-eye">
          <span class="fico left"><img src="/public/img/lock.svg" alt=""></span>
          <input id="regPass" type="password" placeholder="* Inserir Senha" autocomplete="new-password">
          <button class="fico right clear" data-clear="#regPass" type="button" aria-label="Limpar"><img src="/public/img/xx.svg" alt=""></button>
          <button class="fico right eye" data-eye="#regPass" type="button" aria-label="Mostrar senha"><img src="/public/img/hidd.svg" alt=""></button>
        </div>
        <div class="ferror" id="errRegPass"><img src="/public/img/warn.svg" alt=""><span>6-16 caracteres</span></div>
      </div>
      <div class="fgroup">
        <div class="fphone">
          <button class="ddi" type="button"><img src="/public/img/br.png" alt=""><span>+55</span><span class="ddi-caret">▾</span></button>
          <div class="finput phone no-eye">
            <input id="regPhone" type="tel" placeholder="* Digite o Celular" autocomplete="tel">
            <button class="fico right clear" data-clear="#regPhone" type="button" aria-label="Limpar"><img src="/public/img/xx.svg" alt=""></button>
          </div>
        </div>
      </div>
      <div class="auth-support">Suporte ao cliente?</div>
      <button class="auth-submit" id="btnRegister" type="button">Registro</button>
    </div>
    <!-- LOGIN -->
    <div class="auth-pane" id="paneLogin">
      <div class="auth-hint">Suporta apenas Conta Login</div>
      <div class="fgroup">
        <div class="finput no-eye">
          <span class="fico left"><img src="/public/img/user.svg" alt=""></span>
          <input id="logUser" type="text" placeholder="* Digite o Conta" autocomplete="username">
          <button class="fico right clear" data-clear="#logUser" type="button" aria-label="Limpar"><img src="/public/img/xx.svg" alt=""></button>
        </div>
        <div class="ferror" id="errLogUser"><img src="/public/img/warn.svg" alt=""><span>Digite o Conta</span></div>
      </div>
      <div class="fgroup">
        <div class="finput no-eye">
          <span class="fico left"><img src="/public/img/lock.svg" alt=""></span>
          <input id="logPass" type="password" placeholder="* Inserir Senha" autocomplete="current-password">
          <button class="fico right clear" data-clear="#logPass" type="button" aria-label="Limpar"><img src="/public/img/xx.svg" alt=""></button>
          <button class="fico right eye" data-eye="#logPass" type="button" aria-label="Mostrar senha"><img src="/public/img/hidd.svg" alt=""></button>
        </div>
        <div class="ferror" id="errLogPass"><img src="/public/img/warn.svg" alt=""><span>Inserir Senha</span></div>
      </div>
      <div class="auth-support">Suporte ao cliente?</div>
      <button class="auth-submit" id="btnLogin" type="button">Login</button>
    </div>
  </div>
</div>

<!-- Account / Ranking / Bonus drawers mount -->
<div id="accountMount"></div>
<div id="rankingMount"></div>
<div id="bonusMount"></div>

<!-- TOAST -->
<div class="toast-container" id="toastContainer"></div>

<%- include('partials/foot', { extraJs: ['/public/js/script.js', '/public/js/account.js', '/public/js/ranking.js', '/public/js/bonus.js'] }) %>
