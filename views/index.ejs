    <!-- BOTTOM LINKS -->
    <div class="sidebar-bottom">
      <a href="#" data-tooltip="Suporte ao vivo"><img src="/public/img/novo/suporte11.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Suporte ao vivo</span></a>
      <a href="#" data-tooltip="Promoções"><img src="/public/img/novo/suporte2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Promoções</span></a>
      <a href="#" data-tooltip="Central de Ajuda"><img src="/public/img/novo/suporte3.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Central de Ajuda</span></a>
