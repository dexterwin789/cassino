<%- include('partials/head') %>

<%- include('partials/topbar') %>

<!-- LAYOUT: SIDEBAR + MAIN -->
<div class="app-layout" id="appLayout">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-cards">
      <a href="#" class="sq-card" data-tooltip="Torneios">
        <span class="sq-label">Torneios</span>
        <img src="/public/img/novo/torneios1.svg" class="sq-img" alt="Torneios">
      </a>
      <a href="#" class="sq-card" data-tooltip="Missões">
        <span class="sq-label">Missões</span>
        <img src="/public/img/novo/missoes1.svg" class="sq-img" alt="Missões">
      </a>
      <a href="#" class="sq-card" data-tooltip="Loja">
        <span class="sq-label">Loja</span>
        <img src="/public/img/novo/store1.svg" class="sq-img" alt="Loja">
      </a>
      <a href="/games?category=mines" class="sq-card" data-tooltip="Mini Jogos">
        <span class="sq-label">Mini Jogos</span>
        <img src="/public/img/novo/minigames.svg" class="sq-img" alt="Mini Jogos">
      </a>
      <a href="#" class="sq-card" data-tooltip="Promoções" onclick="if(typeof toggleWallet==='function'){toggleWallet('premios');return false;}">
        <span class="sq-label">Promoções</span>
        <img src="/public/img/novo/promocoes1.svg" class="sq-img" alt="Promoções">
      </a>
      <a href="#" class="sq-card" data-tooltip="Suporte 24h">
        <span class="sq-label">Suporte 24h</span>
        <img src="/public/img/novo/suporte1.svg" class="sq-img" alt="Suporte">
      </a>
    </div>

    <div class="sidebar-promos sb-full">
      <a href="#" class="promo-banner">
        <img src="/public/img/novo/calendario.png" alt="Calendário" width="218" height="73">
      </a>
      <a href="#" class="promo-banner">
        <img src="/public/img/novo/app.png" alt="Baixe nosso app" width="218" height="73">
      </a>
    </div>

    <div class="sidebar-menu">
      <div class="menu-title sb-full" id="menuCassinoToggle">
        CASSINO
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <ul class="menu-list" id="menuCassinoList">
        <li class="active" data-filter="all" data-tooltip="Todos os jogos" onclick="window.location='/games'"><img src="/public/img/novo/1.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Todos os jogos</span></li>
        <li data-filter="slots" data-tooltip="Jogos Slots" onclick="window.location='/games?category=slots'"><img src="/public/img/novo/2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Jogos Slots</span></li>
        <li data-filter="live" data-tooltip="Cassino ao vivo" onclick="window.location='/games?category=live'"><img src="/public/img/novo/3.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Cassino ao vivo</span></li>
        <li data-filter="providers" data-tooltip="Provedores" onclick="window.location='/providers'"><img src="/public/img/novo/4.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Provedores</span></li>
        <li data-filter="mines" data-tooltip="Mines" onclick="window.location='/games?category=mines'"><img src="/public/img/novo/5.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Mines</span></li>
        <li data-filter="fortune" data-tooltip="Fortune Tiger" onclick="window.location='/games?category=pg'"><img src="/public/img/novo/6.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Fortune Tiger</span></li>
        <li data-filter="aviator" data-tooltip="Aviator" onclick="window.location='/games?category=crash'"><img src="/public/img/novo/7.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Aviator</span></li>
        <li data-filter="spaceman" data-tooltip="Spaceman" onclick="window.location='/games?category=crash'"><img src="/public/img/novo/8.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Spaceman</span></li>
        <li data-filter="blackjack" data-tooltip="Infinite Blackjack" onclick="window.location='/games?category=live'"><img src="/public/img/novo/9.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Infinite Blackjack</span></li>
        <li data-filter="roleta" data-tooltip="Roleta brasileira" onclick="window.location='/games?category=live'"><img src="/public/img/novo/10.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Roleta brasileira</span></li>
        <li data-filter="footbal" data-tooltip="Footbal Studio" onclick="window.location='/games?category=live'"><img src="/public/img/novo/11.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Footbal Studio</span></li>
        <li data-filter="fruits" data-tooltip="Fortune Fruits" onclick="window.location='/games?category=pg'"><img src="/public/img/novo/12.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Fortune Fruits</span></li>
        <li data-filter="pirates" data-tooltip="Fortune Pirates" onclick="window.location='/games?category=pg'"><img src="/public/img/novo/13.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Fortune Pirates</span></li>
      </ul>
    </div>

    <!-- ESPORTES (group: Esportes + Popular + Top5) -->
    <% if (locals.sportsEnabled) { %>
    <div class="sidebar-menu sidebar-section-border" id="esportesGroup">
      <div class="menu-title sb-full" id="menuEsportesToggle">
        ESPORTES
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <ul class="menu-list" id="menuEsportesList">
        <li data-tooltip="Jogos ao Vivo"><img src="/public/img/novo/esportes1.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Jogos ao Vivo</span></li>
        <li data-tooltip="Começa em breve"><img src="/public/img/novo/esportes2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Começa em breve</span></li>
        <li data-tooltip="E-Sports"><img src="/public/img/novo/esportes3.svg" class="mi" width="20" height="20" alt=""> <span class="ml">E-Sports</span></li>
      </ul>

      <div class="menu-title sb-full" style="margin-top:4px">POPULAR</div>
      <ul class="menu-list" id="menuPopularList">
        <li data-tooltip="Brasileirão Série A"><img src="/public/img/novo/popular1.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Brasileirão Série A</span></li>
        <li data-tooltip="Copa Libertadores"><img src="/public/img/novo/popular2.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Copa Libertadores</span></li>
        <li data-tooltip="Premier League (Inglês)"><img src="/public/img/novo/popular3.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Premier League (Inglês)</span></li>
        <li data-tooltip="La Liga (Espanhol)"><img src="/public/img/novo/popular4.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">La Liga (Espanhol)</span></li>
        <li data-tooltip="Serie A (Italiano)"><img src="/public/img/novo/popular5.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Serie A (Italiano)</span></li>
        <li data-tooltip="Ligue 1 (França)"><img src="/public/img/novo/popular6.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Ligue 1 (França)</span></li>
        <li data-tooltip="Bundesliga (Alemanha)"><img src="/public/img/novo/popular7.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Bundesliga (Alemanha)</span></li>
        <li data-tooltip="UEFA Champions League"><img src="/public/img/novo/popular8.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">UEFA Champions League</span></li>
        <li data-tooltip="NBA (EUA)"><img src="/public/img/novo/popular9.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">NBA (EUA)</span></li>
        <li data-tooltip="NFL (EUA)"><img src="/public/img/novo/popular10.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">NFL (EUA)</span></li>
      </ul>

      <div class="menu-title sb-full" style="margin-top:4px">TOP 5 ESPORTES</div>
      <ul class="menu-list" id="menuTop5List">
        <li data-tooltip="Futebol"><img src="/public/img/novo/top1.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Futebol</span></li>
        <li data-tooltip="Tênis"><img src="/public/img/novo/top2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Tênis</span></li>
        <li data-tooltip="Basquete"><img src="/public/img/novo/top3.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Basquete</span></li>
        <li data-tooltip="Vôlei"><img src="/public/img/novo/top4.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Vôlei</span></li>
        <li data-tooltip="Esportes Virtuais"><img src="/public/img/novo/top5.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Esportes Virtuais</span></li>
      </ul>
    </div>
    <% } %>

    <!-- BOTTOM LINKS -->
    <div class="sidebar-bottom">
      <a href="#" data-tooltip="Suporte ao vivo"><img src="/public/img/novo/suporte11.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Suporte ao vivo</span></a>
      <a href="#" data-tooltip="Promoções"><img src="/public/img/novo/suporte2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Promoções</span></a>
      <a href="#" data-tooltip="Central de Ajuda"><img src="/public/img/novo/suporte3.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Central de Ajuda</span></a>
      <a href="#" data-tooltip="Baixar App"><img src="/public/img/novo/suporte4.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Baixar App</span></a>
      <a href="#" data-tooltip="Blog"><img src="/public/img/novo/suporte5.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Blog</span></a>
    </div>

    <div class="sidebar-lang sb-full">
      <img src="https://flagcdn.com/w40/br.png" alt="BR"> Português
      <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main-content" id="mainContent">
    <div class="main-container">

    <!-- Home content (hidden when wallet is open) -->
    <div id="homeContent">

    <section class="category-icons">
      <% if (locals.sportsEnabled) { %>
      <a href="#" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/esportes_svg.svg" width="60" height="60" alt="Esportes"></div>
        <span>Esportes</span>
      </a>
      <% } %>
      <a href="#" class="cat-icon-item" onclick="if(typeof toggleWallet==='function'){toggleWallet('premios');return false;}">
        <div class="cat-icon-circle"><img src="/public/img/promocoes_svg.svg" width="60" height="60" alt="Promoções"></div>
        <span>Promoções</span>
      </a>
      <a href="/games?category=live" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/roleta_svg.svg" width="60" height="60" alt="Cassino"></div>
        <span>Cassino</span>
      </a>
      <a href="/game/aviator" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/aviator.png" width="60" height="60" alt="Aviator"></div>
        <span>Aviator</span>
      </a>
      <a href="/games" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/cartas_svg.svg" width="60" height="60" alt="Slots"></div>
        <span>Slots</span>
      </a>
      <% if (locals.sportsEnabled) { %>
      <a href="#" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/novo/controle_svg.svg" width="60" height="60" alt="E-Sports"></div>
        <span>E-Sports</span>
      </a>
      <% } %>
      <a href="/games?category=crash" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/calendar.png" width="60" height="60" alt="Crash"></div>
        <span>Crash</span>
      </a>
      <a href="/games?category=mines" class="cat-icon-item">
        <div class="cat-icon-circle"><img src="/public/img/mines_svg.svg" width="60" height="60" alt="Mines"></div>
        <span>Mines</span>
      </a>
      <a href="#" class="cat-icon-item is-logged-el" onclick="if(typeof toggleWallet==='function'){toggleWallet('indique');return false;}">
        <div class="cat-icon-circle"><img src="/public/img/indique_e_ganhe_svg.svg" width="60" height="60" alt="Indique"></div>
        <span>Indique</span>
      </a>
    </section>

    <section class="banner-area">
      <div class="banner-main" id="bannerMain">
        <% if (typeof banners !== 'undefined' && banners.length) { %>
          <div class="banner-slider" id="bannerSlider">
            <% banners.forEach(function(b, i) { %>
            <a href="<%= b.link_url || '#' %>" class="banner-slide <%= i === 0 ? 'active' : '' %>">
              <img src="<%= b.image_url %>" alt="Banner" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
            </a>
            <% }); %>
          </div>
          <div class="banner-dots" id="bannerDots"></div>
          <button class="banner-arrow banner-prev" id="bannerPrev">&#8249;</button>
          <button class="banner-arrow banner-next" id="bannerNext">&#8250;</button>
        <% } %>
      </div>
      <div class="banner-side">
        <% if (typeof sideBanner1 !== 'undefined' && sideBanner1) { %>
          <a href="<%= typeof sideBanner1Link !== 'undefined' ? sideBanner1Link : '#' %>" class="banner-side-item">
            <img src="<%= sideBanner1 %>" alt="Promo" loading="lazy">
          </a>
        <% } else if (typeof banners !== 'undefined' && banners.length > 1) { %>
          <a href="<%= banners[1] ? banners[1].link_url || '#' : '#' %>" class="banner-side-item">
            <img src="<%= banners[1] ? banners[1].image_url : '' %>" alt="Promo" loading="lazy">
          </a>
        <% } %>
        <% if (typeof sideBanner2 !== 'undefined' && sideBanner2) { %>
          <a href="<%= typeof sideBanner2Link !== 'undefined' ? sideBanner2Link : '#' %>" class="banner-side-item">
            <img src="<%= sideBanner2 %>" alt="Promo" loading="lazy">
          </a>
        <% } else if (typeof banners !== 'undefined' && banners.length > 2) { %>
          <a href="<%= banners[2] ? banners[2].link_url || '#' : '#' %>" class="banner-side-item">
            <img src="<%= banners[2] ? banners[2].image_url : '' %>" alt="Promo" loading="lazy">
          </a>
        <% } %>
      </div>
    </section>

    <section class="search-section" id="searchSection">
      <div class="search-box" id="searchBox">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="searchGames" name="search_games_nofill_x" placeholder="Pesquise um jogo de cassino..." autocomplete="off" role="presentation" data-lpignore="true" data-form-type="other" data-1p-ignore="true" aria-autocomplete="none">
        <button class="search-close" id="searchClose">&times;</button>
      </div>
      <div class="search-results" id="searchResults">
        <div class="search-message" id="searchMessage" style="display:none"></div>
        <div class="search-results-tags" id="searchTags"></div>
        <div class="search-results-grid" id="searchGrid"></div>
        <div class="search-results-footer" id="searchFooter" style="display:none">
          <div class="search-results-count" id="searchCount"></div>
          <button class="search-load-more" id="searchLoadMore">Carregar mais</button>
        </div>
      </div>
    </section>
    <div class="search-overlay" id="searchOverlay"></div>

    <section class="game-section top10-section">
      <div class="section-header"><h2>Em alta</h2><a href="/games" class="see-all">Ver todos</a></div>
      <div class="top10-slider-wrap">
        <button class="top10-arrow top10-prev" aria-label="Anterior">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="top10-viewport">
          <div class="top10-track" id="top10Track"></div>
        </div>
        <button class="top10-arrow top10-next" aria-label="Próximo">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </section>

    <!-- Cassino ao Vivo -->
    <section class="game-section">
      <div class="section-header"><h2>Cassino ao Vivo</h2><a href="/games?category=live" class="see-all">Ver todos</a></div>
      <div class="category-games-scroll" id="liveGamesScroll"></div>
    </section>

    <!-- Crash -->
    <section class="game-section">
      <div class="section-header"><h2>Crash</h2><a href="/games?category=crash" class="see-all">Ver todos</a></div>
      <div class="category-games-scroll" id="crashGamesScroll"></div>
    </section>

    <!-- Principais Ligas -->
    <% if (locals.sportsEnabled) { %>
    <section class="principais-ligas">
      <div class="ligas-bar"><span>🏆 Principais Ligas</span></div>
      <div class="ligas-row">
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin1.svg" alt="Brasileirão" width="40" height="40"></div>
          <div class="liga-name"><span>Brasileirão</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin2.svg" alt="Copa do Brasil" width="40" height="40"></div>
          <div class="liga-name"><span>Copa do</span><span>Brasil</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin3.svg" alt="Europa League" width="40" height="40"></div>
          <div class="liga-name"><span>Europa</span><span>League</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin4.svg" alt="Libertadores" width="40" height="40"></div>
          <div class="liga-name"><span>Libertadores</span></div>
        </a>
        <a href="#" class="liga-item liga-hot">
          <div class="liga-icon"><img src="/public/img/novo/prin5.svg" alt="Premier League" width="40" height="40"></div>
          <div class="liga-hot-badge"><span>🔥</span><span>HOT</span></div>
          <div class="liga-name"><span>Premier</span><span>League</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin6.svg" alt="La Liga" width="40" height="40"></div>
          <div class="liga-name"><span>La Liga</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin7.svg" alt="Itália Série A" width="40" height="40"></div>
          <div class="liga-name"><span>Itália</span><span>Série A</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin8.svg" alt="Bundesliga" width="40" height="40"></div>
          <div class="liga-name"><span>Bundesliga</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin9.svg" alt="Ligue 1" width="40" height="40"></div>
          <div class="liga-name"><span>Ligue 1</span></div>
        </a>
        <a href="#" class="liga-item">
          <div class="liga-icon"><img src="/public/img/novo/prin10.svg" alt="NBA" width="40" height="40"></div>
          <div class="liga-name"><span>NBA</span></div>
        </a>
      </div>
    </section>
    <% } %>

    <!-- Provider Filter + Dynamic Games Grid -->
    <section class="game-section">
      <div class="section-header" style="flex-wrap:wrap;gap:10px">
        <h2 id="providerSectionTitle">Todos os Jogos</h2>
        <div style="display:flex;gap:8px;align-items:center;margin-left:auto">
          <div class="home-provider-wrap">
            <button class="archive-provider-btn" id="homeProviderBtn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0"><path d="M4 6h16M4 12h16M4 18h7"/></svg>
              Provedor: <span id="homeProviderLabel">Todos</span>
            </button>
            <div class="archive-provider-dropdown" id="homeProviderDropdown">
              <label class="archive-provider-item" style="font-weight:600;border-bottom:1px solid rgba(255,255,255,.08);padding-bottom:6px;margin-bottom:4px">
                <input type="radio" name="homeProv" value="" class="home-prov-radio" checked> Todos os Provedores
              </label>
            </div>
          </div>
          <a href="/games" class="see-all">Ver todos</a>
        </div>
      </div>
      <div class="provider-grid" id="homeFilteredGrid"></div>
      <div style="text-align:center;margin-top:16px">
        <button class="archive-load-more" id="homeLoadMore" style="display:none">Carregar mais</button>
      </div>
    </section>

    <!-- Estúdios -->
    <section class="game-section estudios-section">
      <div class="section-header"><h2>Estúdios</h2><a href="/providers" class="see-all">Ver todos</a></div>
      <div class="estudios-grid">
        <% (providerImages || []).forEach(function(pi) { %>
        <a href="/games?provider=<%= encodeURIComponent(pi.provider_name) %>" class="estudio-card"><img src="<%= pi.image_url %>" alt="<%= pi.provider_name %>"></a>
        <% }); %>
      </div>
    </section>

    <!-- Maiores Ganhos -->
    <section class="game-section ganhos-section">
      <div class="ganhos-tabs">
        <button class="ganhos-tab" data-period="hoje">Hoje</button>
        <button class="ganhos-tab" data-period="3dias">3 Dias</button>
        <button class="ganhos-tab" data-period="7dias">7 dias</button>
        <button class="ganhos-tab active" data-period="15dias">15 dias</button>
      </div>
      <div class="ganhos-strip">
        <div class="ganhos-trophy-card">
          <img src="/public/img/novo/trophy.webp" alt="Trophy" class="ganhos-trophy-img">
          <div class="ganhos-trophy-text">MAIORES<br>GANHOS</div>
        </div>
        <div class="ganhos-scroll-wrapper">
          <div class="ganhos-scroll-track" id="ganhosTrack"></div>
        </div>
      </div>
    </section>

    <!-- Últimas Apostas -->
    <section class="game-section apostas-section">
