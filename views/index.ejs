        <li data-tooltip="Serie A (Italiano)"><img src="/public/img/novo/popular5.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Serie A (Italiano)</span></li>
        <li data-tooltip="Ligue 1 (França)"><img src="/public/img/novo/popular6.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Ligue 1 (França)</span></li>
        <li data-tooltip="Bundesliga (Alemanha)"><img src="/public/img/novo/popular7.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">Bundesliga (Alemanha)</span></li>
        <li data-tooltip="UEFA Champions League"><img src="/public/img/novo/popular8.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">UEFA Champions League</span></li>
        <li data-tooltip="NBA (EUA)"><img src="/public/img/novo/popular9.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">NBA (EUA)</span></li>
        <li data-tooltip="NFL (EUA)"><img src="/public/img/novo/popular10.svg" class="mi grayscale" width="20" height="20" alt=""> <span class="ml">NFL (EUA)</span></li>
      </ul>

      <div class="menu-title sb-full" style="margin-top:4px">TOP 5 ESPORTES</div>
      <ul class="menu-list" id="menuTop5List">
        <li data-tooltip="Futebol"><img src="/public/img/novo/top1.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Futebol</span></li>
        <li data-tooltip="Tênis"><img src="/public/img/novo/top2.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Tênis</span></li>
        <li data-tooltip="Basquete"><img src="/public/img/novo/top3.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Basquete</span></li>
        <li data-tooltip="Vôlei"><img src="/public/img/novo/top4.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Vôlei</span></li>
        <li data-tooltip="Esportes Virtuais"><img src="/public/img/novo/top5.svg" class="mi" width="20" height="20" alt=""> <span class="ml">Esportes Virtuais</span></li>
