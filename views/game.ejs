<%- include('partials/head') %>

<%- include('partials/topbar') %>

<div class="app-layout" id="appLayout">
  <%- include('partials/sidebar') %>

  <main class="main-content" id="mainContent">
    <div class="main-container">

      <!-- Game Hero Section -->
      <section class="gp-hero" id="gpHero">
        <!-- Blurred background image -->
        <div class="gp-hero-bg" style="background-image:url('<%= game.image_url %>')"></div>
        <div class="gp-hero-overlay"></div>
        <a href="/" class="gp-fs-back" id="gpFsBack" style="display:none">&#8249;</a>
        <button class="gp-fs-close" id="gpFsClose" style="display:none">&times;</button>
        <div class="gp-hero-content">
          <div class="gp-hero-image" id="gpHeroImage">
            <img src="<%= game.image_url %>" alt="<%= game.game_name %>" draggable="false">
          </div>
          <div class="gp-hero-actions is-guest-el">
            <p class="gp-hero-cta">Vocę precisa entrar para jogar</p>
            <span class="gp-responsible-label">Jogo Responsável</span>
            <button class="btn-register" id="heroRegister">Registre-se</button>
            <button class="btn-login" id="heroLogin">Entrar</button>
          </div>
          <div class="gp-play-area is-logged-el" id="gpPlayArea">
            <button class="gp-play-btn" id="gpPlayBtn">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              JOGAR AGORA
            </button>
            <div class="gp-game-loading" id="gpGameLoading" style="display:none">
              <div class="gp-spinner"></div>
              <span>Carregando jogo...</span>
            </div>
          </div>
          <iframe id="gpGameIframe" class="gp-game-iframe" style="display:none" allowfullscreen allow="autoplay; fullscreen"></iframe>
        </div>
      </section>

      <!-- Game Info Bar -->
      <section class="gp-info-bar">
        <div class="gp-info-left">
          <h1 class="gp-game-name"><%= game.game_name %></h1>
          <span class="gp-provider-name"><%= game.provider ? game.provider.toUpperCase() : '' %></span>
        </div>
        <div class="gp-info-right">
          <button class="gp-action-btn" title="Gostei">
            <svg width="18" height="18" viewBox="0 0 512 512" fill="currentColor"><path d="M512 224.112C512 197.608 490.516 176.133 464 176.133H317.482C340.25 138.226 352.005 95.257 352.005 80.11C352.005 56.523 333.495 32 302.54 32C239.411 32 276.176 108.148 194.312 173.618L178.016 186.644C166.23 196.06 160.285 209.903 160.215 223.897C160.191 223.921 160 224.112 160 224.112V384.042C160 399.146 167.113 413.368 179.198 422.427L213.336 448.02C241.027 468.779 274.702 480 309.309 480H368C394.516 480 416 458.525 416 432.021C416 428.386 415.52 424.878 414.754 421.475C434 415.228 448 397.37 448 376.045C448 366.897 445.303 358.438 440.861 351.164C463.131 347.002 480 327.547 480 304.077C480 291.577 475.107 280.298 467.275 271.761C492.234 270.051 512 249.495 512 224.112Z"/><path d="M128 448V224C128 206.328 113.674 192 96 192H32C14.326 192 0 206.328 0 224V448C0 465.674 14.326 480 32 480H96C113.674 480 128 465.674 128 448Z" opacity="0.4"/></svg>
            <span><%= Math.floor(100 + Math.random() * 900) %></span>
          </button>
          <button class="gp-action-btn" title="Năo gostei">
            <svg width="18" height="18" viewBox="0 0 512 512" fill="currentColor"><path d="M467.275 240.239C475.107 231.702 480 220.423 480 207.923C480 184.453 463.131 164.998 440.861 160.836C445.303 153.562 448 145.103 448 135.955C448 114.63 434 96.772 414.754 90.525C415.52 87.122 416 83.614 416 79.979C416 53.475 394.516 32 368 32H309.309C274.702 32 241.027 43.221 213.336 63.98L179.198 89.573C167.113 98.632 160 112.854 160 127.958V287.888C160 287.888 160.191 288.079 160.215 288.103C160.285 302.097 166.23 315.94 178.016 325.356L194.312 338.382C276.176 403.852 239.411 480 302.54 480C333.495 480 352.005 455.477 352.005 431.89C352.005 416.743 340.25 373.774 317.482 335.867H464C490.516 335.867 512 314.392 512 287.888C512 262.505 492.234 241.949 467.275 240.239Z"/><path d="M96 32H32C14.326 32 0 46.326 0 64V288C0 305.672 14.326 320 32 320H96C113.674 320 128 305.672 128 288V64C128 46.326 113.674 32 96 32Z" opacity="0.4"/></svg>
          </button>
          <button class="gp-action-btn gp-fullscreen-btn" id="gpFullscreenBtn" title="Tela cheia">
            <svg width="18" height="18" viewBox="0 0 512 512" fill="currentColor"><path d="M128 64H32C14.31 64 0 78.31 0 96v96c0 17.69 14.31 32 32 32s32-14.31 32-32V128h64c17.69 0 32-14.31 32-32S145.7 64 128 64zM480 288c-17.69 0-32 14.31-32 32v64h-64c-17.69 0-32 14.31-32 32s14.31 32 32 32h96c17.69 0 32-14.31 32-32v-96C512 302.3 497.7 288 480 288z"/><path d="M480 64h-96c-17.69 0-32 14.31-32 32s14.31 32 32 32h64v64c0 17.69 14.31 32 32 32s32-14.31 32-32V96C512 78.31 497.7 64 480 64zM128 384H64v-64c0-17.69-14.31-32-32-32s-32 14.31-32 32v96c0 17.69 14.31 32 32 32h96c17.69 0 32-14.31 32-32S145.7 384 128 384z" opacity="0.4"/></svg>
          </button>
        </div>
      </section>

      <!-- Stats Section -->
      <section class="gp-stats">
        <div class="gp-stat-card">
          <div class="gp-stat-icon">
            <svg width="20" height="20" viewBox="0 0 384 512" fill="currentColor"><path d="M214.6 41.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L160 141.2V448c0 17.7 14.3 32 32 32s32-14.3 32-32V141.2L329.4 246.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z"/></svg>
          </div>
          <div class="gp-stat-text">
            <span class="gp-stat-label">Ganhos nas últimas 24 horas</span>
            <span class="gp-stat-value gp-stat-money">R$&nbsp;<%= Number(stats.ganhos24h).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
          </div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-icon">
            <svg width="20" height="20" viewBox="0 0 512 512" fill="currentColor"><path d="M256 272c39.77 0 72-32.24 72-72S295.8 128 256 128C216.2 128 184 160.2 184 200S216.2 272 256 272zM288 320H224c-47.54 0-87.54 29.88-103.7 71.71C155.1 426.5 203.1 448 256 448s100.9-21.53 135.7-56.29C375.5 349.9 335.5 320 288 320z"/><path d="M256 0C114.6 0 0 114.6 0 256s114.6 256 256 256s256-114.6 256-256S397.4 0 256 0zM256 128c39.77 0 72 32.24 72 72S295.8 272 256 272c-39.76 0-72-32.24-72-72S216.2 128 256 128zM256 448c-52.93 0-100.9-21.53-135.7-56.29C136.5 349.9 176.5 320 224 320h64c47.54 0 87.54 29.88 103.7 71.71C356.9 426.5 308.9 448 256 448z" opacity="0.4"/></svg>
          </div>
          <div class="gp-stat-text">
            <span class="gp-stat-label">Jogadores nas últimas 24 horas</span>
            <span class="gp-stat-value"><%= stats.players24h.toLocaleString('pt-BR') %></span>
          </div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-icon">
            <svg width="20" height="20" viewBox="0 0 640 512" fill="currentColor"><path d="M554.9 154.5c-17.62-35.25-68.12-35.38-85.87 0c-86.1 174.3-84.1 165.9-84.1 181.5c0 44.13 57.25 80 128 80s127.1-35.88 127.1-80C639.1 319.9 641.4 327.3 554.9 154.5zM439.1 320l71.96-144l72.17 144H439.1zM85 154.5C-1.998 328.8 .0019 320.4 .0019 336c0 44.13 57.25 80 127.1 80s128-35.88 128-80c0-16.12 1.375-8.75-85.12-181.5C153.3 119.3 102.8 119.1 85 154.5zM55.96 320l71.96-144L200.1 320H55.96z"/><path d="M495.1 448h-143.1V153.3C375.5 143 393.1 121.8 398.4 96h113.6c17.67 0 31.1-14.33 31.1-32s-14.33-32-31.1-32h-128.4c-14.62-19.38-37.5-32-63.62-32S270.1 12.62 256.4 32H128C110.3 32 96 46.33 96 64S110.3 96 127.1 96h113.6C246.9 121.8 264.5 143 287.1 153.3V448H144c-26.51 0-48.01 21.49-48.01 48c0 8.836 7.165 16 16 16h416c8.836 0 16-7.164 16-16C544 469.5 522.5 448 495.1 448z" opacity="0.4"/></svg>
          </div>
          <div class="gp-stat-text">
            <span class="gp-stat-label">RTP nas últimas 24 horas</span>
            <span class="gp-stat-value gp-stat-rtp"><%= stats.rtp %>%</span>
          </div>
        </div>
      </section>

      <!-- Related Games Slider -->
      <% if (relatedGames.length > 0) { %>
      <section class="game-section gp-related-section">
        <div class="section-header">
          <h2>Jogos Relacionados</h2>
          <div class="gp-slider-nav">
            <button class="gp-slider-arrow gp-related-prev" aria-label="Anterior">&#8249;</button>
            <button class="gp-slider-arrow gp-related-next" aria-label="Próximo">&#8250;</button>
          </div>
        </div>
        <div class="gp-slider-viewport">
          <div class="gp-slider-track" id="relatedTrack">
            <% relatedGames.forEach(function(rg) { %>
            <a href="/game/<%= rg.game_code %>" class="game-card gp-slider-card" title="<%= rg.game_name %>" style="text-decoration:none">
              <img src="<%= rg.image_url %>" alt="<%= rg.game_name %>" draggable="false" loading="lazy">
              <div class="game-overlay">
                <span class="play-btn">&#9654; JOGAR</span>
              </div>
            </a>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <!-- Providers / Estudios Slider -->
      <section class="game-section gp-providers-section">
        <div class="section-header">
          <h2>Estúdios</h2>
          <div class="gp-slider-nav">
            <button class="gp-slider-arrow gp-studios-prev" aria-label="Anterior">&#8249;</button>
            <button class="gp-slider-arrow gp-studios-next" aria-label="Próximo">&#8250;</button>
          </div>
          <a href="/games" class="see-all">Ver todos</a>
        </div>
        <div class="gp-slider-viewport">
          <div class="gp-slider-track gp-studios-track" id="studiosTrack">
            <% if (typeof providerImages !== 'undefined' && providerImages.length) { %>
              <% for (var r = 0; r < 3; r++) { %>
                <% providerImages.forEach(function(pi) { %>
                <a href="/games?provider=<%= encodeURIComponent(pi.provider_name) %>" class="estudio-card" style="text-decoration:none">
                  <img src="<%= pi.image_url %>" alt="<%= pi.provider_name %>" loading="lazy">
                </a>
                <% }); %>
              <% } %>
            <% } %>
          </div>
        </div>
      </section>

      <%- include('partials/footer') %>

    </div>
  </main>
</div>

<!-- Bottom nav mobile -->
<nav class="bottom-nav">
  <a href="/" class="bnav-item active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    <span>Início</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-search">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span>Buscar</span>
  </a>
  <button class="bnav-item bnav-deposit" id="bnav-deposit">
    <div class="bnav-deposit-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </div>
    <span>Depositar</span>
  </button>
  <a href="#" class="bnav-item" id="bnav-promos">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12v10H4V12M2 7h20v5H2zM12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
    <span>Promoçőes</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
    <span>Menu</span>
  </a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<%- include('partials/login-modal') %>

<div id="toastContainer" class="toast-container"></div>

<script src="/public/js/script.js"></script>
<script>
(function(){
  /* === Slider helper === */
  function initSlider(trackId, prevSel, nextSel) {
    var track = document.getElementById(trackId);
    if (!track) return;
    var prev = document.querySelector(prevSel);
    var next = document.querySelector(nextSel);
    var cardW = 0;

    function getCardWidth() {
      var first = track.children[0];
      if (!first) return 200;
      return first.offsetWidth + parseInt(getComputedStyle(track).gap || '16');
    }

    if (prev) prev.addEventListener('click', function() {
      cardW = getCardWidth();
      track.parentElement.scrollBy({ left: -cardW, behavior: 'smooth' });
    });
    if (next) next.addEventListener('click', function() {
      cardW = getCardWidth();
      track.parentElement.scrollBy({ left: cardW, behavior: 'smooth' });
    });
  }

  initSlider('relatedTrack', '.gp-related-prev', '.gp-related-next');
  initSlider('studiosTrack', '.gp-studios-prev', '.gp-studios-next');

  /* === Fullscreen toggle === */
  var hero = document.getElementById('gpHero');
  var fsBtn = document.getElementById('gpFullscreenBtn');
  var fsClose = document.getElementById('gpFsClose');
  var fsBack = document.getElementById('gpFsBack');

  function enterFullscreen() {
    if (!hero) return;
    hero.classList.add('gp-fullscreen');
    if (fsClose) fsClose.style.display = 'flex';
    if (fsBack) fsBack.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
  function exitFullscreen() {
    if (!hero) return;
    hero.classList.remove('gp-fullscreen');
    if (fsClose) fsClose.style.display = 'none';
    if (fsBack) fsBack.style.display = 'none';
    document.body.style.overflow = '';
  }
  if (fsBtn) fsBtn.addEventListener('click', enterFullscreen);
  if (fsClose) fsClose.addEventListener('click', exitFullscreen);
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') exitFullscreen(); });

  /* === Footer SEO toggle === */
  var seoToggle = document.getElementById('footerSeoToggle');
  var seoMore = document.getElementById('footerSeoMore');
  if (seoToggle && seoMore) {
    seoToggle.addEventListener('click', function() {
      var open = seoMore.style.display !== 'none';
      seoMore.style.display = open ? 'none' : 'block';
      seoToggle.textContent = open ? 'Ver mais' : 'Ver menos';
    });
  }

  /* === Game Launch via PlayFivers === */
  var playBtn = document.getElementById('gpPlayBtn');
  var gameLoading = document.getElementById('gpGameLoading');
  var gameIframe = document.getElementById('gpGameIframe');
  var heroImage = document.getElementById('gpHeroImage');
  var playArea = document.getElementById('gpPlayArea');
  var gameCode = '<%= game.game_code %>';

  if (playBtn) {
    playBtn.addEventListener('click', function() {
      playBtn.style.display = 'none';
      if (gameLoading) gameLoading.style.display = 'flex';

      fetch('/api/game/launch', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ game_code: gameCode })
      })
      .then(function(r) { return r.json(); })
      .then(function(j) {
        if (gameLoading) gameLoading.style.display = 'none';
        if (j.ok && j.launch_url) {
          // Show iframe, hide hero image
          if (heroImage) heroImage.style.display = 'none';
          if (playArea) playArea.style.display = 'none';
          if (gameIframe) {
            gameIframe.src = j.launch_url;
            gameIframe.style.display = 'block';
          }
          // Auto enter a wider view
          if (hero) hero.classList.add('gp-playing');
        } else {
          if (typeof showToast === 'function') showToast(j.msg || 'Erro ao iniciar jogo', 'error');
          playBtn.style.display = '';
        }
      })
      .catch(function(err) {
        if (gameLoading) gameLoading.style.display = 'none';
        if (typeof showToast === 'function') showToast('Erro ao conectar', 'error');
        playBtn.style.display = '';
      });
    });
  }

})();
</script>
<%- include('partials/foot') %>
