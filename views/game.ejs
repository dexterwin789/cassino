<%- include('partials/head') %>

<!-- TOP BAR -->
<header class="topbar" id="topbar">
  <div class="topbar-tabs" id="topbarTabs">
    <button class="tab-switch active" data-tab="cassino">
      <img src="/public/img/novo/carta1.svg" width="17" height="17" alt="Cassino">
      CASSINO
    </button>
    <button class="tab-switch" data-tab="esportes">
      <img src="/public/img/novo/bola1.svg" width="17" height="17" alt="Esportes">
      ESPORTES
    </button>
  </div>
  <div class="topbar-container">
    <button class="bars-toggle" id="barsToggle" title="Toggle sidebar">
      <img src="/public/img/novo/bars1.svg" width="16" height="16" alt="Menu">
    </button>
    <a href="/" class="topbar-logo">
      <img src="/public/img/novo/logo.png" alt="CassinoBet" class="logo-img">
    </a>
    <div class="topbar-spacer"></div>
    <span class="responsible-label is-guest-el">Jogo Responsável</span>
    <div class="topbar-auth is-guest-el">
      <button class="btn-register" id="btnOpenRegister">Registre-se</button>
      <button class="btn-login" id="btnOpenLogin">Entrar</button>
    </div>
  </div>
</header>

<div class="app-layout" id="appLayout">
  <%- include('partials/sidebar') %>

  <main class="main-content" id="mainContent">
    <div class="main-container">

      <!-- Game Hero Section -->
      <section class="gp-hero">
        <!-- Blurred background image -->
        <div class="gp-hero-bg" style="background-image:url('<%= game.image_url %>')"></div>
        <div class="gp-hero-overlay"></div>
        <div class="gp-hero-content">
          <div class="gp-hero-image">
            <img src="<%= game.image_url %>" alt="<%= game.game_name %>" draggable="false">
          </div>
          <p class="gp-hero-cta">Você precisa entrar para jogar</p>
          <div class="gp-hero-actions">
            <span class="gp-responsible-label">Jogo Responsável</span>
            <button class="btn-register" id="heroRegister">Registre-se</button>
            <button class="btn-login" id="heroLogin">Entrar</button>
          </div>
        </div>
      </section>

      <!-- Game Info Bar -->
      <section class="gp-info-bar">
        <div class="gp-info-left">
          <h1 class="gp-game-name"><%= game.game_name %></h1>
          <span class="gp-provider-name"><%= game.provider ? game.provider.toUpperCase() : '' %></span>
        </div>
        <div class="gp-info-right">
          <button class="gp-action-btn" title="Gostei">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/></svg>
            <span><%= Math.floor(100 + Math.random() * 900) %></span>
          </button>
          <button class="gp-action-btn" title="Não gostei">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 15V19a3 3 0 0 0 3 3l4-9V2H5.72a2 2 0 0 0-2 1.7l-1.38 9a2 2 0 0 0 2 2.3H10z"/><path d="M17 2h2.67A2.31 2.31 0 0 1 22 4v7a2.31 2.31 0 0 1-2.33 2H17"/></svg>
            <span><%= Math.floor(10 + Math.random() * 90) %></span>
          </button>
          <button class="gp-action-btn gp-fullscreen-btn" title="Tela cheia">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>
          </button>
        </div>
      </section>

      <!-- Stats Section -->
      <section class="gp-stats">
        <div class="gp-stat-card">
          <div class="gp-stat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <div class="gp-stat-text">
            <span class="gp-stat-label">Ganhos nas últimas 24 horas</span>
            <span class="gp-stat-value gp-stat-money">R$ <%= Number(stats.ganhos24h).toLocaleString('pt-BR', { minimumFractionDigits: 2 }) %></span>
          </div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <div class="gp-stat-text">
            <span class="gp-stat-label">Jogadores nas últimas 24 horas</span>
            <span class="gp-stat-value"><%= stats.players24h.toLocaleString('pt-BR') %></span>
          </div>
        </div>
        <div class="gp-stat-card">
          <div class="gp-stat-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div class="gp-stat-text">
            <span class="gp-stat-label">RTP nas últimas 24 horas</span>
            <span class="gp-stat-value gp-stat-rtp"><%= stats.rtp %>%</span>
          </div>
        </div>
      </section>

      <!-- Related Games Slider -->
      <% if (relatedGames.length > 0) { %>
      <section class="game-section gp-related-section">
        <div class="section-header">
          <h2>Jogos Relacionados</h2>
          <div class="gp-slider-nav">
            <button class="gp-slider-arrow gp-related-prev" aria-label="Anterior">&#8249;</button>
            <button class="gp-slider-arrow gp-related-next" aria-label="Próximo">&#8250;</button>
            <a href="/games?provider=<%= game.provider %>" class="see-all">Ver todos</a>
          </div>
        </div>
        <div class="gp-slider-viewport">
          <div class="gp-slider-track" id="relatedTrack">
            <% relatedGames.forEach(function(rg) { %>
            <a href="/game/<%= rg.game_code %>" class="game-card gp-slider-card" title="<%= rg.game_name %>" style="text-decoration:none">
              <img src="<%= rg.image_url %>" alt="<%= rg.game_name %>" draggable="false" loading="lazy">
              <div class="game-overlay">
                <span class="play-btn">&#9654; JOGAR</span>
              </div>
            </a>
            <% }); %>
          </div>
        </div>
      </section>
      <% } %>

      <!-- Providers / Estudios Slider -->
      <section class="game-section gp-providers-section">
        <div class="section-header">
          <h2>Estúdios</h2>
          <div class="gp-slider-nav">
            <button class="gp-slider-arrow gp-studios-prev" aria-label="Anterior">&#8249;</button>
            <button class="gp-slider-arrow gp-studios-next" aria-label="Próximo">&#8250;</button>
            <a href="/games" class="see-all">Ver todos</a>
          </div>
        </div>
        <div class="gp-slider-viewport">
          <div class="gp-slider-track gp-studios-track" id="studiosTrack">
            <% providers.forEach(function(p) { %>
            <a href="/games?provider=<%= p %>" class="estudio-card gp-studio-card" style="text-decoration:none">
              <span class="gp-studio-name"><%= p.toUpperCase() %></span>
            </a>
            <% }); %>
          </div>
        </div>
      </section>

    </div>
  </main>
</div>

<!-- Bottom nav mobile -->
<nav class="bottom-nav">
  <a href="/" class="bnav-item active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    <span>Início</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-search">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span>Buscar</span>
  </a>
  <button class="bnav-item bnav-deposit" id="bnav-deposit">
    <div class="bnav-deposit-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </div>
    <span>Depositar</span>
  </button>
  <a href="#" class="bnav-item" id="bnav-promos">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12v10H4V12M2 7h20v5H2zM12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
    <span>Promoções</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
    <span>Menu</span>
  </a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<div id="toastContainer" class="toast-container"></div>

<script>
(function(){
  /* === Sidebar toggle === */
  var sidebar = document.getElementById('sidebar');
  var sidebarOverlay = document.getElementById('sidebarOverlay');
  var barsToggle = document.getElementById('barsToggle');
  var topbarTabs = document.getElementById('topbarTabs');
  function isMobile() { return window.innerWidth <= 768; }
  if (barsToggle) barsToggle.addEventListener('click', function() {
    if (isMobile()) {
      if (sidebar) sidebar.classList.toggle('mobile-open');
      if (sidebarOverlay) sidebarOverlay.classList.toggle('active');
    } else {
      if (sidebar) sidebar.classList.toggle('collapsed');
      if (topbarTabs) topbarTabs.classList.toggle('collapsed');
    }
  });
  if (sidebarOverlay) sidebarOverlay.addEventListener('click', function() {
    if (sidebar) sidebar.classList.remove('mobile-open');
    if (sidebarOverlay) sidebarOverlay.classList.remove('active');
  });

  /* === Slider helper === */
  function initSlider(trackId, prevSel, nextSel) {
    var track = document.getElementById(trackId);
    if (!track) return;
    var prev = document.querySelector(prevSel);
    var next = document.querySelector(nextSel);
    var cardW = 0;

    function getCardWidth() {
      var first = track.children[0];
      if (!first) return 200;
      return first.offsetWidth + parseInt(getComputedStyle(track).gap || '16');
    }

    if (prev) prev.addEventListener('click', function() {
      cardW = getCardWidth();
      track.parentElement.scrollBy({ left: -cardW, behavior: 'smooth' });
    });
    if (next) next.addEventListener('click', function() {
      cardW = getCardWidth();
      track.parentElement.scrollBy({ left: cardW, behavior: 'smooth' });
    });
  }

  initSlider('relatedTrack', '.gp-related-prev', '.gp-related-next');
  initSlider('studiosTrack', '.gp-studios-prev', '.gp-studios-next');

  /* Toast */
  window.showToast = function(msg, type) {
    var container = document.getElementById('toastContainer');
    if (!container) { alert(msg); return; }
    var toast = document.createElement('div');
    toast.className = 'toast ' + (type || 'info');
    toast.textContent = msg;
    container.appendChild(toast);
    setTimeout(function() { toast.style.opacity = '0'; toast.style.transform = 'translateX(20px)'; toast.style.transition = '.3s'; setTimeout(function() { toast.remove(); }, 300); }, 3000);
  };
})();
</script>
</body>
</html>
