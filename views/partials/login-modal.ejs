        <span class="dep-qr-countdown-label">O tempo para vocГЄ pagar acaba em:</span>
        <span class="dep-qr-countdown-time" id="depQrCountdown">05:00</span>
        <div class="dep-qr-countdown-bar"><div class="dep-qr-countdown-fill" id="depQrCountdownFill"></div></div>
      </div>
