<script>
(function(){
  /* ===== PASSWORD EYE TOGGLE HELPER ===== */
  function setupEyeToggle(btn, input) {
    if (!btn || !input) return;
    btn.addEventListener('click', function() {
      var isPw = input.type === 'password';
      input.type = isPw ? 'text' : 'password';
      btn.querySelector('.eye-off').style.display = isPw ? 'none' : '';
      btn.querySelector('.eye-on').style.display = isPw ? '' : 'none';
    });
  }

  /* ===== LOGIN MODAL ===== */
  var loginModal = document.getElementById('loginModal');
  var loginForm = document.getElementById('loginForm');
  var emailInput = document.getElementById('loginEmail');
  var pwInput = document.getElementById('loginPassword');
  var loginSubmit = document.getElementById('loginSubmit');
  var loginClose = document.getElementById('loginClose');

  window.openLoginModal = function() {
    if (loginModal) { loginModal.classList.add('open'); document.body.style.overflow = 'hidden'; }
  };
  window.closeLoginModal = function() {
    if (loginModal) { loginModal.classList.remove('open'); document.body.style.overflow = ''; }
  };
  if (loginClose) loginClose.addEventListener('click', closeLoginModal);
  if (loginModal) loginModal.addEventListener('click', function(e) { if (e.target === loginModal) closeLoginModal(); });

  document.querySelectorAll('.btn-login, #heroLogin').forEach(function(btn) {
    btn.addEventListener('click', function(e) { e.preventDefault(); openLoginModal(); });
  });

  setupEyeToggle(document.getElementById('loginTogglePw'), pwInput);

  function checkLoginValid() {
    var valid = emailInput && emailInput.value.trim().length > 0 && pwInput && pwInput.value.length > 0;
    if (loginSubmit) loginSubmit.disabled = !valid;
  }
  if (emailInput) emailInput.addEventListener('input', checkLoginValid);
  if (pwInput) pwInput.addEventListener('input', checkLoginValid);

  if (loginForm) loginForm.addEventListener('submit', function(e) {
    e.preventDefault();
    var login = (emailInput.value || '').trim();
    var password = pwInput.value || '';
    if (!login || !password) return;
    loginSubmit.disabled = true;
    loginSubmit.textContent = 'Entrando...';
    if (typeof apiPost === 'function') {
      apiPost('/api/login', { login: login, password: password })
        .then(function(data) {
          var j = data.json || data;
          if (j && j.ok) { sessionStorage.setItem('acctLoginStart', Date.now()); closeLoginModal(); window.location.reload(); }
          else { if (typeof showToast === 'function') showToast(j.msg || 'Erro ao entrar', 'error'); }
        })
        .catch(function() { if (typeof showToast === 'function') showToast('Erro ao conectar', 'error'); })
        .finally(function() { loginSubmit.disabled = false; loginSubmit.textContent = 'Entrar'; checkLoginValid(); });
    }
  });

  /* ===== REGISTER MODAL ===== */
  var regModal = document.getElementById('registerModal');
  var regClose = document.getElementById('registerClose');
  var regCpf = document.getElementById('regCpf');
  var regValidateBtn = document.getElementById('regValidateBtn');
  var regExtraFields = document.getElementById('regExtraFields');
  var regForm = document.getElementById('registerForm');
  var regSubmitBtn = document.getElementById('regSubmitBtn');
  var regPhone = document.getElementById('regPhone');
  var regPasswordInput = document.getElementById('regPassword');
  var regTerms = document.getElementById('regTerms');
  var regTrocarCpf = document.getElementById('regTrocarCpf');

  window.openRegisterModal = function() {
    if (regModal) { regModal.classList.add('open'); document.body.style.overflow = 'hidden'; }
  };
  window.closeRegisterModal = function() {
    if (regModal) { regModal.classList.remove('open'); document.body.style.overflow = ''; }
  };
  if (regClose) regClose.addEventListener('click', closeRegisterModal);
  if (regModal) regModal.addEventListener('click', function(e) { if (e.target === regModal) closeRegisterModal(); });

  document.querySelectorAll('.btn-register, #heroRegister, #btnOpenRegister').forEach(function(btn) {
    btn.addEventListener('click', function(e) { e.preventDefault(); openRegisterModal(); });
  });

  /* CPF mask */
  if (regCpf) regCpf.addEventListener('input', function() {
    var v = regCpf.value.replace(/\D/g, '').substring(0, 11);
    if (v.length > 9) v = v.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
    else if (v.length > 6) v = v.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
    else if (v.length > 3) v = v.replace(/(\d{3})(\d{1,3})/, '$1.$2');
    regCpf.value = v;
  });

  /* Phone mask */
  if (regPhone) regPhone.addEventListener('input', function() {
    var v = regPhone.value.replace(/\D/g, '').substring(0, 11);
    if (v.length > 6) v = v.replace(/(\d{2})(\d{5})(\d{1,4})/, '($1) $2-$3');
    else if (v.length > 2) v = v.replace(/(\d{2})(\d{1,5})/, '($1) $2');
    regPhone.value = v;
  });

  setupEyeToggle(document.getElementById('regTogglePw'), regPasswordInput);

  /* Validate CPF в„ў spinner в„ў check API в„ў show fields */
  if (regValidateBtn) regValidateBtn.addEventListener('click', function() {
    var cpf = (regCpf.value || '').replace(/\D/g, '');
    if (cpf.length !== 11) {
      if (typeof showToast === 'function') showToast('Digite um CPF vГЎlido com 11 dГ­gitos', 'error');
      return;
    }
    regValidateBtn.querySelector('.reg-validate-text').style.display = 'none';
    regValidateBtn.querySelector('.reg-validate-spinner').style.display = '';
    regValidateBtn.disabled = true;
    regCpf.disabled = true;

    /* Check if CPF already registered */
    fetch('/api/check-cpf?cpf=' + cpf, { credentials: 'include' })
      .then(function(r) { return r.json().catch(function() { return {}; }); })
      .then(function(data) {
        if (data.exists) {
          if (typeof showToast === 'function') showToast('CPF jГЎ cadastrado. FaГ§a login.', 'error');
          regCpf.disabled = false;
          regValidateBtn.querySelector('.reg-validate-text').style.display = '';
          regValidateBtn.querySelector('.reg-validate-spinner').style.display = 'none';
          regValidateBtn.disabled = false;
          return;
        }
        var masked = cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
        document.getElementById('regCpfNumbers').textContent = masked;
        regValidateBtn.style.display = 'none';
        if (regExtraFields) regExtraFields.style.display = 'flex';
      })
      .catch(function() {
        /* Fallback: just show fields without check */
        var masked = cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
        document.getElementById('regCpfNumbers').textContent = masked;
        regValidateBtn.style.display = 'none';
        if (regExtraFields) regExtraFields.style.display = 'flex';
      });
  });

  /* Trocar CPF */
  if (regTrocarCpf) regTrocarCpf.addEventListener('click', function() {
    regCpf.disabled = false;
    regCpf.value = '';
    regCpf.focus();
    regValidateBtn.style.display = '';
    regValidateBtn.querySelector('.reg-validate-text').style.display = '';
    regValidateBtn.querySelector('.reg-validate-spinner').style.display = 'none';
    regValidateBtn.disabled = false;
    if (regExtraFields) regExtraFields.style.display = 'none';
  });

  /* Check register valid */
  function checkRegValid() {
    var name = document.getElementById('regName');
    var birth = document.getElementById('regBirthDate');
    var email = document.getElementById('regEmail');
    var pw = regPasswordInput;
    var terms = regTerms;
    var valid = name && name.value.trim().length > 2
      && birth && birth.value.length > 0
      && email && email.value.trim().length > 3
      && regPhone && regPhone.value.replace(/\D/g, '').length >= 10
      && pw && pw.value.length >= 6
      && terms && terms.checked;
    if (regSubmitBtn) regSubmitBtn.disabled = !valid;
  }
  ['regName','regBirthDate','regEmail','regPhone','regPassword'].forEach(function(id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', checkRegValid);
    if (el) el.addEventListener('change', checkRegValid);
  });
  if (regTerms) regTerms.addEventListener('change', checkRegValid);

  /* Submit register */
  if (regForm) regForm.addEventListener('submit', function(e) {
    e.preventDefault();
    if (regSubmitBtn.disabled) return;
    var cpf = (regCpf.value || '').replace(/\D/g, '');
    var nameVal = (document.getElementById('regName').value || '').trim();
    var birthVal = (document.getElementById('regBirthDate').value || '').trim();
    var emailVal = (document.getElementById('regEmail').value || '').trim();
    var phone = (regPhone.value || '').replace(/\D/g, '');
    var password = regPasswordInput.value || '';
    regSubmitBtn.disabled = true;
    regSubmitBtn.textContent = 'Registrando...';

    if (typeof apiPost === 'function') {
      apiPost('/api/register', { cpf: cpf, email: emailVal, phone: phone, password: password, username: emailVal, name: nameVal, birth_date: birthVal })
        .then(function(data) {
          var j = data.json || data;
          if (j && j.ok) {
            sessionStorage.setItem('acctLoginStart', Date.now());
            closeRegisterModal();
            if (typeof showToast === 'function') showToast('Conta criada com sucesso!', 'success');
            // Redirect to home logged in with deposit modal flag
            setTimeout(function() { window.location.href = '/?openDeposit=1'; }, 600);
          } else {
            if (typeof showToast === 'function') showToast(j.msg || 'Erro ao registrar', 'error');
          }
        })
        .catch(function() { if (typeof showToast === 'function') showToast('Erro ao conectar', 'error'); })
        .finally(function() { regSubmitBtn.disabled = false; regSubmitBtn.textContent = 'CONCLUIR REGISTRO'; checkRegValid(); });
    } else {
      closeRegisterModal();
      if (typeof showToast === 'function') showToast('Conta criada com sucesso!', 'success');
      setTimeout(function() { window.location.href = '/?openDeposit=1'; }, 600);
    }
  });

  /* ===== DEPOSIT MODAL (2-step) ===== */
  var depModal = document.getElementById('depositModal');
  var depBannerClose = document.getElementById('depBannerClose');
  var depBack = document.getElementById('depBack');
  var depValueInput = document.getElementById('depValueInput');
  var depCupomToggle = document.getElementById('depCupomToggle');
  var depCupomWrap = document.getElementById('depCupomWrap');
  var depSubmitBtn = document.getElementById('depSubmitBtn');
  var depStepValue = document.getElementById('depStepValue');
  var depStepQr = document.getElementById('depStepQr');
  var depQrStatus = document.getElementById('depQrStatus');
  var depQrAmount = document.getElementById('depQrAmount');
  var depQrImg = document.getElementById('depQrImg');
  var depQrCode = document.getElementById('depQrCode');
  var depQrCopyBtn = document.getElementById('depQrCopyBtn');
  var depQrCountdown = document.getElementById('depQrCountdown');
  var depQrCountdownFill = document.getElementById('depQrCountdownFill');
  var depQrApproved = document.getElementById('depQrApproved');
  var depPaymentPollId = null;
  var depCountdownId = null;
  var depCurrentStep = 'value'; // 'value' or 'qr'

  window.openDepositModal = function() {
    if (depModal) { depModal.classList.add('open'); document.body.style.overflow = 'hidden'; }
  };
  window.closeDepositModal = function() {
    if (depModal) { depModal.classList.remove('open'); document.body.style.overflow = ''; }
    resetDepositModal();
  };

  function goToQrStep(data) {
    depCurrentStep = 'qr';
    if (depStepValue) depStepValue.style.display = 'none';
    if (depStepQr) depStepQr.style.display = '';
    if (depQrApproved) depQrApproved.style.display = 'none';
    if (depQrAmount) depQrAmount.textContent = 'R$ ' + (data.amount_cents / 100).toLocaleString('pt-BR', { minimumFractionDigits: 2 });
    if (depQrCode) depQrCode.value = data.copyPaste || '';
    if (depQrStatus) { depQrStatus.textContent = 'Aguardando pagamento...'; depQrStatus.style.color = ''; }
    if (depQrImg) {
      if (data.qrCodeBase64) depQrImg.src = data.qrCodeBase64;
      else if (data.copyPaste) depQrImg.src = 'https://quickchart.io/qr?size=220&margin=2&text=' + encodeURIComponent(data.copyPaste);
    }
    startCountdown(300);
    if (data.tx_id) startDepositPoll(data.tx_id);
  }

  function goToValueStep() {
    depCurrentStep = 'value';
    if (depStepQr) depStepQr.style.display = 'none';
    if (depStepValue) depStepValue.style.display = '';
    if (depPaymentPollId) { clearInterval(depPaymentPollId); depPaymentPollId = null; }
    if (depCountdownId) { clearInterval(depCountdownId); depCountdownId = null; }
    if (depSubmitBtn) { depSubmitBtn.disabled = false; depSubmitBtn.textContent = 'DEPOSITAR'; }
  }

  function startCountdown(totalSec) {
    var remaining = totalSec;
    if (depCountdownId) clearInterval(depCountdownId);
    function updateTimer() {
      var m = Math.floor(remaining / 60);
      var s = remaining % 60;
      if (depQrCountdown) depQrCountdown.textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
      if (depQrCountdownFill) depQrCountdownFill.style.width = ((remaining / totalSec) * 100) + '%';
    }
    updateTimer();
    depCountdownId = setInterval(function() {
      remaining--;
      if (remaining <= 0) {
        clearInterval(depCountdownId);
        if (depQrStatus) { depQrStatus.textContent = 'Tempo expirado'; depQrStatus.style.color = '#ef4444'; }
        if (depPaymentPollId) { clearInterval(depPaymentPollId); depPaymentPollId = null; }
      }
      updateTimer();
    }, 1000);
  }

  function startDepositPoll(txId) {
    if (depPaymentPollId) clearInterval(depPaymentPollId);
    depPaymentPollId = setInterval(function() {
      fetch('/api/deposit/status?tx_id=' + txId, { credentials: 'include' })
        .then(function(r) { return r.json(); })
        .then(function(j) {
          if (j.ok && j.status === 'paid') {
            clearInterval(depPaymentPollId); depPaymentPollId = null;
            if (depCountdownId) { clearInterval(depCountdownId); depCountdownId = null; }
            // Show approved animation
            if (depQrApproved) depQrApproved.style.display = '';
            if (depQrStatus) { depQrStatus.textContent = 'Pagamento confirmado!'; depQrStatus.style.color = '#22c55e'; }
            if (typeof refreshWalletUI === 'function') refreshWalletUI();
            setTimeout(function() { closeDepositModal(); }, 3000);
          }
        }).catch(function() {});
    }, 4000);
  }

  function resetDepositModal() {
    depCurrentStep = 'value';
    if (depStepQr) depStepQr.style.display = 'none';
    if (depStepValue) depStepValue.style.display = '';
    if (depSubmitBtn) { depSubmitBtn.disabled = false; depSubmitBtn.textContent = 'DEPOSITAR'; }
    if (depValueInput) depValueInput.value = '';
    if (depQrStatus) { depQrStatus.textContent = ''; depQrStatus.style.color = ''; }
    if (depQrApproved) depQrApproved.style.display = 'none';
    if (depPaymentPollId) { clearInterval(depPaymentPollId); depPaymentPollId = null; }
    if (depCountdownId) { clearInterval(depCountdownId); depCountdownId = null; }
    document.querySelectorAll('.dep-val-btn').forEach(function(b) {
      b.classList.remove('dep-val-selected');
      var c = b.querySelector('.dep-val-check'); if (c) c.remove();
    });
  }

  if (depBannerClose) depBannerClose.addEventListener('click', closeDepositModal);
  if (depBack) depBack.addEventListener('click', function() {
    if (depCurrentStep === 'qr') goToValueStep();
    else closeDepositModal();
  });
  if (depModal) depModal.addEventListener('click', function(e) { if (e.target === depModal) closeDepositModal(); });

  document.querySelectorAll('#bnav-deposit, .bnav-deposit').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      if (!document.body.classList.contains('is-logged')) {
        if (typeof openLoginModal === 'function') openLoginModal();
        return;
      }
      openDepositModal();
    });
  });

  /* Method card switching */
  document.querySelectorAll('.dep-method-card').forEach(function(card) {
    card.addEventListener('click', function() {
      document.querySelectorAll('.dep-method-card').forEach(function(c) { c.classList.remove('dep-method-active'); });
      card.classList.add('dep-method-active');
      var name = card.dataset.method || 'PIX';
      var label = document.getElementById('depPaymentName');
      if (label) label.textContent = name;
    });
  });

  /* Value buttons */
  document.querySelectorAll('.dep-val-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var val = btn.dataset.value;
      if (depValueInput) depValueInput.value = val;
      document.querySelectorAll('.dep-val-btn').forEach(function(b) {
        b.classList.remove('dep-val-selected');
        var oldCheck = b.querySelector('.dep-val-check');
        if (oldCheck) oldCheck.remove();
      });
      btn.classList.add('dep-val-selected');
      var check = document.createElement('span');
      check.className = 'dep-val-check';
      check.innerHTML = '<svg width="10" height="8" viewBox="0 0 10 8" fill="#fff"><path d="M1 4l2.5 2.5L9 1"/></svg>';
      btn.appendChild(check);
    });
  });

  /* Cupom toggle */
  if (depCupomToggle) depCupomToggle.addEventListener('click', function() {
    var vis = depCupomWrap.style.display !== 'none';
    depCupomWrap.style.display = vis ? 'none' : 'block';
  });

  /* Copy PIX code */
  if (depQrCopyBtn) depQrCopyBtn.addEventListener('click', function() {
    var code = depQrCode ? depQrCode.value : '';
    if (code && navigator.clipboard) {
      navigator.clipboard.writeText(code).then(function() {
        if (typeof showToast === 'function') showToast('CГіdigo PIX copiado!', 'success');
      });
    }
  });

  /* DEPOSITAR button вЂ” loading animation then API call */
  if (depSubmitBtn) depSubmitBtn.addEventListener('click', function() {
    var val = depValueInput ? depValueInput.value : '';
    if (!val || isNaN(val) || +val <= 0) {
      if (typeof showToast === 'function') showToast('Digite um valor vГЎlido', 'error');
      return;
    }
    if (+val < 30) {
      if (typeof showToast === 'function') showToast('Valor mГ­nimo: R$ 30', 'error');
      return;
    }
    depSubmitBtn.disabled = true;
    depSubmitBtn.innerHTML = '<span class="dep-submit-spinner"></span> Gerando PIX...';

    fetch('/api/deposit/create', {
      method: 'POST', credentials: 'include',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ amount_brl: +val })
    }).then(function(r) { return r.json(); })
    .then(function(j) {
      if (!j.ok) {
        depSubmitBtn.disabled = false;
        depSubmitBtn.textContent = 'DEPOSITAR';
        if (typeof showToast === 'function') showToast(j.msg || 'Erro ao gerar PIX', 'error');
        return;
      }
      goToQrStep(j);
    }).catch(function() {
      depSubmitBtn.disabled = false;
      depSubmitBtn.textContent = 'DEPOSITAR';
      if (typeof showToast === 'function') showToast('Erro de conexГЈo', 'error');
    });
  });

  /* ===== SWITCH MODALS ===== */
  var goReg1 = document.getElementById('loginGoRegister');
  var goReg2 = document.getElementById('loginGoRegister2');
  var goLogin = document.getElementById('regGoLogin');

  function switchToRegister(e) { e.preventDefault(); closeLoginModal(); setTimeout(openRegisterModal, 150); }
  function switchToLogin(e) { e.preventDefault(); closeRegisterModal(); setTimeout(openLoginModal, 150); }

  if (goReg1) goReg1.addEventListener('click', switchToRegister);
  if (goReg2) goReg2.addEventListener('click', switchToRegister);
  if (goLogin) goLogin.addEventListener('click', switchToLogin);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') { closeLoginModal(); closeRegisterModal(); closeDepositModal(); }
  });
})();
</script>
