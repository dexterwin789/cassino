<!-- Г‚Г‚Г‚Г‚Г‚ REGISTER MODAL Г‚Г‚Г‚Г‚Г‚ -->
<div class="login-overlay" id="registerModal">
  <div class="login-modal">
    <div class="login-left">
      <img src="/public/img/novo/login-banner.png" alt="" class="login-left-img">
    </div>
    <div class="login-right">
      <div class="login-topbar">
        <button class="login-help-btn" type="button">
          <img src="/public/img/novo/modal1.svg" width="24" height="24" alt="">
          <span>Precisa de<br>Ajuda?</span>
        </button>
        <div class="login-topbar-right">
          <span class="login-topbar-line">JГЎ tem uma conta?</span>
          <a href="#" class="login-link" id="regGoLogin">FaГ§a login aqui</a>
        </div>
        <button class="login-close" id="registerClose" type="button">
          <img src="/public/img/novo/modal2.svg" width="24" height="24" alt="Fechar">
        </button>
      </div>
      <div class="login-body">
        <button class="login-google reg-google" type="button">
          <img src="/public/img/novo/modal4.svg" width="14" height="14" alt="">
          Registrar com Google
        </button>
        <div class="login-divider"><span>OU</span></div>

        <form class="login-form" id="registerForm" autocomplete="off">
          <!-- CPF step -->
          <div class="login-field login-field-cpf">
            <input type="text" id="regCpf" name="cpf" placeholder=" " maxlength="14" autocomplete="off">
            <label for="regCpf">CPF *</label>
            <button type="button" class="reg-validate-btn" id="regValidateBtn">
              <span class="reg-validate-text">Validar</span>
              <span class="reg-validate-spinner" style="display:none"></span>
            </button>
          </div>

          <!-- Extra fields (hidden until CPF validated) -->
          <div class="reg-extra-fields" id="regExtraFields" style="display:none">
            <!-- CPF info bar -->
            <div class="reg-cpf-info" id="regCpfInfo">
              <div class="reg-cpf-data">
                <span class="reg-cpf-numbers" id="regCpfNumbers">---</span>
              </div>
              <button type="button" class="reg-trocar-btn" id="regTrocarCpf">Trocar CPF</button>
            </div>

            <!-- Nome -->
            <div class="login-field">
              <input type="text" id="regName" name="name" placeholder=" " autocomplete="name">
              <label for="regName">Nome completo *</label>
            </div>

            <!-- Data de nascimento -->
            <div class="login-field login-field-date">
              <input type="date" id="regBirthDate" name="birth_date" placeholder=" ">
              <label for="regBirthDate">Data de nascimento *</label>
            </div>

            <!-- Email -->
            <div class="login-field">
              <input type="email" id="regEmail" name="email" placeholder=" " autocomplete="email">
              <label for="regEmail">E-mail *</label>
            </div>

            <!-- Telefone -->
            <div class="login-field reg-phone-field">
              <span class="reg-phone-prefix"><img src="/public/img/novo/BRA.png" alt="" style="width:18px;height:13px;border-radius:50%"> +55</span>
              <input type="tel" id="regPhone" name="phone" placeholder=" " maxlength="15" autocomplete="tel">
              <label for="regPhone" class="reg-phone-label">Telefone *</label>
            </div>

            <!-- Senha -->
            <div class="login-field">
              <input type="password" id="regPassword" name="password" placeholder=" " autocomplete="new-password">
              <label for="regPassword">Senha *</label>
              <button type="button" class="login-eye" id="regTogglePw" tabindex="-1">
                <img src="/public/img/novo/modal3.svg" width="16" height="16" alt="" class="eye-off">
                <img src="/public/img/novo/modal5.svg" width="16" height="16" alt="" class="eye-on" style="display:none">
              </button>
            </div>

            <!-- Nacionalidade -->
            <div class="login-field reg-select-field">
              <select id="regNationality" name="nationality">
                <option value="br" selected>Brasileiro (a)</option>
                <option value="other">Estrangeiro (a)</option>
              </select>
            </div>

            <!-- Checkbox -->
            <label class="reg-check">
              <input type="checkbox" id="regTerms" name="terms">
              <span>Confirmo que <strong><u>tenho mais de 18 anos</u></strong> e aceito os <a href="#" class="login-link">Termos e CondiГ§Гµes</a> e a <a href="#" class="login-link">PolГ­tica de Privacidade</a>.</span>
            </label>

            <!-- Submit -->
            <button type="submit" class="reg-submit-btn" id="regSubmitBtn" disabled>CONCLUIR REGISTRO</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

