        <div class="dep-qr-amount" id="depQrAmount">R$ 0,00</div>
        <div class="dep-qr-code-wrap">
          <input type="text" class="dep-qr-code" id="depQrCode" readonly>
        </div>
        <button class="dep-qr-copy-btn" id="depQrCopyBtn" type="button">Copiar CГіdigo "copia e cola"</button>
      </div>
