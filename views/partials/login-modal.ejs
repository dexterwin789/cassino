        <span class="dep-qr-spinner"></span>
        <span class="dep-qr-status" id="depQrStatus">Aguardando pagamento...</span>
      </div>
      <!-- Payment approved overlay -->
      <div class="dep-qr-approved" id="depQrApproved" style="display:none">
        <div class="dep-qr-check-circle">
          <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#22c55e" stroke-width="3"/><path d="M14 24l7 7 13-13" stroke="#22c55e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <strong>Pagamento Aprovado!</strong>
