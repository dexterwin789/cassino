    <!-- STEP 2: QR Code -->
    <div class="dep-body dep-step-qr" id="depStepQr" style="display:none">
      <div class="dep-qr-title">Escaneie a imagem<br>para realizar o pagamento</div>
      <img class="dep-qr-img" id="depQrImg" alt="QR Code PIX" src="">
