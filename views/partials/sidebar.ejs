<script>
(function(){
  var path = location.pathname;
  var search = location.search;
  var full = path + search;
  var items = document.querySelectorAll('#menuCassinoList li[data-href]');
  if (!items.length) return;
  var bestMatch = null;
  var bestLen = 0;
  items.forEach(function(li) {
    li.classList.remove('active');
    var href = li.getAttribute('data-href');
    if (full === href || (href === '/' && path === '/') || (href === '/games' && path === '/' && !search)) {
      if (href.length > bestLen) { bestMatch = li; bestLen = href.length; }
    } else if (full.indexOf(href) === 0 && href.length > bestLen) {
      bestMatch = li; bestLen = href.length;
    }
  });
  if (path === '/providers') {
    items.forEach(function(li) { li.classList.remove('active'); });
    var prov = document.querySelector('#menuCassinoList li[data-filter="providers"]');
    if (prov) prov.classList.add('active');
  } else if (bestMatch) {
    bestMatch.classList.add('active');
  } else if (path === '/' || path === '/games') {
    var all = document.querySelector('#menuCassinoList li[data-filter="all"]');
    if (all) all.classList.add('active');
  }
})();
</script>
