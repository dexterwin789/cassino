<%- include('partials/head') %>

<!-- TOP BAR -->
<header class="topbar" id="topbar">
  <div class="topbar-left">
    <button class="bars-toggle" id="barsToggle" title="Toggle sidebar">
      <img src="/public/img/novo/bars1.svg" width="22" height="22" alt="Menu">
    </button>
    <a href="/" class="topbar-logo">
      <% if (locals.logoDark && locals.logoLight) { %>
        <img src="<%= logoDark %>" alt="Logo" class="logo-img logo-dark-only">
        <img src="<%= logoLight %>" alt="Logo" class="logo-img logo-light-only">
      <% } else if (locals.logoDark) { %>
        <img src="<%= logoDark %>" alt="Logo" class="logo-img">
      <% } else if (locals.logoLight) { %>
        <img src="<%= logoLight %>" alt="Logo" class="logo-img">
      <% } else { %>
        <img src="/public/img/novo/logo.png" alt="Logo" class="logo-img">
      <% } %>
    </a>
  </div>
  <div class="topbar-center">
    <button class="tab-switch active" data-tab="cassino">
      <img src="/public/img/novo/carta1.svg" width="17" height="17" alt="Cassino">
      CASSINO
    </button>
    <button class="tab-switch" data-tab="esportes">
      <img src="/public/img/novo/bola1.svg" width="17" height="17" alt="Esportes">
      ESPORTES
    </button>
  </div>
  <div class="topbar-right">
    <span class="responsible-label is-guest-el">Jogo Responsável</span>
    <div class="topbar-auth is-guest-el">
      <button class="btn-register" id="btnOpenRegister">Registre-se</button>
      <button class="btn-login" id="btnOpenLogin">Entrar</button>
    </div>
    <div class="topbar-wallet is-logged-el">
      <span class="wallet-balance" id="walletBalance">R$ 0,00</span>
      <button class="btn-deposit-top" id="btnDepositTop">Depositar</button>
    </div>
  </div>
</header>

<!-- LAYOUT: SIDEBAR + MAIN -->
<div class="app-layout" id="appLayout">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <!-- Quick Access Cards -->
    <div class="sidebar-cards sb-full">
      <a href="#" class="sq-card">
        <span class="sq-label">Torneios</span>
        <img src="/public/img/novo/torneios1.svg" class="sq-img" alt="Torneios">
      </a>
      <a href="#" class="sq-card">
        <span class="sq-label">Missões</span>
        <img src="/public/img/novo/missoes1.svg" class="sq-img" alt="Missões">
      </a>
      <a href="#" class="sq-card">
        <span class="sq-label">Loja</span>
        <img src="/public/img/novo/store1.svg" class="sq-img" alt="Loja">
      </a>
      <a href="#" class="sq-card">
        <span class="sq-label">Mini Games</span>
        <img src="/public/img/novo/minigames.svg" class="sq-img" alt="Mini Games">
      </a>
      <a href="#" class="sq-card">
        <span class="sq-label">Promoções</span>
        <img src="/public/img/novo/promocoes1.svg" class="sq-img" alt="Promoções">
      </a>
      <a href="#" class="sq-card">
        <span class="sq-label">Suporte 24h</span>
        <img src="/public/img/novo/suporte1.svg" class="sq-img" alt="Suporte">
      </a>
    </div>

    <!-- Promo banners -->
    <div class="sidebar-promos sb-full">
      <a href="#" class="promo-card promo-calendar">
        <img src="/public/img/novo/calendario.png" alt="Calendário" class="promo-img">
        <span class="promo-text">CALENDÁRIO</span>
      </a>
      <a href="#" class="promo-card promo-app">
        <img src="/public/img/novo/app.png" alt="App" class="promo-img">
        <span class="promo-text">BAIXE NOSSO APP</span>
      </a>
    </div>

    <!-- Casino Menu -->
    <div class="sidebar-menu">
      <div class="menu-title sb-full" id="menuCassinoToggle">
        CASSINO
        <svg class="chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <ul class="menu-list" id="menuCassinoList">
        <li class="active" data-filter="all"><img src="/public/img/menu1.svg" class="mi" alt=""> <span class="ml">Todos os jogos</span></li>
        <li data-filter="slots"><img src="/public/img/menu2.svg" class="mi" alt=""> <span class="ml">Jogos Slots</span></li>
        <li data-filter="live"><img src="/public/img/menu3.svg" class="mi" alt=""> <span class="ml">Cassino ao vivo</span></li>
        <li data-filter="providers"><img src="/public/img/menu4.svg" class="mi" alt=""> <span class="ml">Provedores</span></li>
        <li data-filter="mines"><img src="/public/img/menu5.svg" class="mi" alt=""> <span class="ml">Mines</span></li>
        <li data-filter="fortune"><img src="/public/img/menu6.svg" class="mi" alt=""> <span class="ml">Fortune Tiger</span></li>
        <li data-filter="aviator"><img src="/public/img/menu7.svg" class="mi" alt=""> <span class="ml">Aviator</span></li>
        <li data-filter="spaceman"><img src="/public/img/menu8.svg" class="mi" alt=""> <span class="ml">Spaceman</span></li>
        <li data-filter="blackjack"><img src="/public/img/menu9.svg" class="mi" alt=""> <span class="ml">Infinite Blackjack</span></li>
        <li data-filter="roleta"><img src="/public/img/menu10.svg" class="mi" alt=""> <span class="ml">Roleta brasileira</span></li>
      </ul>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="main-content" id="mainContent">

    <!-- Category Icons Row -->
    <section class="category-icons">
      <div class="cat-icon-item"><div class="cat-icon-circle ci-blue"><img src="/public/img/icon1.png" alt=""></div><span>Esportes</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-red"><img src="/public/img/icon2.png" alt=""></div><span>Promoções</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-pink"><img src="/public/img/icon3.png" alt=""></div><span>Cassino</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-purple"><img src="/public/img/icon4.png" alt=""></div><span>Aviatrix</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-teal"><img src="/public/img/icon5.png" alt=""></div><span>Cassino</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-green"><img src="/public/img/icon6.png" alt=""></div><span>E-Sports</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-orange"><img src="/public/img/icon7.png" alt=""></div><span>Calendário</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-yellow"><img src="/public/img/icon8.png" alt=""></div><span>Mines</span></div>
      <div class="cat-icon-item"><div class="cat-icon-circle ci-lime"><img src="/public/img/icon3.png" alt=""></div><span>Indique</span></div>
    </section>

    <!-- Banner Area: 1 large + 2 small stacked -->
    <section class="banner-area">
      <div class="banner-main" id="bannerMain">
        <% if (typeof banners !== 'undefined' && banners.length) { %>
          <div class="banner-slider" id="bannerSlider">
            <% banners.forEach(function(b, i) { %>
            <a href="<%= b.link_url || '#' %>" class="banner-slide <%= i === 0 ? 'active' : '' %>">
              <img src="<%= b.image_url %>" alt="Banner" loading="<%= i === 0 ? 'eager' : 'lazy' %>">
            </a>
            <% }); %>
          </div>
          <div class="banner-dots" id="bannerDots"></div>
          <button class="banner-arrow banner-prev" id="bannerPrev">&#8249;</button>
          <button class="banner-arrow banner-next" id="bannerNext">&#8250;</button>
        <% } %>
      </div>
      <div class="banner-side">
        <% if (typeof banners !== 'undefined' && banners.length > 1) { %>
          <a href="<%= banners[1] ? banners[1].link_url || '#' : '#' %>" class="banner-side-item">
            <img src="<%= banners[1] ? banners[1].image_url : '' %>" alt="Promo" loading="lazy">
          </a>
        <% } %>
        <% if (typeof banners !== 'undefined' && banners.length > 2) { %>
          <a href="<%= banners[2] ? banners[2].link_url || '#' : '#' %>" class="banner-side-item">
            <img src="<%= banners[2] ? banners[2].image_url : '' %>" alt="Promo" loading="lazy">
          </a>
        <% } %>
      </div>
    </section>

    <!-- Search Bar -->
    <section class="search-section">
      <div class="search-box">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="searchGames" placeholder="Pesquise um jogo de cassino..." autocomplete="off">
      </div>
    </section>

    <!-- Recomendados -->
    <section class="game-section">
      <div class="section-header">
        <h2>Recomendados</h2>
      </div>
      <div class="games-row" id="gamesRecommended"></div>
    </section>

    <!-- Em Alta -->
    <section class="game-section">
      <div class="section-header">
        <h2>Em alta</h2>
        <a href="#" class="see-all">Ver todos</a>
      </div>
      <div class="games-grid" id="gamesHot"></div>
    </section>

    <!-- Todos os Jogos -->
    <section class="game-section">
      <div class="section-header">
        <h2>Todos os Jogos</h2>
        <a href="#" class="see-all">Ver todos</a>
      </div>
      <div class="games-grid" id="gamesAll"></div>
    </section>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-logo">
          <% if (locals.logoDark && locals.logoLight) { %>
            <img src="<%= logoDark %>" alt="Logo" style="height:32px" class="logo-dark-only">
            <img src="<%= logoLight %>" alt="Logo" style="height:32px" class="logo-light-only">
          <% } else if (locals.logoDark) { %>
            <img src="<%= logoDark %>" alt="Logo" style="height:32px">
          <% } else if (locals.logoLight) { %>
            <img src="<%= logoLight %>" alt="Logo" style="height:32px">
          <% } else { %>
            <img src="/public/img/novo/logo.png" alt="Logo" style="height:32px">
          <% } %>
        </div>
        <p>Jogue com responsabilidade. Apenas para maiores de 18 anos.</p>
        <p class="footer-copy">&copy; 2025 EsportivaBet. Todos os direitos reservados.</p>
      </div>
    </footer>

  </main>
</div>

<!-- BOTTOM NAV (mobile) -->
<nav class="bottom-nav">
  <a href="/" class="bnav-item active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    <span>Início</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-search">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span>Buscar</span>
  </a>
  <button class="bnav-item bnav-deposit" id="bnav-deposit">
    <div class="bnav-deposit-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </div>
    <span>Depositar</span>
  </button>
  <a href="#" class="bnav-item" id="bnav-promos">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12v10H4V12M2 7h20v5H2zM12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
    <span>Promoções</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
    <span>Menu</span>
  </a>
</nav>

<!-- OVERLAY (sidebar mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<!-- ══════════ DEPOSIT MODAL ══════════ -->
<div class="modal-overlay" id="depositModal">
  <div class="modal-box deposit-box">
    <div class="modal-header">
      <h3>Depositar via PIX</h3>
      <button class="modal-close" id="depositClose">&times;</button>
    </div>
    <div class="modal-body">
      <div class="deposit-chips">
        <button class="chip" data-val="30">R$ 30</button>
        <button class="chip" data-val="50">R$ 50</button>
        <button class="chip" data-val="100">R$ 100</button>
        <button class="chip" data-val="200">R$ 200</button>
        <button class="chip" data-val="500">R$ 500</button>
        <button class="chip" data-val="1000">R$ 1.000</button>
      </div>
      <div class="deposit-input-wrap">
        <label>Ou digite o valor:</label>
        <input type="text" id="depositAmount" placeholder="R$ 0,00" inputmode="numeric">
      </div>
      <button class="btn-confirm-deposit" id="btnConfirmDeposit">Gerar PIX</button>
      <div class="pix-result" id="pixResult" style="display:none">
        <img id="pixQr" src="" alt="QR Code">
        <div class="pix-copy-wrap">
          <input type="text" id="pixCode" readonly>
          <button class="btn-copy-pix" id="btnCopyPix">Copiar</button>
        </div>
        <p class="pix-status" id="pixStatus">Aguardando pagamento...</p>
      </div>
    </div>
  </div>
</div>

<!-- ══════════ AUTH MODAL ══════════ -->
<div class="modal-overlay" id="authModal">
  <div class="modal-box auth-box">
    <button class="modal-close" id="authClose">&times;</button>
    <div class="auth-tabs">
      <button class="auth-tab active" data-tab="register">Registre-se</button>
      <button class="auth-tab" data-tab="login">Entrar</button>
    </div>
    <!-- Register -->
    <form class="auth-form" id="formRegister">
      <input type="text" name="name" placeholder="Nome completo" required>
      <input type="text" name="cpf" placeholder="CPF" required>
      <input type="email" name="email" placeholder="E-mail" required>
      <input type="tel" name="phone" placeholder="Telefone" required>
      <input type="password" name="password" placeholder="Senha" required>
      <input type="password" name="password_confirm" placeholder="Confirmar senha" required>
      <label class="check-label"><input type="checkbox" required> Tenho mais de 18 anos e aceito os termos</label>
      <button type="submit" class="btn-auth-submit">Criar conta</button>
    </form>
    <!-- Login -->
    <form class="auth-form" id="formLogin" style="display:none">
      <input type="text" name="login" placeholder="E-mail ou CPF" required>
      <input type="password" name="password" placeholder="Senha" required>
      <button type="submit" class="btn-auth-submit">Entrar</button>
      <a href="#" class="forgot-link">Esqueceu a senha?</a>
    </form>
  </div>
</div>

<!-- ══════════ TOAST ══════════ -->
<div class="toast-container" id="toastContainer"></div>

<script src="/public/js/script.js"></script>
<%- include('partials/foot') %>