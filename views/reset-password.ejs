<%- include('partials/head', { title: 'Redefinir senha' }) %>
<div style="min-height:100vh;display:grid;place-items:center;background:#0d1b2a;color:#f6f6f6;font-family:Montserrat,system-ui,sans-serif;padding:24px;">
  <div style="width:100%;max-width:420px;background:#13283f;border:1px solid #1f3a5a;border-radius:16px;padding:32px 28px;box-shadow:0 12px 40px rgba(0,0,0,.35);">
    <h1 style="font-size:22px;font-weight:800;margin:0 0 8px;color:#fff;">Redefinir senha</h1>
    <% if (!valid) { %>
      <p style="color:#fda4af;margin:8px 0 16px;font-size:14px;">Este link é inválido ou expirou. Solicite um novo link de redefinição.</p>
      <a href="/" style="display:inline-block;padding:12px 22px;border-radius:10px;background:linear-gradient(180deg,#34D399,#25D366);color:#081018;font-weight:800;text-decoration:none;">Voltar ao início</a>
    <% } else { %>
      <p style="color:#a7c2dc;margin:0 0 18px;font-size:14px;">Defina uma nova senha para a conta <strong style="color:#fff;"><%= username %></strong>.</p>
      <form id="resetForm" autocomplete="off">
        <input type="hidden" name="token" value="<%= token %>" />
        <label style="display:block;font-size:13px;color:#a7c2dc;margin-bottom:6px;">Nova senha</label>
        <input id="pwd" name="password" type="password" minlength="8" maxlength="64" required
               style="width:100%;padding:12px 14px;border-radius:10px;border:1px solid #2a4564;background:#0d1b2a;color:#fff;font-size:15px;margin-bottom:14px;" />
        <label style="display:block;font-size:13px;color:#a7c2dc;margin-bottom:6px;">Confirme a senha</label>
        <input id="pwd2" type="password" minlength="8" maxlength="64" required
               style="width:100%;padding:12px 14px;border-radius:10px;border:1px solid #2a4564;background:#0d1b2a;color:#fff;font-size:15px;margin-bottom:18px;" />
        <button type="submit" id="resetBtn"
                style="width:100%;padding:13px 22px;border:0;border-radius:10px;background:linear-gradient(180deg,#34D399,#25D366);color:#081018;font-weight:800;font-size:15px;cursor:pointer;">
          Redefinir senha
        </button>
        <div id="resetMsg" style="margin-top:14px;font-size:14px;text-align:center;"></div>
      </form>
      <script>
        (function(){
          var f = document.getElementById('resetForm');
          var btn = document.getElementById('resetBtn');
          var msg = document.getElementById('resetMsg');
          f.addEventListener('submit', async function(e){
            e.preventDefault();
            msg.textContent = '';
            msg.style.color = '#a7c2dc';
            var p1 = document.getElementById('pwd').value;
            var p2 = document.getElementById('pwd2').value;
            if (p1 !== p2) { msg.style.color = '#fda4af'; msg.textContent = 'As senhas não conferem.'; return; }
            if (p1.length < 8) { msg.style.color = '#fda4af'; msg.textContent = 'Senha deve ter pelo menos 8 caracteres.'; return; }
            btn.disabled = true; btn.textContent = 'Salvando...';
            try {
              var r = await fetch('/api/password/reset-confirm', {
                method:'POST', credentials:'include',
                headers:{'Content-Type':'application/json'},
                body: JSON.stringify({ token: f.token.value, password: p1 })
              });
              var j = await r.json();
              if (j.ok) {
                msg.style.color = '#34D399';
                msg.textContent = j.msg || 'Senha redefinida! Redirecionando...';
                setTimeout(function(){ window.location.href = '/'; }, 1500);
              } else {
                msg.style.color = '#fda4af';
                msg.textContent = j.msg || 'Erro ao redefinir.';
                btn.disabled = false; btn.textContent = 'Redefinir senha';
              }
            } catch (err) {
              msg.style.color = '#fda4af';
              msg.textContent = 'Erro de conexão.';
              btn.disabled = false; btn.textContent = 'Redefinir senha';
            }
          });
        })();
      </script>
    <% } %>
  </div>
</div>
<%- include('partials/foot', {}) %>
