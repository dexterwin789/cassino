<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover" />
  <title><%= typeof title !== 'undefined' ? title : 'Minha Conta' %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/user-dashboard.css" />
</head>
<body>
  <div class="ud-layout">
    <!-- SIDEBAR -->
    <aside class="ud-sidebar" id="udSidebar">
      <div class="ud-sidebar-head">
        <div class="ud-sidebar-logo">
          <div class="ud-logo-dot"></div>
          <span class="ud-logo-text">Cassino</span>
        </div>
        <button class="ud-sidebar-toggle" id="udSidebarToggle" aria-label="Fechar menu">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>

      <nav class="ud-sidebar-nav">
        <div class="ud-nav-section">Menu</div>
        <a href="/dashboard" class="ud-nav-link<%= typeof page !== 'undefined' && page === 'dashboard' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>Painel</span>
        </a>
        <a href="/dashboard/transactions" class="ud-nav-link<%= typeof page !== 'undefined' && page === 'transactions' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <span>Transações</span>
        </a>
        <a href="/dashboard/security" class="ud-nav-link<%= typeof page !== 'undefined' && page === 'security' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <span>Segurança</span>
        </a>
        <a href="/dashboard/referrals" class="ud-nav-link<%= typeof page !== 'undefined' && page === 'referrals' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          <span>Indicações</span>
        </a>

        <div class="ud-nav-section">Ajuda</div>
        <a href="/" class="ud-nav-link">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span>Voltar ao Jogo</span>
        </a>
      </nav>

      <div class="ud-sidebar-foot">
        <div class="ud-user-card">
          <div class="ud-user-avatar"><%= u.username.charAt(0).toUpperCase() %></div>
          <div class="ud-user-info">
            <div class="ud-user-name"><%= u.username %></div>
            <div class="ud-user-id">ID: <%= u.id %></div>
          </div>
        </div>
        <button class="ud-nav-link logout" id="udLogoutBtn">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span>Sair</span>
        </button>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="ud-main">
      <header class="ud-topbar">
        <button class="ud-mobile-menu" id="udMobileMenu" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <h2 class="ud-topbar-title"><%= typeof title !== 'undefined' ? title : '' %></h2>
        <div class="ud-topbar-right">
          <a href="/" class="ud-topbar-btn" title="Voltar ao jogo">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </a>
        </div>
      </header>

      <div class="ud-content">
