<%- include('layout-head', { title: 'Transações', page: 'transactions', u }) %>

<!-- Filters -->
<div class="ud-card ud-filters">
  <form method="GET" action="/dashboard/transactions" class="ud-filter-form">
    <div class="ud-filter-group">
      <label class="ud-filter-label">Status</label>
      <select name="status" class="ud-select" onchange="this.form.submit()">
        <option value="">Todos</option>
        <option value="paid" <%= typeof status !== 'undefined' && status === 'paid' ? 'selected' : '' %>>Pago</option>
        <option value="pending" <%= typeof status !== 'undefined' && status === 'pending' ? 'selected' : '' %>>Pendente</option>
        <option value="failed" <%= typeof status !== 'undefined' && status === 'failed' ? 'selected' : '' %>>Falhou</option>
      </select>
    </div>
    <div class="ud-filter-group">
      <label class="ud-filter-label">De</label>
      <input type="date" name="from" class="ud-input" value="<%= typeof from !== 'undefined' ? from : '' %>" onchange="this.form.submit()" />
    </div>
    <div class="ud-filter-group">
      <label class="ud-filter-label">Até</label>
      <input type="date" name="to" class="ud-input" value="<%= typeof to !== 'undefined' ? to : '' %>" onchange="this.form.submit()" />
    </div>
    <button type="submit" class="ud-btn-filter">Filtrar</button>
  </form>
</div>

<!-- Summary -->
<div class="ud-tx-summary">
  <span><%= total %> transaç<%= total === 1 ? 'ão' : 'ões' %> encontrada<%= total === 1 ? '' : 's' %></span>
</div>

<!-- Table -->
<div class="ud-card ud-table-wrap">
  <% if (transactions.length === 0) { %>
  <div class="ud-empty">Nenhuma transação encontrada.</div>
  <% } else { %>
  <table class="ud-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Tipo</th>
        <th>Valor</th>
        <th>Status</th>
        <th>Data</th>
      </tr>
    </thead>
    <tbody>
      <% transactions.forEach(function(tx) { %>
      <tr>
        <td class="ud-mono">#<%= tx.id %></td>
        <td><%= tx.type === 'deposit' ? 'Depósito' : tx.type === 'withdrawal' ? 'Saque' : tx.type %></td>
        <td class="ud-mono">R$ <%= (parseInt(tx.amount_cents) / 100).toFixed(2).replace('.', ',') %></td>
        <td>
          <span class="ud-badge <%= tx.status === 'paid' ? 'ok' : tx.status === 'pending' ? 'warn' : 'bad' %>">
            <%= tx.status === 'paid' ? 'Pago' : tx.status === 'pending' ? 'Pendente' : 'Falhou' %>
          </span>
        </td>
        <td><%= new Date(tx.created_at).toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div class="ud-pagination">
  <% if (page > 1) { %>
  <a href="?page=<%= page - 1 %><%= typeof status !== 'undefined' && status ? '&status=' + status : '' %><%= typeof from !== 'undefined' && from ? '&from=' + from : '' %><%= typeof to !== 'undefined' && to ? '&to=' + to : '' %>" class="ud-page-btn">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
    Anterior
  </a>
  <% } %>
  <span class="ud-page-info">Página <%= page %> de <%= totalPages %></span>
  <% if (page < totalPages) { %>
  <a href="?page=<%= page + 1 %><%= typeof status !== 'undefined' && status ? '&status=' + status : '' %><%= typeof from !== 'undefined' && from ? '&from=' + from : '' %><%= typeof to !== 'undefined' && to ? '&to=' + to : '' %>" class="ud-page-btn">
    Próxima
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
  </a>
  <% } %>
</div>
<% } %>

<%- include('layout-foot') %>
