      </div><!-- .ud-content -->

      <footer class="ud-footer">
        <span>&copy; <%= new Date().getFullYear() %> • Cassino</span>
      </footer>
    </div><!-- .ud-main -->
  </div><!-- .ud-layout -->

  <script>
  // Sidebar toggle
  const udSidebar = document.getElementById('udSidebar');
  document.getElementById('udSidebarToggle')?.addEventListener('click', () => udSidebar.classList.toggle('collapsed'));
  document.getElementById('udMobileMenu')?.addEventListener('click', () => udSidebar.classList.toggle('mobile-open'));
  // Close on outside click (mobile)
  document.addEventListener('click', (e) => {
    if (udSidebar.classList.contains('mobile-open') && !udSidebar.contains(e.target) && e.target.id !== 'udMobileMenu') {
      udSidebar.classList.remove('mobile-open');
    }
  });
  // Logout
  document.getElementById('udLogoutBtn')?.addEventListener('click', async () => {
    await fetch('/api/logout', { method: 'POST', credentials: 'same-origin' });
    location.href = '/';
  });
  </script>
</body>
</html>
