<%- include('layout-head', { title: 'Dashboard', page: 'dashboard', u }) %>

<!-- Welcome -->
<div class="ud-welcome">
  <h1>Olá, <strong><%= u.username %></strong> 👋</h1>
  <p>Bem-vindo de volta ao seu painel.</p>
</div>

<!-- Stats -->
<div class="ud-stats-grid">
  <div class="ud-stat-card green">
    <div class="ud-stat-icon">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    </div>
    <div class="ud-stat-data">
      <span class="ud-stat-label">Saldo</span>
      <span class="ud-stat-value">R$ <%= (balance_cents / 100).toFixed(2).replace('.', ',') %></span>
    </div>
  </div>

  <div class="ud-stat-card green">
    <div class="ud-stat-icon">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
    </div>
    <div class="ud-stat-data">
      <span class="ud-stat-label">Total Depositado</span>
      <span class="ud-stat-value">R$ <%= (totalDeposited / 100).toFixed(2).replace('.', ',') %></span>
    </div>
  </div>

  <div class="ud-stat-card blue">
    <div class="ud-stat-icon">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
    </div>
    <div class="ud-stat-data">
      <span class="ud-stat-label">Depósitos</span>
      <span class="ud-stat-value"><%= totalDeposits %></span>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="ud-quick-actions">
  <a href="/" class="ud-qaction green">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    Jogar Agora
  </a>
  <button class="ud-qaction" onclick="window.open('/')">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
    Depositar
  </button>
  <a href="/dashboard/referrals" class="ud-qaction">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
    Convidar Amigo
  </a>
</div>

<!-- Agent Link -->
<div class="ud-card ud-agent-card">
  <div class="ud-card-header">
    <svg width="18" height="18" fill="none" stroke="var(--ud-accent)" stroke-width="2" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
    <span>Link de Indicação</span>
  </div>
  <div class="ud-agent-row">
    <code class="ud-agent-link" id="agentLink"><%= `${process.env.BASE_URL || (process.env.NODE_ENV === 'production' ? 'https://vemnabet.bet' : 'http://localhost:3000')}/?ref=${u.id}` %></code>
    <button class="ud-btn-copy" onclick="navigator.clipboard.writeText(document.getElementById('agentLink').textContent);this.textContent='Copiado!';setTimeout(()=>this.textContent='Copiar',1500)">Copiar</button>
  </div>
</div>

<!-- Recent Transactions -->
<div class="ud-card">
  <div class="ud-card-header">
    <svg width="18" height="18" fill="none" stroke="var(--ud-green1)" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
    <span>Últimas Transações</span>
    <a href="/dashboard/transactions" class="ud-card-action">Ver todas →</a>
  </div>
  <div class="ud-tx-list">
    <% if (recentTx.length === 0) { %>
    <div class="ud-empty">Nenhuma transação ainda.</div>
    <% } else { %>
    <% recentTx.forEach(function(tx) { %>
    <div class="ud-tx-row">
      <div class="ud-tx-icon <%= tx.status === 'paid' ? 'ok' : tx.status === 'pending' ? 'warn' : 'bad' %>">
        <% if (tx.status === 'paid') { %>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        <% } else if (tx.status === 'pending') { %>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <% } else { %>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        <% } %>
      </div>
      <div class="ud-tx-info">
        <div class="ud-tx-type"><%= tx.type === 'deposit' ? 'Depósito' : tx.type %></div>
        <div class="ud-tx-date"><%= new Date(tx.created_at).toLocaleDateString('pt-BR', { day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit' }) %></div>
      </div>
      <div class="ud-tx-amount">R$ <%= (parseInt(tx.amount_cents) / 100).toFixed(2).replace('.', ',') %></div>
      <span class="ud-badge <%= tx.status === 'paid' ? 'ok' : tx.status === 'pending' ? 'warn' : 'bad' %>"><%= tx.status === 'paid' ? 'Pago' : tx.status === 'pending' ? 'Pendente' : 'Falhou' %></span>
    </div>
    <% }); %>
    <% } %>
  </div>
</div>

<%- include('layout-foot') %>
