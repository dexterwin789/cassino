<%- include('layout-head', { title: 'Banners', page: 'banners' }) %>

<!--  Banners do Carrossel  -->
<div class="adm-page-card" data-page="banners">
  <div class="adm-page-head">
    <div><h3>Banners do Carrossel</h3><p class="adm-muted">Banners rotativos exibidos no topo da home</p></div>
    <div style="display:flex;gap:8px">
      <button class="adm-btn primary" id="btnAddBanner">+ Adicionar</button>
      <button class="adm-btn" data-action="refresh">Atualizar</button>
    </div>
  </div>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead><tr><th>ID</th><th>Preview</th><th>Link</th><th>Ordem</th><th>Ativo</th><th>Criado</th><th>Açőes</th></tr></thead>
      <tbody data-tbody></tbody>
    </table>
  </div>
  <div class="adm-pager">
    <div class="adm-muted"><span data-count>0</span> resultados</div>
  </div>
</div>

<!--  Banners Laterais (estáticos)  -->
<div class="adm-page-card" style="margin-top:24px;">
  <div class="adm-page-head">
    <div><h3>Banners Laterais</h3><p class="adm-muted">2 banners ao lado do carrossel na home</p></div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:16px;">
    <% for (let i = 1; i <= 2; i++) { %>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:20px;text-align:center;position:relative;">
      <label style="font-weight:700;display:block;margin-bottom:12px;color:var(--adm-text);font-size:14px">Banner Lateral <%= i %></label>
      <div class="sideDropZone" data-idx="<%= i %>" style="border:2px dashed rgba(255,255,255,.12);border-radius:12px;padding:24px 12px;text-align:center;cursor:pointer;transition:all .25s;background:rgba(0,0,0,.2);min-height:120px;display:flex;align-items:center;justify-content:center;flex-direction:column;margin-bottom:12px;position:relative;">
        <div id="previewSide<%= i %>">
          <% const sideKey = 'side_banner_' + i; %>
          <% if (settings[sideKey]) { %>
            <img src="<%= settings[sideKey] %>" style="max-height:120px;max-width:100%;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.3)">
          <% } else { %>
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="1.5" style="display:block;margin:0 auto 8px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            <p style="margin:0;color:rgba(255,255,255,.4);font-size:13px;font-weight:500">Clique ou arraste</p>
            <p style="margin:4px 0 0;color:rgba(255,255,255,.18);font-size:10px">PNG, JPG, WebP</p>
          <% } %>
        </div>
        <input type="file" class="sideBannerFile" data-idx="<%= i %>" accept="image/*" style="display:none;">
        <% if (settings[sideKey]) { %>
        <button type="button" class="btnDeleteSide" data-idx="<%= i %>" style="position:absolute;top:8px;right:8px;width:28px;height:28px;border-radius:50%;border:1px solid rgba(255,77,77,.3);background:rgba(255,77,77,.12);color:#ff4d4d;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:14px;line-height:1" title="Remover banner">&times;</button>
        <% } %>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px;text-align:left">Link (opcional)</label>
        <input type="text" class="sideBannerLink" data-idx="<%= i %>" placeholder="https://..." value="<%= settings['side_banner_' + i + '_link'] || '' %>" style="height:38px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 12px;outline:none;font-size:12px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
      </div>
    </div>
    <% } %>
  </div>
  <button class="adm-btn primary" id="btnSaveSideBanners" style="margin-top:16px;">Salvar Banners Laterais</button>
</div>

<!--  Banners Promocionais (strip)  -->
<div class="adm-page-card" style="margin-top:24px;">
  <div class="adm-page-head">
    <div><h3>Banners Promocionais</h3><p class="adm-muted">3 banners da faixa de recomendados na home</p></div>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-top:16px;">
    <% for (let i = 1; i <= 3; i++) { %>
    <div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:16px;text-align:center;position:relative;">
      <label style="font-weight:700;display:block;margin-bottom:10px;color:var(--adm-text);font-size:13px;">Promo <%= i %></label>
      <div class="promoDropZone" data-idx="<%= i %>" style="border:2px dashed rgba(255,255,255,.12);border-radius:12px;padding:20px 10px;text-align:center;cursor:pointer;transition:all .25s;background:rgba(0,0,0,.2);min-height:90px;display:flex;align-items:center;justify-content:center;flex-direction:column;margin-bottom:10px;position:relative;">
        <div id="previewPromo<%= i %>">
          <% const promoKey = 'promo_banner_' + i; %>
          <% if (settings[promoKey]) { %>
            <img src="<%= settings[promoKey] %>" style="max-height:80px;max-width:100%;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.3)">
          <% } else { %>
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="1.5" style="display:block;margin:0 auto 6px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            <p style="margin:0;color:rgba(255,255,255,.4);font-size:12px;font-weight:500">Clique ou arraste</p>
            <p style="margin:3px 0 0;color:rgba(255,255,255,.18);font-size:10px">PNG, JPG, WebP</p>
          <% } %>
        </div>
        <input type="file" class="promoBannerFile" data-idx="<%= i %>" accept="image/*" style="display:none;">
        <% if (settings[promoKey]) { %>
        <button type="button" class="btnDeletePromo" data-idx="<%= i %>" style="position:absolute;top:6px;right:6px;width:26px;height:26px;border-radius:50%;border:1px solid rgba(255,77,77,.3);background:rgba(255,77,77,.12);color:#ff4d4d;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:13px;line-height:1" title="Remover banner">&times;</button>
        <% } %>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px;text-align:left">Link (opcional)</label>
        <input type="text" class="promoBannerLink" data-idx="<%= i %>" placeholder="https://..." value="<%= settings['promo_banner_' + i + '_link'] || '' %>" style="height:38px;border-radius:10px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 12px;outline:none;font-size:12px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
      </div>
    </div>
    <% } %>
  </div>
  <button class="adm-btn primary" id="btnSavePromoBanners" style="margin-top:16px;">Salvar Banners Promo</button>
</div>

<!--  Modal: Adicionar Banner  -->
<div id="bannerModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);align-items:center;justify-content:center">
  <div style="background:linear-gradient(160deg,#111827,#0d1321);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:32px;width:500px;max-width:92vw;box-shadow:0 24px 80px rgba(0,0,0,.6)">
    <h4 style="margin:0 0 24px;color:#fff;font-size:18px;font-weight:700">Adicionar Banner</h4>
    <div style="display:flex;flex-direction:column;gap:18px">
      <!-- Upload area -->
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Imagem do Banner</label>
        <div id="bannerDropZone" style="border:2px dashed rgba(255,255,255,.12);border-radius:14px;padding:36px 16px;text-align:center;cursor:pointer;transition:all .25s;background:rgba(0,0,0,.2)">
          <div id="bannerPreviewArea">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.18)" stroke-width="1.5" style="display:block;margin:0 auto 10px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            <p style="margin:0;color:rgba(255,255,255,.45);font-size:14px;font-weight:500">Clique ou arraste uma imagem</p>
            <p style="margin:6px 0 0;color:rgba(255,255,255,.2);font-size:11px">PNG, JPG, WebP — máx. 2MB</p>
          </div>
          <input type="file" id="bannerFileInput" accept="image/*" style="display:none;">
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Link URL</label>
        <input id="bannerLinkUrl" placeholder="https://... (opcional)" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
      </div>
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Ordem de exibiçăo</label>
        <input id="bannerSortOrder" type="number" value="0" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s;width:120px" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:24px;justify-content:flex-end">
      <button class="adm-btn" id="bannerModalCancel" style="padding:10px 20px;border-radius:10px">Cancelar</button>
      <button class="adm-btn primary" id="bannerModalSave" style="padding:10px 24px;border-radius:10px;font-weight:700">Salvar</button>
    </div>
  </div>
</div>

<script src="/public/js/admin.js" defer></script>
<script>
(function(){
  var modal = document.getElementById('bannerModal');
  var dropZone = document.getElementById('bannerDropZone');
  var fileInput = document.getElementById('bannerFileInput');
  var previewArea = document.getElementById('bannerPreviewArea');
  var selectedFile = null;

  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  //  Banner Modal 
  var defaultDropHTML = '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.18)" stroke-width="1.5" style="display:block;margin:0 auto 10px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg><p style="margin:0;color:rgba(255,255,255,.45);font-size:14px;font-weight:500">Clique ou arraste uma imagem</p><p style="margin:6px 0 0;color:rgba(255,255,255,.2);font-size:11px">PNG, JPG, WebP — máx. 2MB</p>';

  document.getElementById('btnAddBanner').addEventListener('click', function() {
    selectedFile = null;
    fileInput.value = '';
    previewArea.innerHTML = defaultDropHTML;
    document.getElementById('bannerLinkUrl').value = '';
    document.getElementById('bannerSortOrder').value = '0';
    modal.style.display = 'flex';
  });

  document.getElementById('bannerModalCancel').addEventListener('click', function() { modal.style.display = 'none'; });
  modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });

  dropZone.addEventListener('click', function() { fileInput.click(); });
  dropZone.addEventListener('dragover', function(e) { e.preventDefault(); dropZone.style.borderColor = 'var(--adm-green1)'; dropZone.style.background = 'rgba(52,211,153,.06)'; });
  dropZone.addEventListener('dragleave', function() { dropZone.style.borderColor = 'rgba(255,255,255,.12)'; dropZone.style.background = 'rgba(0,0,0,.2)'; });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropZone.style.borderColor = 'rgba(255,255,255,.12)';
    dropZone.style.background = 'rgba(0,0,0,.2)';
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', function() { if (this.files[0]) handleFile(this.files[0]); });

  function handleFile(f) {
    if (f.size > 2 * 1024 * 1024) return alert('Arquivo muito grande. Máx. 2MB.');
    selectedFile = f;
    var url = URL.createObjectURL(f);
    previewArea.innerHTML = '<img src="' + url + '" style="max-height:140px;max-width:100%;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.3)"><p style="margin:8px 0 0;color:rgba(255,255,255,.45);font-size:11px;font-weight:500">' + esc(f.name) + '</p>';
  }

  document.getElementById('bannerModalSave').addEventListener('click', async function() {
    if (!selectedFile) return alert('Selecione uma imagem.');
    var btn = this;
    btn.disabled = true; btn.textContent = 'Salvando...';
    var fd = new FormData();
    fd.append('image', selectedFile);
    fd.append('link_url', document.getElementById('bannerLinkUrl').value);
    fd.append('sort_order', document.getElementById('bannerSortOrder').value);
    try {
      var r = await fetch('/admin/api/banners/upload', { method: 'POST', body: fd, credentials: 'same-origin' });
      var d = await r.json();
      if (d.ok) { modal.style.display = 'none'; location.reload(); }
      else alert(d.msg || 'Erro');
    } catch { alert('Erro de rede.'); }
    btn.disabled = false; btn.textContent = 'Salvar';
  });

  //  Side Banners (drag-and-drop + delete) 
  var sideDeleteFlags = {};
  function initDropZone(zone, fileInput, previewId, type) {
    zone.addEventListener('click', function(e) { if (!e.target.closest('.btnDeleteSide,.btnDeletePromo')) fileInput.click(); });
    zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.style.borderColor = 'var(--adm-green1)'; zone.style.background = 'rgba(16,185,129,.06)'; });
    zone.addEventListener('dragleave', function() { zone.style.borderColor = 'rgba(255,255,255,.12)'; zone.style.background = 'rgba(0,0,0,.2)'; });
    zone.addEventListener('drop', function(e) {
      e.preventDefault();
      zone.style.borderColor = 'rgba(255,255,255,.12)'; zone.style.background = 'rgba(0,0,0,.2)';
      if (e.dataTransfer.files[0]) { fileInput.files = e.dataTransfer.files; showPreview(fileInput.files[0], previewId, type, zone); }
    });
    fileInput.addEventListener('change', function() { if (this.files[0]) showPreview(this.files[0], previewId, type, zone); });
  }
  function showPreview(f, previewId, type, zone) {
    if (f.size > 2*1024*1024) return alert('Arquivo muito grande. Máx. 2MB.');
    var url = URL.createObjectURL(f);
    var h = type === 'promo' ? 80 : 120;
    document.getElementById(previewId).innerHTML = '<img src="'+url+'" style="max-height:'+h+'px;max-width:100%;border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.3)"><p style="margin:6px 0 0;color:rgba(255,255,255,.4);font-size:10px;font-weight:500">'+esc(f.name)+'</p>';
    var existing = zone.querySelector('.btnDeleteSide,.btnDeletePromo');
    if (!existing) {
      var cls = type === 'promo' ? 'btnDeletePromo' : 'btnDeleteSide';
      var sz = type === 'promo' ? 26 : 28;
      zone.insertAdjacentHTML('beforeend', '<button type="button" class="'+cls+'" data-idx="'+zone.dataset.idx+'" style="position:absolute;top:'+(type==='promo'?6:8)+'px;right:'+(type==='promo'?6:8)+'px;width:'+sz+'px;height:'+sz+'px;border-radius:50%;border:1px solid rgba(255,77,77,.3);background:rgba(255,77,77,.12);color:#ff4d4d;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;font-size:'+(type==='promo'?13:14)+'px;line-height:1" title="Remover banner">&times;</button>');
    }
  }

  document.querySelectorAll('.sideDropZone').forEach(function(zone) {
    var idx = zone.dataset.idx;
    var fileInput = zone.querySelector('.sideBannerFile');
    initDropZone(zone, fileInput, 'previewSide' + idx, 'side');
  });

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.btnDeleteSide');
    if (btn) {
      e.stopPropagation();
      var idx = btn.dataset.idx;
      sideDeleteFlags[idx] = true;
      document.getElementById('previewSide' + idx).innerHTML = '<svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="1.5" style="display:block;margin:0 auto 8px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg><p style="margin:0;color:rgba(255,77,77,.5);font-size:12px;font-weight:600">Removido</p><p style="margin:3px 0 0;color:rgba(255,255,255,.18);font-size:10px">Salve para confirmar</p>';
      var fileInput = document.querySelector('.sideBannerFile[data-idx="' + idx + '"]');
      fileInput.value = '';
      btn.remove();
    }
  });

  document.getElementById('btnSaveSideBanners').addEventListener('click', async function() {
    var btn = this; btn.disabled = true; btn.textContent = 'Salvando...';
    try {
      for (var i = 1; i <= 2; i++) {
        if (sideDeleteFlags[i]) {
          await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'side_banner_' + i, value: '' }), credentials: 'same-origin' });
          await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'side_banner_' + i + '_link', value: '' }), credentials: 'same-origin' });
          continue;
        }
        var fileEl = document.querySelector('.sideBannerFile[data-idx="' + i + '"]');
        var linkEl = document.querySelector('.sideBannerLink[data-idx="' + i + '"]');
        if (fileEl.files[0]) {
          var fd = new FormData();
          fd.append('image', fileEl.files[0]);
          fd.append('key', 'side_banner_' + i);
          await fetch('/admin/api/settings/banner-upload', { method: 'POST', body: fd, credentials: 'same-origin' });
        }
        if (linkEl.value !== undefined) {
          await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'side_banner_' + i + '_link', value: linkEl.value }), credentials: 'same-origin' });
        }
      }
      location.reload();
    } catch { alert('Erro de rede.'); }
    btn.disabled = false; btn.textContent = 'Salvar Banners Laterais';
  });

  //  Promo Banners (drag-and-drop + delete) 
  var promoDeleteFlags = {};

  document.querySelectorAll('.promoDropZone').forEach(function(zone) {
    var idx = zone.dataset.idx;
    var fileInput = zone.querySelector('.promoBannerFile');
    initDropZone(zone, fileInput, 'previewPromo' + idx, 'promo');
  });

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.btnDeletePromo');
    if (btn) {
      e.stopPropagation();
      var idx = btn.dataset.idx;
      promoDeleteFlags[idx] = true;
      document.getElementById('previewPromo' + idx).innerHTML = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.15)" stroke-width="1.5" style="display:block;margin:0 auto 6px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg><p style="margin:0;color:rgba(255,77,77,.5);font-size:11px;font-weight:600">Removido</p><p style="margin:3px 0 0;color:rgba(255,255,255,.18);font-size:10px">Salve para confirmar</p>';
      var fileInput = document.querySelector('.promoBannerFile[data-idx="' + idx + '"]');
      fileInput.value = '';
      btn.remove();
    }
  });

  document.getElementById('btnSavePromoBanners').addEventListener('click', async function() {
    var btn = this; btn.disabled = true; btn.textContent = 'Salvando...';
    try {
      for (var i = 1; i <= 3; i++) {
        if (promoDeleteFlags[i]) {
          await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'promo_banner_' + i, value: '' }), credentials: 'same-origin' });
          await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'promo_banner_' + i + '_link', value: '' }), credentials: 'same-origin' });
          continue;
        }
        var fileEl = document.querySelector('.promoBannerFile[data-idx="' + i + '"]');
        if (fileEl.files[0]) {
          var fd = new FormData();
          fd.append('image', fileEl.files[0]);
          fd.append('key', 'promo_banner_' + i);
          await fetch('/admin/api/settings/banner-upload', { method: 'POST', body: fd, credentials: 'same-origin' });
        }
        var linkEl = document.querySelector('.promoBannerLink[data-idx="' + i + '"]');
        if (linkEl && linkEl.value !== undefined) {
          await fetch('/admin/api/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ key: 'promo_banner_' + i + '_link', value: linkEl.value }), credentials: 'same-origin' });
        }
      }
      location.reload();
    } catch { alert('Erro de rede.'); }
    btn.disabled = false; btn.textContent = 'Salvar Banners Promo';
  });
})();
</script>
<%- include('layout-foot') %>
