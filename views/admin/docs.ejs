  .docs-toc a { display:block; padding:6px 8px; color:inherit; text-decoration:none; border-radius:6px; font-size:13px; opacity:.85; }
  .docs-toc a:hover { background:rgba(255,255,255,.05); opacity:1; }
  .docs-content section { background:var(--card-bg, #1a1f2e); border:1px solid var(--border, rgba(255,255,255,.08)); border-radius:12px; padding:22px 24px; margin-bottom:18px; scroll-margin-top:80px; }
