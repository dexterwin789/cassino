  .docs-card .v { font-size:18px; font-weight:600; margin-top:4px; }
</style>

<div class="adm-page-card">
  <div class="adm-page-head">
    <div>
      <h3>Documentação do Sistema</h3>
      <p class="adm-muted">Visão completa de integrações, funcionalidades e arquitetura</p>
    </div>
  </div>

  <div class="docs-wrap">
    <aside class="docs-toc">
      <h4>Sumário</h4>
      <a href="#visao-geral">Visão geral</a>
      <a href="#stack">Stack técnico</a>
      <a href="#integracoes">Integrações</a>
