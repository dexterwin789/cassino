  .docs-toc h4 { margin:0 0 10px; font-size:11px; letter-spacing:.5px; text-transform:uppercase; opacity:.6; }
  .docs-toc a { display:block; padding:6px 8px; color:inherit; text-decoration:none; border-radius:6px; font-size:13px; opacity:.85; }
  .docs-toc a:hover { background:rgba(255,255,255,.05); opacity:1; }
  .docs-content section { background:var(--card-bg, #1a1f2e); border:1px solid var(--border, rgba(255,255,255,.08)); border-radius:12px; padding:22px 24px; margin-bottom:18px; scroll-margin-top:80px; }
  .docs-content h2 { margin:0 0 12px; font-size:18px; display:flex; align-items:center; gap:10px; }
  .docs-content h2 .ico { width:32px; height:32px; border-radius:8px; background:linear-gradient(135deg,#8b5cf6,#3b82f6); display:inline-flex; align-items:center; justify-content:center; color:#fff; font-size:14px; }
  .docs-content h3 { margin:18px 0 8px; font-size:14px; opacity:.85; }
  .docs-content p, .docs-content li { font-size:13.5px; line-height:1.6; opacity:.9; }
  .docs-content code { background:rgba(255,255,255,.06); padding:2px 6px; border-radius:4px; font-size:12px; font-family: ui-monospace, Menlo, monospace; }
  .docs-content table { width:100%; border-collapse:collapse; margin:10px 0; font-size:13px; }
  .docs-content th, .docs-content td { text-align:left; padding:8px 10px; border-bottom:1px solid var(--border, rgba(255,255,255,.06)); }
  .docs-content th { opacity:.7; font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:.5px; }
  .docs-pill { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; }
  .docs-pill.ok { background:rgba(16,185,129,.15); color:#10b981; }
  .docs-pill.warn { background:rgba(245,158,11,.15); color:#f59e0b; }
  .docs-pill.off { background:rgba(239,68,68,.15); color:#ef4444; }
  .docs-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:10px; margin:12px 0; }
  .docs-card { background:rgba(255,255,255,.03); border:1px solid var(--border, rgba(255,255,255,.06)); border-radius:8px; padding:12px; }
  .docs-card .k { font-size:11px; opacity:.6; text-transform:uppercase; letter-spacing:.5px; }
  .docs-card .v { font-size:18px; font-weight:600; margin-top:4px; }
</style>

