  .docs-content p, .docs-content li { font-size:13.5px; line-height:1.6; opacity:.9; }
  .docs-content code { background:rgba(255,255,255,.06); padding:2px 6px; border-radius:4px; font-size:12px; font-family: ui-monospace, Menlo, monospace; }
  .docs-content table { width:100%; border-collapse:collapse; margin:10px 0; font-size:13px; }
  .docs-content th, .docs-content td { text-align:left; padding:8px 10px; border-bottom:1px solid var(--border, rgba(255,255,255,.06)); }
  .docs-content th { opacity:.7; font-weight:600; font-size:11px; text-transform:uppercase; letter-spacing:.5px; }
  .docs-pill { display:inline-block; padding:2px 8px; border-radius:999px; font-size:11px; font-weight:600; }
