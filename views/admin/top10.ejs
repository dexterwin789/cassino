<%- include('layout-head', { title: 'Top 10', page: 'top10' }) %>

<div class="adm-page-card" data-page="top10">
  <div class="adm-page-head">
    <div><h3>Top 10 — Jogos em Destaque</h3><p class="adm-muted">Gerencie os jogos destacados na home</p></div>
    <button class="adm-btn primary" id="btnAddFeatured">+ Adicionar Jogo</button>
  </div>

  <div id="featuredList" style="display:flex;flex-direction:column;gap:8px;padding:16px 0;">
    <p class="adm-muted" id="featuredLoading">Carregando...</p>
  </div>
</div>

<!-- Modal add game -->
<div id="addModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:999;align-items:center;justify-content:center;">
  <div style="background:var(--adm-card,#1a1a2e);border-radius:12px;padding:24px;width:480px;max-width:95%;max-height:80vh;overflow:auto;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <h4 style="margin:0;">Adicionar ao Top 10</h4>
      <button class="adm-btn" id="closeModal">&times;</button>
    </div>
    <div class="adm-field" style="margin-bottom:12px;">
      <input type="text" id="searchAvailable" placeholder="Buscar jogo por nome, código ou provider..." style="width:100%;padding:8px 12px;border-radius:8px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.05);color:inherit;" />
    </div>
    <div class="adm-field" style="margin-bottom:12px;max-width:140px;"><label>Por página</label><select id="availableLimit"><option value="5">5</option><option value="10" selected>10</option><option value="20">20</option><option value="30">30</option></select></div>
    <div id="availableList" style="display:flex;flex-direction:column;gap:6px;max-height:400px;overflow:auto;"></div>
    <div class="adm-pager" style="padding:12px 0 0;">
      <div class="adm-muted"><span id="availableCount">0</span> resultados</div>
      <div class="adm-pager-btns">
        <button class="adm-btn" id="availablePrev">‹</button>
        <span class="adm-muted">Página <span id="availablePageNum">1 de 1</span></span>
        <div class="adm-page-numbers" id="availablePageList"></div>
        <button class="adm-btn" id="availableNext">›</button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  var featuredList = document.getElementById('featuredList');
  var addModal = document.getElementById('addModal');
  var searchAvail = document.getElementById('searchAvailable');
  var availList = document.getElementById('availableList');
  var availableLimit = document.getElementById('availableLimit');
  var availableCount = document.getElementById('availableCount');
  var availablePageNum = document.getElementById('availablePageNum');
  var availablePageList = document.getElementById('availablePageList');
  var availablePrev = document.getElementById('availablePrev');
  var availableNext = document.getElementById('availableNext');
  var searchTimer = null;
  var availablePage = 1;
  var availableTotalPages = 1;

  function normalizeLimit(value) { var n = parseInt(value, 10); return [5, 10, 20, 30].indexOf(n) >= 0 ? n : 10; }
  function compactPages(current, total) {
    total = Math.max(1, parseInt(total, 10) || 1);
    current = Math.min(Math.max(1, parseInt(current, 10) || 1), total);
    if (total <= 7) return Array.from({ length: total }, function(_, i) { return i + 1; });
    var items = [1], start = Math.max(2, current - 1), end = Math.min(total - 1, current + 1);
    if (current <= 3) end = 4;
    if (current >= total - 2) start = total - 3;
    if (start > 2) items.push('...');
    for (var i = start; i <= end; i++) items.push(i);
    if (end < total - 1) items.push('...');
    items.push(total);
    return items;
  }
  function renderAvailablePager(total, current, limit) {
    availableTotalPages = Math.max(1, Math.ceil(total / limit));
    availablePage = Math.min(Math.max(1, current), availableTotalPages);
    availableCount.textContent = total;
    availablePageNum.textContent = availablePage + ' de ' + availableTotalPages;
    availablePrev.disabled = availablePage <= 1;
    availableNext.disabled = availablePage >= availableTotalPages;
    availablePageList.innerHTML = compactPages(availablePage, availableTotalPages).map(function(item) {
      if (item === '...') return '<span class="adm-page-ellipsis">...</span>';
      return '<button class="adm-page-btn' + (item === availablePage ? ' active' : '') + '" type="button" data-available-page="' + item + '">' + item + '</button>';
    }).join('');
  }

  function loadFeatured() {
    fetch('/admin/api/top10').then(r => r.json()).then(data => {
      if (!data.ok || !data.rows.length) {
        featuredList.innerHTML = '<p class="adm-muted">Nenhum jogo destacado. Clique em + Adicionar Jogo.</p>';
        return;
      }
      featuredList.innerHTML = data.rows.map((g, i) => `
        <div class="adm-featured-row" data-id="${g.id}" draggable="true" style="display:flex;align-items:center;gap:12px;padding:10px 14px;background:rgba(255,255,255,.03);border-radius:10px;border:1px solid rgba(255,255,255,.06);cursor:grab;">
          <span style="font-weight:700;font-size:18px;color:var(--adm-accent,#10b981);min-width:28px;text-align:center;">${i+1}</span>
          <img src="${g.image_url || ''}" alt="" style="width:48px;height:48px;object-fit:cover;border-radius:8px;${g.image_url ? '' : 'display:none'}">
          <div style="flex:1;min-width:0;">
            <div style="font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${g.game_name}</div>
            <div style="font-size:12px;opacity:.5;">${g.provider || ''} • ${g.game_code}</div>
          </div>
          <div style="display:flex;gap:6px;">
            <button class="adm-btn" data-move="up" title="Subir" style="padding:4px 8px;">↑</button>
            <button class="adm-btn" data-move="down" title="Descer" style="padding:4px 8px;">↓</button>
            <button class="adm-btn" data-remove="${g.id}" title="Remover" style="padding:4px 8px;color:#ef4444;">x</button>
          </div>
        </div>
      `).join('');
      bindFeaturedActions();
    }).catch(() => {
      featuredList.innerHTML = '<p class="adm-muted" style="color:#ef4444;">Erro ao carregar.</p>';
    });
  }

  function bindFeaturedActions() {
    featuredList.querySelectorAll('[data-remove]').forEach(btn => {
      btn.addEventListener('click', function() {
        var gId = this.getAttribute('data-remove');
        fetch('/admin/api/top10/remove', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ game_id: parseInt(gId) })
        }).then(r => r.json()).then(d => { if (d.ok) loadFeatured(); });
      });
    });
    featuredList.querySelectorAll('[data-move]').forEach(btn => {
      btn.addEventListener('click', function() {
        var dir = this.getAttribute('data-move');
        var row = this.closest('.adm-featured-row');
        var sibling = dir === 'up' ? row.previousElementSibling : row.nextElementSibling;
        if (!sibling) return;
        if (dir === 'up') featuredList.insertBefore(row, sibling);
        else featuredList.insertBefore(sibling, row);
        saveOrder();
      });
    });
  }

  function saveOrder() {
    var rows = featuredList.querySelectorAll('.adm-featured-row');
    var order = [];
    rows.forEach((r, i) => {
      order.push(parseInt(r.getAttribute('data-id')));
      r.querySelector('span').textContent = i + 1;
    });
    fetch('/admin/api/top10/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ order: order })
    });
  }

  function loadAvailable(q) {
    var limit = normalizeLimit(availableLimit.value);
    var url = '/admin/api/top10/available?page=' + availablePage + '&limit=' + limit + (q ? '&q=' + encodeURIComponent(q) : '');
    fetch(url).then(r => r.json()).then(data => {
      var total = parseInt(data.total || 0, 10) || 0;
      var current = parseInt(data.page || availablePage, 10) || 1;
      renderAvailablePager(total, current, normalizeLimit(data.limit || limit));
      if (current > availableTotalPages) { availablePage = availableTotalPages; loadAvailable(q); return; }
      if (!data.ok || !data.rows.length) {
        availList.innerHTML = '<p class="adm-muted">Nenhum jogo encontrado.</p>';
        return;
      }
      availList.innerHTML = data.rows.map(g => `
        <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;background:rgba(255,255,255,.03);cursor:pointer;" class="avail-row" data-id="${g.id}">
          <img src="${g.image_url || ''}" style="width:40px;height:40px;object-fit:cover;border-radius:6px;${g.image_url ? '' : 'display:none'}">
          <div style="flex:1;min-width:0;">
            <div style="font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${g.game_name}</div>
            <div style="font-size:11px;opacity:.5;">${g.provider || ''}</div>
          </div>
          <button class="adm-btn primary" data-add="${g.id}" style="padding:4px 12px;font-size:12px;">Adicionar</button>
        </div>
      `).join('');
      availList.querySelectorAll('[data-add]').forEach(btn => {
        btn.addEventListener('click', function() {
          var gId = this.getAttribute('data-add');
          fetch('/admin/api/top10/add', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ game_id: parseInt(gId) })
          }).then(r => r.json()).then(d => {
            if (d.ok) { loadFeatured(); loadAvailable(searchAvail.value); }
          });
        });
      });
    });
  }

  document.getElementById('btnAddFeatured').addEventListener('click', () => {
    addModal.style.display = 'flex';
    searchAvail.value = '';
    availablePage = 1;
    loadAvailable('');
  });
  document.getElementById('closeModal').addEventListener('click', () => { addModal.style.display = 'none'; });
  addModal.addEventListener('click', (e) => { if (e.target === addModal) addModal.style.display = 'none'; });
  searchAvail.addEventListener('input', function() {
    clearTimeout(searchTimer);
    availablePage = 1;
    searchTimer = setTimeout(() => loadAvailable(this.value), 300);
  });
  availableLimit.addEventListener('change', function() { availablePage = 1; loadAvailable(searchAvail.value); });
  availablePrev.addEventListener('click', function() { availablePage = Math.max(1, availablePage - 1); loadAvailable(searchAvail.value); });
  availableNext.addEventListener('click', function() { availablePage = Math.min(availableTotalPages, availablePage + 1); loadAvailable(searchAvail.value); });
  availablePageList.addEventListener('click', function(e) { var btn = e.target.closest('[data-available-page]'); if (!btn) return; availablePage = parseInt(btn.dataset.availablePage, 10) || 1; loadAvailable(searchAvail.value); });

  loadFeatured();
})();
</script>

<%- include('layout-foot') %>
