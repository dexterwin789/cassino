<%- include('layout-head', { title: 'Jogos', page: 'games' }) %>

<div class="adm-page-card" data-page="games">
  <div class="adm-page-head">
    <div><h3>Jogos</h3><p class="adm-muted">Catálogo de jogos</p></div>
    <div style="display:flex;gap:8px;">
      <button class="adm-btn" id="btnDedupGames" title="Identificar e desativar jogos duplicados">🔍 Dedup</button>
      <button class="adm-btn" id="btnSyncPF" title="Importar/atualizar jogos do PlayFivers">🔄 Sync PlayFivers</button>
      <button class="adm-btn" data-action="refresh">Atualizar</button>
      <button class="adm-btn primary" id="btnAddGame">+ Novo Jogo</button>
    </div>
  </div>

  <!-- Sync Provider Selection Modal -->
  <div id="syncModal" style="display:none;background:rgba(0,0,0,.6);position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center">
    <div style="background:var(--adm-card,#1e2330);border-radius:12px;padding:24px;max-width:480px;width:90%;max-height:70vh;overflow-y:auto">
      <h4 style="margin:0 0 12px">Sincronizar PlayFivers</h4>
      <p style="font-size:13px;opacity:.7;margin:0 0 16px">Selecione os provedores para importar ou clique "Todos" para sincronizar tudo.</p>
      <div id="syncProviderList" style="display:grid;gap:6px;margin-bottom:16px">
        <div style="text-align:center;opacity:.5">Carregando provedores...</div>
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button class="adm-btn" id="syncCancel">Cancelar</button>
        <button class="adm-btn" id="syncAll">🔄 Todos</button>
        <button class="adm-btn primary" id="syncSelected">Sincronizar Selecionados</button>
      </div>
      <div id="syncStatus" style="margin-top:12px;font-size:13px;display:none"></div>
    </div>
  </div>
  <div class="adm-toolbar">
    <div class="adm-field"><label>Buscar</label><input type="text" placeholder="code / nome / provider" data-filter="q" /></div>
    <div class="adm-field"><label>Ativo</label><select data-filter="active"><option value="">Todos</option><option value="1" selected>Ativo</option><option value="0">Inativo</option></select></div>
    <div class="adm-field" style="position:relative"><label>Provedor</label>
      <input type="hidden" id="admProviderHidden" data-filter="providers" value="">
      <div id="admProviderMulti" class="adm-multiselect">
        <div class="adm-ms-chips" id="admProvChips"><span class="adm-ms-placeholder">Todos</span></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;opacity:.5"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div id="admProvDropdown" class="adm-ms-dropdown" style="display:none">
        <input type="text" class="adm-ms-search" id="admProvSearch" placeholder="Buscar...">
        <div class="adm-ms-list" id="admProvList"></div>
      </div>
    </div>
    <div class="adm-field"><label>Por página</label><select data-filter="limit"><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option><option value="100">100</option></select></div>
    <div class="adm-field"><label>&nbsp;</label><button class="adm-btn primary" data-action="apply">Aplicar</button></div>
  </div>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead><tr><th>ID</th><th>Imagem</th><th>Código</th><th>Nome</th><th>Provider</th><th>Categoria</th><th>Status</th><th>Ações</th></tr></thead>
      <tbody data-tbody></tbody>
    </table>
  </div>
  <div class="adm-pager">
    <div class="adm-muted"><span data-count>0</span> resultados</div>
    <div class="adm-pager-btns">
      <button class="adm-btn" data-action="prev">‹</button>
      <span class="adm-muted">Página <span data-page-num>1</span></span>
      <button class="adm-btn" data-action="next">›</button>
    </div>
  </div>
</div>

<script src="/public/js/admin.js" defer></script>
<script>
// Multi-select provider filter
(function() {
  var hidden = document.getElementById('admProviderHidden');
  var toggle = document.getElementById('admProviderMulti');
  var dropdown = document.getElementById('admProvDropdown');
  var chipsEl = document.getElementById('admProvChips');
  var listEl = document.getElementById('admProvList');
  var searchEl = document.getElementById('admProvSearch');
  var selected = [];
  var allProviders = [];

  function updateHidden() {
    hidden.value = selected.join(',');
  }
  function renderChips() {
    if (!selected.length) { chipsEl.innerHTML = '<span class="adm-ms-placeholder">Todos</span>'; updateHidden(); return; }
    chipsEl.innerHTML = selected.map(function(p) {
      return '<span class="adm-ms-chip">' + p + '<span class="adm-ms-chip-x" data-prov="' + p + '">&times;</span></span>';
    }).join('');
    updateHidden();
  }
  function renderList(q) {
    var fq = (q || '').toLowerCase();
    var filtered = allProviders.filter(function(p) { return !fq || p.toLowerCase().includes(fq); });
    listEl.innerHTML = filtered.map(function(p) {
      var checked = selected.indexOf(p) >= 0;
      return '<label class="adm-ms-item' + (checked ? ' checked' : '') + '"><input type="checkbox"' + (checked ? ' checked' : '') + ' value="' + p + '"> ' + p + '</label>';
    }).join('');
  }

  toggle.addEventListener('click', function(e) {
    if (e.target.closest('.adm-ms-chip-x')) {
      var prov = e.target.closest('.adm-ms-chip-x').dataset.prov;
      selected = selected.filter(function(s) { return s !== prov; });
      renderChips(); renderList(searchEl.value);
      return;
    }
    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
    if (dropdown.style.display === 'block') searchEl.focus();
  });

  listEl.addEventListener('change', function(e) {
    var cb = e.target;
    if (!cb.matches('input[type=checkbox]')) return;
    if (cb.checked) { if (selected.indexOf(cb.value) < 0) selected.push(cb.value); }
    else { selected = selected.filter(function(s) { return s !== cb.value; }); }
    renderChips(); renderList(searchEl.value);
  });

  searchEl.addEventListener('input', function() { renderList(this.value); });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#admProviderMulti') && !e.target.closest('#admProvDropdown')) dropdown.style.display = 'none';
  });

  fetch('/admin/api/games/providers', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.ok || !d.providers.length) return;
      allProviders = d.providers;
      renderList('');
    });
})();

// Dedup button
document.getElementById('btnDedupGames')?.addEventListener('click', async function() {
  var btn = this;
  btn.disabled = true;
  btn.textContent = '⏳ Analisando...';
  try {
    var r = await fetch('/admin/api/games/duplicates', { credentials: 'same-origin' });
    var d = await r.json();
    if (!d.ok) { alert('Erro: ' + (d.msg || 'Falha')); btn.disabled = false; btn.textContent = '🔍 Dedup'; return; }
    if (!d.totalDuplicates) { alert('Nenhum jogo duplicado encontrado!'); btn.disabled = false; btn.textContent = '🔍 Dedup'; return; }
    var summary = d.totalDuplicates + ' duplicatas em ' + d.groups.length + ' grupos.\n\n';
    d.groups.slice(0, 10).forEach(function(g) {
      if (!g.keep) return;
      summary += '✅ Manter: ' + g.keep.game_name + ' (ID ' + g.keep.id + ', ' + (g.keep.provider || '?') + ')\n';
      g.duplicates.forEach(function(dup) {
        summary += '   ❌ Desativar: ID ' + dup.id + ' (' + (dup.provider || '?') + ')' + (dup.is_active ? ' [ativo]' : '') + '\n';
      });
    });
    if (d.groups.length > 10) summary += '\n... e mais ' + (d.groups.length - 10) + ' grupos.';
    summary += '\n\nDesativar todos os ' + d.totalDuplicates + ' duplicados?';
    if (!confirm(summary)) { btn.disabled = false; btn.textContent = '🔍 Dedup'; return; }
    var r2 = await fetch('/admin/api/games/deduplicate', { method: 'POST', credentials: 'same-origin' });
    var d2 = await r2.json();
    alert(d2.ok ? '✅ ' + d2.msg : '❌ ' + (d2.msg || 'Erro'));
    if (d2.ok) location.reload();
  } catch (e) {
    alert('Erro: ' + e.message);
  }
  btn.disabled = false;
  btn.textContent = '🔍 Dedup';
});
</script>
<%- include('layout-foot') %>
