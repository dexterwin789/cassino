<%- include('layout-head', { title: 'Jogos', page: 'games' }) %>

<div class="adm-page-card" data-page="games">
  <div class="adm-page-head">
    <div><h3>Jogos</h3><p class="adm-muted">Catálogo de jogos</p></div>
    <div style="display:flex;gap:8px;">
      <button class="adm-btn" id="btnAutoFetchImages" title="Buscar imagens automaticamente para jogos sem foto">🖼️ Buscar Imagens</button>
      <button class="adm-btn" id="btnBadImages" title="Desativar jogos sem imagem ou com imagem default" style="border-color:rgba(255,77,77,.3);color:#ff4d4d">🖼️ Limpar Imagens</button>
      <button class="adm-btn" id="btnDedupGames" title="Identificar e desativar jogos duplicados">🔍 Dedup</button>
      <button class="adm-btn" id="btnSyncPF" title="Importar/atualizar jogos do PlayFivers">🔄 Sync PlayFivers</button>
      <button class="adm-btn" data-action="refresh">Atualizar</button>
      <button class="adm-btn primary" id="btnAddGame">+ Novo Jogo</button>
    </div>
  </div>

  <!-- Sync Provider Selection Modal -->
  <div id="syncModal" style="display:none;background:rgba(0,0,0,.6);position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center">
    <div style="background:var(--adm-card,#1e2330);border-radius:12px;padding:24px;max-width:480px;width:90%;max-height:70vh;overflow-y:auto">
      <h4 style="margin:0 0 12px">Sincronizar PlayFivers</h4>
      <p style="font-size:13px;opacity:.7;margin:0 0 16px">Selecione os provedores para importar ou clique "Todos" para sincronizar tudo.</p>
      <div id="syncProviderList" style="display:grid;gap:6px;margin-bottom:16px">
        <div style="text-align:center;opacity:.5">Carregando provedores...</div>
      </div>
      <div style="display:flex;gap:8px;justify-content:flex-end">
        <button class="adm-btn" id="syncCancel">Cancelar</button>
        <button class="adm-btn" id="syncAll">🔄 Todos</button>
        <button class="adm-btn primary" id="syncSelected">Sincronizar Selecionados</button>
      </div>
      <div id="syncStatus" style="margin-top:12px;font-size:13px;display:none"></div>
    </div>
  </div>
  <div class="adm-toolbar">
    <div class="adm-field"><label>Buscar</label><input type="text" placeholder="code / nome / provider" data-filter="q" /></div>
    <div class="adm-field"><label>Ativo</label><select data-filter="active"><option value="">Todos</option><option value="1" selected>Ativo</option><option value="0">Inativo</option></select></div>
    <div class="adm-field" style="position:relative"><label>Provedor</label>
      <input type="hidden" id="admProviderHidden" data-filter="providers" value="">
      <div id="admProviderMulti" class="adm-multiselect">
        <div class="adm-ms-chips" id="admProvChips"><span class="adm-ms-placeholder">Todos</span></div>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;opacity:.5"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <div id="admProvDropdown" class="adm-ms-dropdown" style="display:none">
        <input type="text" class="adm-ms-search" id="admProvSearch" placeholder="Buscar...">
        <div class="adm-ms-list" id="admProvList"></div>
      </div>
    </div>
    <div class="adm-field"><label>Por página</label><select data-filter="limit"><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option><option value="100">100</option></select></div>
    <div class="adm-field"><label>&nbsp;</label><button class="adm-btn primary" data-action="apply">Aplicar</button></div>
  </div>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead><tr><th>ID</th><th>Imagem</th><th>Código</th><th>Nome</th><th>Provider</th><th>Categoria</th><th>Status</th><th>Ações</th></tr></thead>
      <tbody data-tbody></tbody>
    </table>
  </div>
  <div class="adm-pager">
    <div class="adm-muted"><span data-count>0</span> resultados</div>
    <div class="adm-pager-btns">
      <button class="adm-btn" data-action="prev">‹</button>
      <span class="adm-muted">Página <span data-page-num>1</span></span>
      <button class="adm-btn" data-action="next">›</button>
    </div>
  </div>
</div>

<script src="/public/js/admin.js" defer></script>

<!-- ── Modal: Novo Jogo ── -->
<div id="gameModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);align-items:center;justify-content:center">
  <div style="background:linear-gradient(160deg,#111827,#0d1321);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:32px;width:560px;max-width:92vw;box-shadow:0 24px 80px rgba(0,0,0,.6);max-height:90vh;overflow-y:auto">
    <h4 style="margin:0 0 24px;color:#fff;font-size:18px;font-weight:700;display:flex;align-items:center;gap:10px">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--adm-green1,#10b981)" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      Novo Jogo
    </h4>
    <div style="display:flex;flex-direction:column;gap:16px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Código do Jogo *</label>
          <input id="gmCode" placeholder="ex: fortune-tiger" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Nome do Jogo *</label>
          <input id="gmName" placeholder="ex: Fortune Tiger" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Provider</label>
          <select id="gmProvider" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s;cursor:pointer" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
            <option value="" style="background:#1a1f2e">Carregando...</option>
          </select>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Categoria</label>
          <select id="gmCategory" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s;cursor:pointer" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
            <option value="slots" style="background:#1a1f2e">Slots</option>
            <option value="crash" style="background:#1a1f2e">Crash</option>
            <option value="mines" style="background:#1a1f2e">Mines</option>
            <option value="dice" style="background:#1a1f2e">Dice</option>
            <option value="table" style="background:#1a1f2e">Table</option>
            <option value="live" style="background:#1a1f2e">Live</option>
          </select>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Destaque</label>
          <select id="gmFeatured" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s;cursor:pointer" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
            <option value="0" style="background:#1a1f2e">Não</option>
            <option value="1" style="background:#1a1f2e">Sim</option>
          </select>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Ordem</label>
          <input id="gmSortOrder" type="number" value="0" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
        </div>
      </div>
      <!-- Drag & Drop Image Upload -->
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Imagem do Jogo</label>
        <div id="gmDropZone" style="border:2px dashed rgba(255,255,255,.12);border-radius:14px;padding:28px 16px;text-align:center;cursor:pointer;transition:all .25s;background:rgba(0,0,0,.2)">
          <div id="gmPreviewArea">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.18)" stroke-width="1.5" style="display:block;margin:0 auto 8px"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
            <p style="margin:0;color:rgba(255,255,255,.45);font-size:13px;font-weight:500">Clique ou arraste uma imagem</p>
            <p style="margin:5px 0 0;color:rgba(255,255,255,.2);font-size:11px">PNG, JPG, WebP — máx. 2MB</p>
          </div>
          <input type="file" id="gmFileInput" accept="image/*" style="display:none;">
        </div>
        <input id="gmImageUrl" placeholder="ou cole uma URL de imagem..." style="height:36px;border-radius:10px;border:1px solid rgba(255,255,255,.07);background:rgba(0,0,0,.2);color:rgba(255,255,255,.6);padding:0 12px;outline:none;font-size:11px;font-weight:500;transition:border-color .2s;margin-top:4px" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.07)'">
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:24px;justify-content:flex-end">
      <button class="adm-btn" id="gmCancel" style="padding:10px 20px;border-radius:10px">Cancelar</button>
      <button class="adm-btn primary" id="gmSave" style="padding:10px 24px;border-radius:10px;font-weight:700">Salvar Jogo</button>
    </div>
  </div>
</div>
<script>
(function(){
  var modal = document.getElementById('gameModal');
  var dropZone = document.getElementById('gmDropZone');
  var fileInput = document.getElementById('gmFileInput');
  var previewArea = document.getElementById('gmPreviewArea');
  var selectedFile = null;
  var providerSelect = document.getElementById('gmProvider');
  var defaultPreview = previewArea.innerHTML;

  function esc(s) { var d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

  // Load providers from PlayFivers API + DB
  (async function loadProviders() {
    var opts = '<option value="" style="background:#1a1f2e">-- Selecione --</option>';
    try {
      var [pfRes, dbRes] = await Promise.all([
        fetch('/admin/api/playfivers/providers', { credentials: 'same-origin' }).then(r => r.json()).catch(() => ({ ok: false })),
        fetch('/admin/api/games/providers', { credentials: 'same-origin' }).then(r => r.json()).catch(() => ({ ok: false }))
      ]);
      var seen = {};
      if (pfRes.ok && pfRes.providers) {
        pfRes.providers.forEach(function(p) {
          var name = p.name || p;
          var id = p.id || name;
          if (!seen[name]) { opts += '<option value="' + esc(name) + '" style="background:#1a1f2e">' + esc(name) + '</option>'; seen[name] = true; }
        });
      }
      if (dbRes.ok && dbRes.providers) {
        dbRes.providers.forEach(function(p) {
          if (!seen[p]) { opts += '<option value="' + esc(p) + '" style="background:#1a1f2e">' + esc(p) + '</option>'; seen[p] = true; }
        });
      }
    } catch(e) {}
    if (Object.keys(providerSelect).length === 0 || opts.indexOf('Selecione') >= 0) {
      opts += '<option value="" style="background:#1a1f2e;color:rgba(255,255,255,.3)">Digite manualmente abaixo</option>';
    }
    providerSelect.innerHTML = opts;
  })();

  // Drag & drop
  dropZone.addEventListener('click', function() { fileInput.click(); });
  dropZone.addEventListener('dragover', function(e) { e.preventDefault(); dropZone.style.borderColor = 'var(--adm-green1)'; dropZone.style.background = 'rgba(16,185,129,.06)'; });
  dropZone.addEventListener('dragleave', function() { dropZone.style.borderColor = 'rgba(255,255,255,.12)'; dropZone.style.background = 'rgba(0,0,0,.2)'; });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault(); dropZone.style.borderColor = 'rgba(255,255,255,.12)'; dropZone.style.background = 'rgba(0,0,0,.2)';
    if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
  });
  fileInput.addEventListener('change', function() { if (this.files[0]) handleFile(this.files[0]); });

  function handleFile(f) {
    if (f.size > 2 * 1024 * 1024) return alert('Arquivo muito grande. Máx. 2MB.');
    selectedFile = f;
    var url = URL.createObjectURL(f);
    previewArea.innerHTML = '<img src="' + url + '" style="max-height:120px;max-width:100%;border-radius:10px;box-shadow:0 4px 20px rgba(0,0,0,.3)"><p style="margin:6px 0 0;color:rgba(255,255,255,.4);font-size:10px;font-weight:500">' + esc(f.name) + '</p>';
    document.getElementById('gmImageUrl').value = '';
  }

  document.getElementById('btnAddGame').addEventListener('click', function() {
    ['gmCode','gmName','gmImageUrl'].forEach(function(id){ document.getElementById(id).value=''; });
    document.getElementById('gmCategory').value = 'slots';
    document.getElementById('gmFeatured').value = '0';
    document.getElementById('gmSortOrder').value = '0';
    providerSelect.selectedIndex = 0;
    selectedFile = null; fileInput.value = '';
    previewArea.innerHTML = defaultPreview;
    modal.style.display = 'flex';
  });
  document.getElementById('gmCancel').addEventListener('click', function() { modal.style.display='none'; });
  modal.addEventListener('click', function(e) { if(e.target===modal) modal.style.display='none'; });

  document.getElementById('gmSave').addEventListener('click', async function() {
    var code = document.getElementById('gmCode').value.trim();
    var name = document.getElementById('gmName').value.trim();
    if(!code || !name) return alert('Código e nome são obrigatórios.');
    var btn = this; btn.disabled=true; btn.textContent='Salvando...';
    try {
      var fd = new FormData();
      fd.append('game_code', code);
      fd.append('game_name', name);
      fd.append('provider', providerSelect.value);
      fd.append('category', document.getElementById('gmCategory').value);
      if (selectedFile) {
        fd.append('image', selectedFile);
      } else if (document.getElementById('gmImageUrl').value.trim()) {
        fd.append('image_url', document.getElementById('gmImageUrl').value.trim());
      }
      var r = await fetch('/admin/api/games', { method:'POST', body: fd, credentials:'same-origin' });
      var d = await r.json();
      if(d.ok){ modal.style.display='none'; location.reload(); }
      else alert(d.msg||'Erro');
    } catch{ alert('Erro de rede.'); }
    btn.disabled=false; btn.textContent='Salvar Jogo';
  });
})();
</script>
<script>
// Multi-select provider filter
(function() {
  var hidden = document.getElementById('admProviderHidden');
  var toggle = document.getElementById('admProviderMulti');
  var dropdown = document.getElementById('admProvDropdown');
  var chipsEl = document.getElementById('admProvChips');
  var listEl = document.getElementById('admProvList');
  var searchEl = document.getElementById('admProvSearch');
  var selected = [];
  var allProviders = [];

  function updateHidden() {
    hidden.value = selected.join(',');
  }
  function renderChips() {
    if (!selected.length) { chipsEl.innerHTML = '<span class="adm-ms-placeholder">Todos</span>'; updateHidden(); return; }
    chipsEl.innerHTML = selected.map(function(p) {
      return '<span class="adm-ms-chip">' + p + '<span class="adm-ms-chip-x" data-prov="' + p + '">&times;</span></span>';
    }).join('');
    updateHidden();
  }
  function renderList(q) {
    var fq = (q || '').toLowerCase();
    var filtered = allProviders.filter(function(p) { return !fq || p.toLowerCase().includes(fq); });
    listEl.innerHTML = filtered.map(function(p) {
      var checked = selected.indexOf(p) >= 0;
      return '<label class="adm-ms-item' + (checked ? ' checked' : '') + '"><input type="checkbox"' + (checked ? ' checked' : '') + ' value="' + p + '"> ' + p + '</label>';
    }).join('');
  }

  toggle.addEventListener('click', function(e) {
    if (e.target.closest('.adm-ms-chip-x')) {
      var prov = e.target.closest('.adm-ms-chip-x').dataset.prov;
      selected = selected.filter(function(s) { return s !== prov; });
      renderChips(); renderList(searchEl.value);
      return;
    }
    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
    if (dropdown.style.display === 'block') searchEl.focus();
  });

  listEl.addEventListener('change', function(e) {
    var cb = e.target;
    if (!cb.matches('input[type=checkbox]')) return;
    if (cb.checked) { if (selected.indexOf(cb.value) < 0) selected.push(cb.value); }
    else { selected = selected.filter(function(s) { return s !== cb.value; }); }
    renderChips(); renderList(searchEl.value);
  });

  searchEl.addEventListener('input', function() { renderList(this.value); });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('#admProviderMulti') && !e.target.closest('#admProvDropdown')) dropdown.style.display = 'none';
  });

  fetch('/admin/api/games/providers', { credentials: 'same-origin' })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (!d.ok || !d.providers.length) return;
      allProviders = d.providers;
      renderList('');
    });
})();

// Auto-fetch missing images
document.getElementById('btnAutoFetchImages')?.addEventListener('click', async function() {
  var btn = this;
  btn.disabled = true; btn.textContent = 'Buscando...';
  try {
    var r = await fetch('/admin/api/games/auto-fetch-images', { method: 'POST', credentials: 'same-origin' });
    var d = await r.json();
    alert(d.msg || (d.ok ? 'Concluído!' : 'Erro'));
    if (d.ok && d.updated > 0) location.reload();
  } catch { alert('Erro de rede.'); }
  btn.disabled = false; btn.textContent = '🖼️ Buscar Imagens';
});

// Bad images button
document.getElementById('btnBadImages')?.addEventListener('click', async function() {
  var btn = this;
  btn.disabled = true;
  btn.textContent = '⏳ Analisando...';
  try {
    var r = await fetch('/admin/api/games/bad-images', { credentials: 'same-origin' });
    var d = await r.json();
    if (!d.ok) { alert('Erro: ' + (d.msg || 'Falha')); btn.disabled = false; btn.textContent = '🖼️ Limpar Imagens'; return; }
    if (!d.totalToDeactivate) { alert('Nenhum jogo com imagem ruim encontrado!'); btn.disabled = false; btn.textContent = '🖼️ Limpar Imagens'; return; }
    var msg = 'Jogos sem imagem: ' + d.nullImageGames.length + '\n';
    msg += 'Imagens duplicadas (default): ' + d.duplicatedImages.length + ' URLs\n';
    d.duplicatedImages.forEach(function(di) { msg += '  → ' + di.cnt + 'x: ' + di.image_url.substring(0, 60) + '...\n'; });
    msg += 'Jogos com imagem default: ' + d.defaultImageGames.length + '\n';
    msg += '\nTotal a desativar: ' + d.totalToDeactivate + '\n\nDesativar todos?';
    if (!confirm(msg)) { btn.disabled = false; btn.textContent = '🖼️ Limpar Imagens'; return; }
    var r2 = await fetch('/admin/api/games/deactivate-bad-images', { method: 'POST', credentials: 'same-origin' });
    var d2 = await r2.json();
    alert(d2.ok ? '✅ ' + d2.msg : '❌ ' + (d2.msg || 'Erro'));
    if (d2.ok) location.reload();
  } catch (e) {
    alert('Erro: ' + e.message);
  }
  btn.disabled = false;
  btn.textContent = '🖼️ Limpar Imagens';
});

// Dedup button
document.getElementById('btnDedupGames')?.addEventListener('click', async function() {
  var btn = this;
  btn.disabled = true;
  btn.textContent = '⏳ Analisando...';
  try {
    var r = await fetch('/admin/api/games/duplicates', { credentials: 'same-origin' });
    var d = await r.json();
    if (!d.ok) { alert('Erro: ' + (d.msg || 'Falha')); btn.disabled = false; btn.textContent = '🔍 Dedup'; return; }
    if (!d.totalDuplicates) { alert('Nenhum jogo duplicado encontrado!'); btn.disabled = false; btn.textContent = '🔍 Dedup'; return; }
    var summary = d.totalDuplicates + ' duplicatas em ' + d.groups.length + ' grupos.\n\n';
    d.groups.slice(0, 10).forEach(function(g) {
      if (!g.keep) return;
      summary += '✅ Manter: ' + g.keep.game_name + ' (ID ' + g.keep.id + ', ' + (g.keep.provider || '?') + ')\n';
      g.duplicates.forEach(function(dup) {
        summary += '   ❌ Desativar: ID ' + dup.id + ' (' + (dup.provider || '?') + ')' + (dup.is_active ? ' [ativo]' : '') + '\n';
      });
    });
    if (d.groups.length > 10) summary += '\n... e mais ' + (d.groups.length - 10) + ' grupos.';
    summary += '\n\nDesativar todos os ' + d.totalDuplicates + ' duplicados?';
    if (!confirm(summary)) { btn.disabled = false; btn.textContent = '🔍 Dedup'; return; }
    var r2 = await fetch('/admin/api/games/deduplicate', { method: 'POST', credentials: 'same-origin' });
    var d2 = await r2.json();
    alert(d2.ok ? '✅ ' + d2.msg : '❌ ' + (d2.msg || 'Erro'));
    if (d2.ok) location.reload();
  } catch (e) {
    alert('Erro: ' + e.message);
  }
  btn.disabled = false;
  btn.textContent = '🔍 Dedup';
});
</script>
