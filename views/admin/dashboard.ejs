<%- include('layout-head', { title: 'Dashboard', page: 'dashboard' }) %>

<div class="adm-dashboard">

  <!-- Row 1: Stats -->
  <div class="adm-stats-grid" style="grid-template-columns:repeat(6,1fr);">
    <div class="adm-stat-card">
      <div class="adm-stat-icon" style="background:rgba(46,231,107,.12);color:#2ee76b;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div class="adm-stat-info">
        <div class="adm-stat-label">Total Usuários</div>
        <div class="adm-stat-value" id="statUsers"><%= stats.totalUsers %></div>
        <div class="adm-stat-sub" id="statTodayUsers">+<%= stats.todayUsers %> hoje</div>
      </div>
    </div>

    <div class="adm-stat-card">
      <div class="adm-stat-icon" style="background:rgba(37,211,102,.12);color:#25D366;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <div class="adm-stat-info">
        <div class="adm-stat-label">Receita Total</div>
        <div class="adm-stat-value" id="statRevenue">R$ <%= (stats.totalRevenue / 100).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></div>
        <div class="adm-stat-sub" id="statTodayRev">-</div>
      </div>
    </div>

    <div class="adm-stat-card">
      <div class="adm-stat-icon" style="background:rgba(43,140,255,.12);color:#2b8cff;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      </div>
      <div class="adm-stat-info">
        <div class="adm-stat-label">Jogos Ativos</div>
        <div class="adm-stat-value" id="statGames"><%= stats.totalGames %></div>
        <div class="adm-stat-sub">no catálogo</div>
      </div>
    </div>

    <div class="adm-stat-card">
      <div class="adm-stat-icon" style="background:rgba(255,215,0,.12);color:#ffd700;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
      </div>
      <div class="adm-stat-info">
        <div class="adm-stat-label">GGR (Lucro Bruto)</div>
        <div class="adm-stat-value" id="statGgr">-</div>
        <div class="adm-stat-sub" id="statGgrSub">apostas - pagamentos</div>
      </div>
    </div>

    <div class="adm-stat-card">
      <div class="adm-stat-icon" style="background:rgba(52,211,153,.12);color:#34D399;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
      </div>
      <div class="adm-stat-info">
        <div class="adm-stat-label">Saques Pendentes</div>
        <div class="adm-stat-value" id="statPendingWd">-</div>
        <div class="adm-stat-sub" id="statPendingWdAmt">-</div>
      </div>
    </div>

    <div class="adm-stat-card">
      <div class="adm-stat-icon" style="background:rgba(168,85,247,.12);color:#a855f7;">
        <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 11v1a10 10 0 0 1-2.2 6.3"/></svg>
      </div>
      <div class="adm-stat-info">
        <div class="adm-stat-label">Conversão</div>
        <div class="adm-stat-value" id="statConversion">-</div>
        <div class="adm-stat-sub">dep/registros</div>
      </div>
    </div>
  </div>

  <!-- Row 2: Charts -->
  <div class="adm-dash-row" style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="adm-chart-card">
      <div class="adm-chart-head">
        <h3>Receita vs Saques (14 dias)</h3>
      </div>
      <div class="adm-chart-body" style="height:280px;">
        <canvas id="revenueChart"></canvas>
      </div>
    </div>
    <div class="adm-chart-card">
      <div class="adm-chart-head">
        <h3>Novos Usuários (7 dias)</h3>
      </div>
      <div class="adm-chart-body" style="height:280px;">
        <canvas id="usersChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Row 3: Lists -->
  <div class="adm-dash-row" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px;margin-bottom:24px;">
    <!-- Top Depositors -->
    <div class="adm-list-card">
      <div class="adm-list-head">
        <h3>
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/></svg>
          Top Depositantes
        </h3>
        <a href="/admin/deposits" class="adm-link-sm">Ver todos</a>
      </div>
      <div class="adm-list-body" id="topDepositors">
        <div class="adm-list-empty">Carregando...</div>
      </div>
    </div>

    <!-- Top Games -->
    <div class="adm-list-card">
      <div class="adm-list-head">
        <h3>
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          Jogos Populares
        </h3>
        <a href="/admin/games" class="adm-link-sm">Ver todos</a>
      </div>
      <div class="adm-list-body" id="topGames">
        <div class="adm-list-empty">Carregando...</div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="adm-list-card">
      <div class="adm-list-head">
        <h3>
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          Atividade Recente
        </h3>
      </div>
      <div class="adm-list-body adm-activity-feed" id="activityFeed">
        <div class="adm-list-empty">Carregando...</div>
      </div>
    </div>
  </div>

  <!-- Row 4: Recent Deposits + Quick Summary -->
  <div class="adm-dash-row" style="display:grid;grid-template-columns:1.4fr 1fr;gap:16px;margin-bottom:24px;">
    <div class="adm-list-card">
      <div class="adm-list-head">
        <h3>
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Últimos Depósitos
        </h3>
        <a href="/admin/deposits" class="adm-link-sm">Ver todos</a>
      </div>
      <div class="adm-list-body" id="recentDeposits">
        <div class="adm-list-empty">Carregando...</div>
      </div>
    </div>

    <div class="adm-list-card">
      <div class="adm-list-head">
        <h3>
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Resumo Financeiro
        </h3>
      </div>
      <div class="adm-list-body" id="financialSummary">
        <div class="adm-list-empty">Carregando...</div>
      </div>
    </div>
  </div>

  <!-- Row 5: Quick Actions -->
  <div class="adm-quick-actions">
    <a href="/admin/users" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
      Usuários
    </a>
    <a href="/admin/deposits" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      Depósitos
    </a>
    <a href="/admin/withdrawals" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
      Saques
    </a>
    <a href="/admin/reports" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      Relatórios
    </a>
    <a href="/admin/games" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      Jogos
    </a>
    <a href="/admin/notifications" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      Notificações
    </a>
    <a href="/admin/coupons" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 12v-2a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v2"/><path d="M4 12a2 2 0 0 0 0 4h16a2 2 0 0 0 0-4"/></svg>
      Cupons
    </a>
    <a href="/admin/settings" class="adm-quick-btn">
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9z"/></svg>
      Configurações
    </a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', async () => {
  const brl = n => new Intl.NumberFormat('pt-BR',{style:'currency',currency:'BRL'}).format(n);
  const fdate = d => d ? new Date(d).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '-';
  const esc = s => String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  try {
    const r = await fetch('/admin/api/stats/enhanced', { credentials: 'same-origin' });
    const d = await r.json();
    if (!d.ok) return;

    // Stat cards
    document.getElementById('statGgr').textContent = brl(d.ggr / 100);
    document.getElementById('statGgrSub').textContent = `apostas - pagamentos`;
    document.getElementById('statPendingWd').textContent = d.pendingWithdrawals;
    document.getElementById('statPendingWdAmt').textContent = brl(d.pendingWithdrawalsAmount / 100) + ' pendente';
    document.getElementById('statConversion').textContent = d.conversionRate + '%';
    document.getElementById('statTodayRev').textContent = brl(d.todayRevenue / 100) + ' hoje';

    // Revenue vs Withdrawals chart (14 days)
    if (d.revenueChart && d.revenueChart.length) {
      const revLabels = d.revenueChart.map(x => new Date(x.d).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'}));
      const revDeps = d.revenueChart.map(x => parseInt(x.deposits) / 100);
      const revWds = d.revenueChart.map(x => parseInt(x.withdrawals) / 100);
      new Chart(document.getElementById('revenueChart'), {
        type: 'line',
        data: {
          labels: revLabels,
          datasets: [
            { label: 'Depósitos', data: revDeps, borderColor: '#2ee76b', backgroundColor: 'rgba(46,231,107,.08)', fill: true, tension: .4, borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#2ee76b' },
            { label: 'Saques', data: revWds, borderColor: '#ff4d4d', backgroundColor: 'rgba(255,77,77,.08)', fill: true, tension: .4, borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#ff4d4d' }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { labels: { color: 'rgba(255,255,255,.6)', font: { weight: 700 } } } },
          scales: {
            y: { beginAtZero: true, ticks: { color: 'rgba(255,255,255,.4)', callback: v => 'R$'+v }, grid: { color: 'rgba(255,255,255,.06)' } },
            x: { ticks: { color: 'rgba(255,255,255,.4)' }, grid: { display: false } }
          }
        }
      });
    }

    // Users chart (7 days)
    if (d.weekChart && d.weekChart.length) {
      const labels = d.weekChart.map(x => new Date(x.d).toLocaleDateString('pt-BR',{weekday:'short',day:'numeric'}));
      const values = d.weekChart.map(x => parseInt(x.c));
      new Chart(document.getElementById('usersChart'), {
        type: 'bar',
        data: {
          labels,
          datasets: [{ label: 'Novos', data: values, backgroundColor: 'rgba(43,140,255,.35)', borderColor: '#2b8cff', borderWidth: 2, borderRadius: 8, borderSkipped: false }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { color: 'rgba(255,255,255,.4)', stepSize: 1 }, grid: { color: 'rgba(255,255,255,.06)' } },
            x: { ticks: { color: 'rgba(255,255,255,.4)' }, grid: { display: false } }
          }
        }
      });
    }

    // Top Depositors
    const depEl = document.getElementById('topDepositors');
    if (d.topDepositors && d.topDepositors.length) {
      depEl.innerHTML = d.topDepositors.map((u, i) => `
        <div class="adm-list-row">
          <div class="adm-list-rank" style="background:${['rgba(255,215,0,.15)','rgba(192,192,192,.12)','rgba(205,127,50,.12)','rgba(255,255,255,.04)','rgba(255,255,255,.04)'][i]};color:${['#ffd700','#c0c0c0','#cd7f32','rgba(255,255,255,.5)','rgba(255,255,255,.5)'][i]}">${i+1}</div>
          <div class="adm-list-info">
            <strong>${esc(u.username)}</strong>
            <span>${u.dep_count} depósitos</span>
          </div>
          <div class="adm-list-val" style="color:#2ee76b">${brl(parseInt(u.total_deposited)/100)}</div>
        </div>`).join('');
    } else {
      depEl.innerHTML = '<div class="adm-list-empty">Nenhum depósito registrado</div>';
    }

    // Top Games
    const gamesEl = document.getElementById('topGames');
    if (d.topGames && d.topGames.length) {
      gamesEl.innerHTML = d.topGames.map((g, i) => `
        <div class="adm-list-row">
          <div class="adm-list-rank" style="background:${['rgba(255,215,0,.15)','rgba(192,192,192,.12)','rgba(205,127,50,.12)','rgba(255,255,255,.04)','rgba(255,255,255,.04)'][i]};color:${['#ffd700','#c0c0c0','#cd7f32','rgba(255,255,255,.5)','rgba(255,255,255,.5)'][i]}">${i+1}</div>
          <div class="adm-list-info">
            <strong>${esc(g.game_name)}</strong>
            <span>${esc(g.provider || '-')}</span>
          </div>
          <div class="adm-list-val">${parseInt(g.bet_count).toLocaleString()} apostas</div>
        </div>`).join('');
    } else {
      gamesEl.innerHTML = '<div class="adm-list-empty">Nenhuma aposta registrada</div>';
    }

    // Activity Feed
    const actEl = document.getElementById('activityFeed');
    if (d.recentActivity && d.recentActivity.length) {
      const typeMap = {
        deposit: { icon: '\ud83d\udcb0', color: '#2ee76b', label: 'Depósito' },
        withdrawal: { icon: '\ud83d\udcb8', color: '#34D399', label: 'Saque' },
        register: { icon: '\ud83d\udc64', color: '#2b8cff', label: 'Registro' }
      };
      actEl.innerHTML = d.recentActivity.map(a => {
        const t = typeMap[a.type] || { icon: '', color: '#fff', label: a.type };
        const amt = a.amount_cents > 0 ? brl(parseInt(a.amount_cents)/100) : '';
        return `<div class="adm-activity-item">
          <div class="adm-activity-dot" style="background:${t.color}">${t.icon}</div>
          <div class="adm-activity-info">
            <div><strong>${esc(a.username || '#'+a.user_id)}</strong> <span class="adm-activity-type">${t.label}</span></div>
            <div class="adm-activity-meta">${fdate(a.created_at)}${amt ? '  <strong style="color:'+t.color+'">'+amt+'</strong>' : ''}</div>
          </div>
        </div>`;
      }).join('');
    } else {
      actEl.innerHTML = '<div class="adm-list-empty">Nenhuma atividade recente</div>';
    }

    // Recent Deposits
    const listEl = document.getElementById('recentDeposits');
    if (d.recentDeposits && d.recentDeposits.length) {
      listEl.innerHTML = d.recentDeposits.map(tx => {
        const amt = brl(parseInt(tx.amount_cents) / 100);
        const stCls = tx.status === 'paid' ? 'ok' : tx.status === 'pending' ? 'warn' : 'bad';
        return `<div class="adm-list-row">
          <div class="adm-list-info" style="flex:1">
            <strong>${esc(tx.username || '#'+tx.user_id)}</strong>
            <span>${fdate(tx.created_at)}</span>
          </div>
          <div class="adm-list-val" style="color:var(--adm-green2)">${amt}</div>
          <span class="adm-tag ${stCls}" style="margin-left:8px">${tx.status}</span>
        </div>`;
      }).join('');
    } else {
      listEl.innerHTML = '<div class="adm-list-empty">Nenhum depósito ainda</div>';
    }

    // Financial Summary
    const finEl = document.getElementById('financialSummary');
    finEl.innerHTML = `
      <div class="adm-summary-row">
        <span class="adm-summary-label">Total Depósitos</span>
        <span class="adm-summary-val" style="color:#2ee76b">${brl(d.totalRevenue / 100)}</span>
      </div>
      <div class="adm-summary-row">
        <span class="adm-summary-label">Depósitos Hoje</span>
        <span class="adm-summary-val" style="color:#2ee76b">${brl(d.todayRevenue / 100)} <small style="color:rgba(255,255,255,.35)">(${d.todayDeposits}x)</small></span>
      </div>
      <div class="adm-summary-row">
        <span class="adm-summary-label">Total Saques Pagos</span>
        <span class="adm-summary-val" style="color:#34D399">${brl(d.totalWithdrawalsAmount / 100)}</span>
      </div>
      <div class="adm-summary-row">
        <span class="adm-summary-label">Saques Pendentes</span>
        <span class="adm-summary-val" style="color:#ff4d4d">${d.pendingWithdrawals}x  ${brl(d.pendingWithdrawalsAmount / 100)}</span>
      </div>
      <div class="adm-summary-divider"></div>
      <div class="adm-summary-row">
        <span class="adm-summary-label">Total Apostas</span>
        <span class="adm-summary-val">${brl(d.totalBets / 100)}</span>
      </div>
      <div class="adm-summary-row">
        <span class="adm-summary-label">Total Pagamentos</span>
        <span class="adm-summary-val">${brl(d.totalPayouts / 100)}</span>
      </div>
      <div class="adm-summary-row" style="padding-top:12px;border-top:1px solid rgba(255,255,255,.08)">
        <span class="adm-summary-label" style="font-size:14px;font-weight:900;color:#fff">GGR (Lucro Bruto)</span>
        <span class="adm-summary-val" style="font-size:18px;color:#ffd700">${brl(d.ggr / 100)}</span>
      </div>
    `;

  } catch (e) {
    console.error('Dashboard stats error:', e);
  }
});

// Server IP banner
</script>

<%- include('layout-foot') %>
