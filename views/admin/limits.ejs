<script src="/public/js/admin.js" defer></script>
<script>
function brlMask(input) {
  input.addEventListener('input', function() {
    var v = this.value.replace(/\D/g, '');
    if (!v) { this.value = ''; return; }
    v = (parseInt(v, 10) / 100).toFixed(2);
    this.value = 'R$ ' + v.replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  });
}
function parseBRL(str) {
  if (!str) return 0;
  var n = str.replace(/[R$\s.]/g, '').replace(',', '.');
  return Math.round(parseFloat(n || 0) * 100);
}
document.querySelectorAll('.brl-mask').forEach(brlMask);

document.addEventListener('DOMContentLoaded', () => {
  const modal = document.getElementById('limitModal');
  const limType = document.getElementById('limType');
  const limValue = document.getElementById('limValue');
  const limValueLabel = document.getElementById('limValueLabel');
  var isBrl = true;

  function toggleValueMode() {
    var isTime = limType.value === 'time';
    limValue.value = '';
    if (isTime) {
      limValueLabel.textContent = 'VALOR (MINUTOS)';
      limValue.placeholder = 'ex: 60';
      limValue.classList.remove('brl-mask');
      limValue.type = 'number';
      limValue.removeEventListener('input', limValue._brlHandler);
      isBrl = false;
    } else {
      limValueLabel.textContent = 'VALOR (R$)';
      limValue.placeholder = 'R$ 0,00';
      limValue.classList.add('brl-mask');
      limValue.type = 'text';
      limValue._brlHandler = function() {
        var v = limValue.value.replace(/\D/g, '');
        if (!v) { limValue.value = ''; return; }
        v = (parseInt(v, 10) / 100).toFixed(2);
        limValue.value = 'R$ ' + v.replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
      };
      limValue.addEventListener('input', limValue._brlHandler);
      isBrl = true;
    }
  }
  limType.addEventListener('change', toggleValueMode);

  document.querySelector('.adm-page-head')?.insertAdjacentHTML('beforeend',
    '<button class="adm-btn primary" id="btnAddLimit" style="margin-left:auto"><svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Impor Limite</button>'
  );

  document.addEventListener('click', e => {
    if (e.target.closest('#btnAddLimit')) {
      ['limUserId','limValue','limNotes'].forEach(id => document.getElementById(id).value = '');
      limType.value = 'deposit';
      document.getElementById('limPeriod').value = 'daily';
      toggleValueMode();
      modal.style.display = 'flex';
    }
    if (e.target.closest('#limCancel') || (e.target === modal)) {
      modal.style.display = 'none';
    }
  });

  document.getElementById('limSave')?.addEventListener('click', async () => {
    var limitVal = isBrl ? parseBRL(limValue.value) : parseInt(limValue.value || 0);
    const body = {
      user_id: document.getElementById('limUserId').value,
      limit_type: limType.value,
      period: document.getElementById('limPeriod').value,
      limit_value: limitVal,
      admin_notes: document.getElementById('limNotes').value
    };
    const r = await fetch('/admin/api/limits', {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify(body), credentials: 'same-origin'
    });
    const d = await r.json();
    if (d.ok) { modal.style.display = 'none'; location.reload(); }
    else alert(d.msg || 'Erro');
  });
});
</script>

