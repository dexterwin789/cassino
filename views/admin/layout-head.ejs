<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Admin • <%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/public/css/admin.css" />
</head>
<body>
  <div class="adm-layout">
    <!-- SIDEBAR -->
    <aside class="adm-sidebar" id="admSidebar">
      <div class="adm-sidebar-head">
        <div class="adm-sidebar-logo">
          <div class="adm-logo-dot"></div>
          <span class="adm-logo-text">Admin</span>
        </div>
        <button class="adm-sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>

      <nav class="adm-sidebar-nav">
        <div class="adm-nav-section">Principal</div>
        <a href="/admin" class="adm-nav-link<%= page === 'dashboard' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          <span>Dashboard</span>
        </a>

        <div class="adm-nav-section">Gerenciar</div>
        <a href="/admin/users" class="adm-nav-link<%= page === 'users' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Usuários</span>
        </a>
        <a href="/admin/deposits" class="adm-nav-link<%= page === 'deposits' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <span>Depósitos</span>
        </a>
        <a href="/admin/games" class="adm-nav-link<%= page === 'games' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span>Jogos</span>
        </a>
        <a href="/admin/transactions" class="adm-nav-link<%= page === 'transactions' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span>Transações</span>
        </a>
        <a href="/admin/banners" class="adm-nav-link<%= page === 'banners' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          <span>Banners</span>
        </a>
        <a href="/admin/bets" class="adm-nav-link<%= page === 'bets' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16v16H4z"/><path d="M9 9h1"/><path d="M14 9h1"/><path d="M9 14h1"/><path d="M14 14h1"/></svg>
          <span>Apostas</span>
        </a>
        <a href="/admin/affiliates" class="adm-nav-link<%= page === 'affiliates' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          <span>Afiliados</span>
        </a>
        <a href="/admin/promotions" class="adm-nav-link<%= page === 'promotions' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          <span>Promoções</span>
        </a>
        <a href="/admin/support" class="adm-nav-link<%= page === 'support' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>Suporte</span>
        </a>
        <a href="/admin/withdrawals" class="adm-nav-link<%= page === 'withdrawals' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
          <span>Saques</span>
        </a>
        <a href="/admin/coupons" class="adm-nav-link<%= page === 'coupons' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 12v-2a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v2"/><path d="M4 12a2 2 0 0 0 0 4h16a2 2 0 0 0 0-4"/><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/><line x1="12" y1="8" x2="12" y2="20"/></svg>
          <span>Cupons</span>
        </a>
        <a href="/admin/leagues" class="adm-nav-link<%= page === 'leagues' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
          <span>Ligas/Esportes</span>
        </a>

        <div class="adm-nav-section">Sistema</div>
        <a href="/admin/notifications" class="adm-nav-link<%= page === 'notifications' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
          <span>Notificações</span>
        </a>
        <a href="/admin/reports" class="adm-nav-link<%= page === 'reports' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          <span>Relatórios</span>
        </a>
        <a href="/admin/limits" class="adm-nav-link<%= page === 'limits' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Jogo Responsável</span>
        </a>
        <a href="/admin/audit" class="adm-nav-link<%= page === 'audit' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          <span>Audit Log</span>
        </a>
        <a href="/admin/settings" class="adm-nav-link<%= page === 'settings' ? ' active' : '' %>">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9z"/></svg>
          <span>Configurações</span>
        </a>
      </nav>

      <div class="adm-sidebar-foot">
        <div class="adm-admin-card">
          <div class="adm-admin-avatar"><%= admin.username.charAt(0).toUpperCase() %></div>
          <div class="adm-admin-info">
            <div class="adm-admin-name"><%= admin.username %></div>
            <div class="adm-admin-role"><%= admin.role %></div>
          </div>
        </div>
        <a href="/admin/logout" class="adm-nav-link logout">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span>Sair</span>
        </a>
      </div>
    </aside>

    <!-- MAIN -->
    <div class="adm-main">
      <header class="adm-topbar">
        <button class="adm-mobile-menu" id="mobileMenu" aria-label="Menu">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <h2 class="adm-topbar-title"><%= title %></h2>
        <div class="adm-topbar-right">
          <a href="/" class="adm-topbar-btn" target="_blank" title="Ver site">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </div>
      </header>

      <div class="adm-content">
