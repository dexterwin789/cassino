<%- include('layout-head', { title: 'Afiliados', page: 'affiliates' }) %>

<!-- ── Configurações de Afiliados ── -->
<div class="adm-page-card" style="margin-bottom:24px;">
  <div class="adm-page-head">
    <div><h3>Configurações de Afiliados</h3><p class="adm-muted">Regras globais do programa de afiliados</p></div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:16px;margin-top:16px;">
    <div class="adm-setting-card">
      <label>Comissão Padrão (%)</label>
      <input type="number" id="affDefaultCommission" value="<%= (typeof affSettings !== 'undefined' && affSettings.aff_default_commission) || '10' %>" min="0" max="100" step="0.5">
    </div>
    <div class="adm-setting-card">
      <label>Depósito Mín. p/ Comissão (R$)</label>
      <input type="text" id="affMinDeposit" class="brl-mask-reais" value="" data-initial-cents="<%= (typeof affSettings !== 'undefined' && affSettings.aff_min_deposit) || '2000' %>" min="0">
    </div>
    <div class="adm-setting-card">
      <label>Cookie (dias)</label>
      <input type="number" id="affCookieDays" value="<%= (typeof affSettings !== 'undefined' && affSettings.aff_cookie_days) || '30' %>" min="1" max="365">
    </div>
    <div class="adm-setting-card">
      <label>Aprovação Automática</label>
      <select id="affAutoApprove">
        <option value="1" <%= (typeof affSettings !== 'undefined' && affSettings.aff_auto_approve === '1') ? 'selected' : '' %>>Sim</option>
        <option value="0" <%= (typeof affSettings === 'undefined' || !affSettings.aff_auto_approve || affSettings.aff_auto_approve === '0') ? 'selected' : '' %>>Não</option>
      </select>
    </div>
    <div class="adm-setting-card">
      <label>Bônus por Indicação (R$)</label>
      <input type="text" id="affReferralBonus" class="brl-mask-reais" value="" data-initial-cents="<%= (typeof affSettings !== 'undefined' && affSettings.aff_referral_bonus) || '5000' %>" min="0">
    </div>
    <div class="adm-setting-card">
      <label>Máx. Afiliados</label>
      <input type="number" id="affMaxAffiliates" value="<%= (typeof affSettings !== 'undefined' && affSettings.aff_max_affiliates) || '0' %>" min="0" placeholder="0 = ilimitado">
    </div>
    <div class="adm-setting-card">
      <label>Saque Mínimo (R$)</label>
      <input type="text" id="affMinWithdrawal" class="brl-mask-reais" value="" data-initial-cents="<%= (typeof affSettings !== 'undefined' && affSettings.aff_min_withdrawal) || '5000' %>" min="0">
    </div>
  </div>
  <button class="adm-btn primary" id="btnSaveAffSettings" style="margin-top:16px;">Salvar Configurações</button>
</div>

<!-- ── RevShare ── -->
<div class="adm-page-card" style="margin-bottom:24px;">
  <div class="adm-page-head">
    <div>
      <h3>RevShare (Comissão sobre perdas)</h3>
      <p class="adm-muted">Afiliado recebe % de cada aposta que o usuário indicado perder. Ative e defina a porcentagem.</p>
    </div>
  </div>
  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:16px;margin-top:16px;">
    <div class="adm-setting-card">
      <label>Ativar RevShare</label>
      <select id="affRevshareEnabled">
        <option value="1" <%= (typeof affSettings !== 'undefined' && affSettings.aff_revshare_enabled === '1') ? 'selected' : '' %>>Sim</option>
        <option value="0" <%= (typeof affSettings === 'undefined' || affSettings.aff_revshare_enabled !== '1') ? 'selected' : '' %>>Não</option>
      </select>
    </div>
    <div class="adm-setting-card">
      <label>Percentual RevShare (%)</label>
      <input type="number" id="affRevsharePct" value="<%= (typeof affSettings !== 'undefined' && affSettings.aff_revshare_pct) || '5' %>" min="0" max="100" step="0.5">
    </div>
  </div>
  <button class="adm-btn primary" id="btnSaveRevshare" style="margin-top:16px;">Salvar RevShare</button>
</div>

<!-- ── Lista de Afiliados ── -->
<div class="adm-page-card" data-page="affiliates">
  <div class="adm-page-head">
    <div><h3>Afiliados</h3><p class="adm-muted">Programa de afiliados</p></div>
    <button class="adm-btn" data-action="refresh">Atualizar</button>
  </div>
  <div class="adm-toolbar">
    <div class="adm-field"><label>Buscar</label><input type="text" placeholder="código / username" data-filter="q" /></div>
    <div class="adm-field"><label>Por página</label><select data-filter="limit"><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option><option value="100">100</option></select></div>
    <div class="adm-field"><label>&nbsp;</label><button class="adm-btn primary" data-action="apply">Aplicar</button></div>
  </div>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead><tr><th>ID</th><th>Usuário</th><th>Código</th><th>Comissão %</th><th>Total Ganho</th><th>Ativo</th><th>Criado</th><th>Ações</th></tr></thead>
      <tbody data-tbody></tbody>
    </table>
  </div>
  <div class="adm-pager">
    <div class="adm-muted"><span data-count>0</span> resultados</div>
    <div class="adm-pager-btns">
      <button class="adm-btn" data-action="prev">‹</button>
      <span class="adm-muted">Página <span data-page-num>1</span></span>
      <button class="adm-btn" data-action="next">›</button>
    </div>
  </div>
</div>

<script src="/public/js/admin.js" defer></script>
<script>
// BRL mask for fields that store in REAIS (not centavos)
function brlMaskReais(input) {
  input.addEventListener('input', function() {
    var v = this.value.replace(/\D/g, '');
    if (!v) { this.value = ''; return; }
    v = (parseInt(v, 10) / 100).toFixed(2);
    this.value = 'R$ ' + v.replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  });
}
function parseReais(str) {
  if (!str) return 0;
  var n = str.replace(/[R$\s.]/g, '').replace(',', '.');
  return parseFloat(n || 0);
}
function formatReais(val) {
  var n = parseFloat(val || 0);
  return 'R$ ' + n.toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
}
// Init masks and set initial values (stored as CENTS in DB, display as REAIS)
document.querySelectorAll('.brl-mask-reais').forEach(function(el) {
  brlMaskReais(el);
  if (el.dataset.initialCents) {
    var reais = (parseInt(el.dataset.initialCents, 10) || 0) / 100;
    el.value = formatReais(reais);
  } else if (el.dataset.initial) {
    el.value = formatReais(el.dataset.initial);
  }
});

document.getElementById('btnSaveAffSettings')?.addEventListener('click', async function() {
  var btn = this; btn.disabled = true; btn.textContent = 'Salvando...';
  try {
    var r = await fetch('/admin/api/affiliate-settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        settings: {
          aff_default_commission: document.getElementById('affDefaultCommission').value,
          aff_min_deposit: Math.round(parseReais(document.getElementById('affMinDeposit').value) * 100),
          aff_cookie_days: document.getElementById('affCookieDays').value,
          aff_auto_approve: document.getElementById('affAutoApprove').value,
          aff_referral_bonus: Math.round(parseReais(document.getElementById('affReferralBonus').value) * 100),
          aff_max_affiliates: document.getElementById('affMaxAffiliates').value,
          aff_min_withdrawal: Math.round(parseReais(document.getElementById('affMinWithdrawal').value) * 100)
        }
      }),
      credentials: 'same-origin'
    });
    var d = await r.json();
    if (d.ok) alert('Configurações salvas!');
    else alert(d.msg || 'Erro');
  } catch { alert('Erro de rede.'); }
  btn.disabled = false; btn.textContent = 'Salvar Configurações';
});

document.getElementById('btnSaveRevshare')?.addEventListener('click', async function() {
  var btn = this; btn.disabled = true; btn.textContent = 'Salvando...';
  try {
    var r = await fetch('/admin/api/affiliate-settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        settings: {
          aff_revshare_enabled: document.getElementById('affRevshareEnabled').value,
          aff_revshare_pct: document.getElementById('affRevsharePct').value
        }
      }),
      credentials: 'same-origin'
    });
    var d = await r.json();
    if (d.ok) alert('RevShare salvo!');
    else alert(d.msg || 'Erro');
  } catch { alert('Erro de rede.'); }
  btn.disabled = false; btn.textContent = 'Salvar RevShare';
});
</script>
<%- include('layout-foot') %>
