      </div><!-- .adm-content -->

      <footer class="adm-footer">
        <span>&copy; <%= new Date().getFullYear() %> | Painel Admin</span>
      </footer>
    </div><!-- .adm-main -->
  </div><!-- .adm-layout -->

  <script>
  window.adminToast = function(message, type) {
    let region = document.querySelector('.adm-toast-region');
    if (!region) {
      region = document.createElement('div');
      region.className = 'adm-toast-region';
      document.body.appendChild(region);
    }
    const toast = document.createElement('div');
    toast.className = 'adm-toast ' + (type || 'info');
    toast.innerHTML = '<span></span><strong>' + String(message || '').replace(/[&<>]/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[c])) + '</strong>';
    region.appendChild(toast);
    setTimeout(() => toast.classList.add('show'), 20);
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => toast.remove(), 180);
    }, 3600);
  };

  // Sidebar toggle
  const sidebar = document.getElementById('admSidebar');
  const sidebarBackdrop = document.getElementById('sidebarBackdrop');
  const openMobileSidebar = () => {
    sidebar.classList.add('mobile-open');
    document.body.classList.add('adm-sidebar-open');
  };
  const closeMobileSidebar = () => {
    sidebar.classList.remove('mobile-open');
    document.body.classList.remove('adm-sidebar-open');
  };
  document.getElementById('sidebarToggle')?.addEventListener('click', () => sidebar.classList.toggle('collapsed'));
  document.getElementById('mobileMenu')?.addEventListener('click', openMobileSidebar);
  sidebarBackdrop?.addEventListener('click', closeMobileSidebar);
  sidebar.querySelectorAll('a').forEach(link => link.addEventListener('click', closeMobileSidebar));
  // Close on outside click (mobile)
  document.addEventListener('click', (e) => {
    if (sidebar.classList.contains('mobile-open') && !sidebar.contains(e.target) && !e.target.closest('#mobileMenu')) {
      closeMobileSidebar();
    }
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMobileSidebar();
  });

  // Collapsed sidebar: JS-based fixed tooltip
  (function() {
    var tip = document.createElement('div');
    tip.className = 'adm-sidebar-tooltip';
    document.body.appendChild(tip);

    sidebar.addEventListener('mouseenter', function(e) {
      var link = e.target.closest && e.target.closest('.adm-nav-link[data-tip]');
      if (!link || !sidebar.classList.contains('collapsed')) return;
      var rect = link.getBoundingClientRect();
      tip.textContent = link.getAttribute('data-tip');
      tip.style.top = (rect.top + rect.height / 2) + 'px';
      tip.style.left = (rect.right + 10) + 'px';
      tip.style.transform = 'translateY(-50%)';
      tip.style.opacity = '1';
    }, true);

    sidebar.addEventListener('mouseleave', function(e) {
      var link = e.target.closest && e.target.closest('.adm-nav-link[data-tip]');
      if (link) tip.style.opacity = '0';
    }, true);

    sidebar.addEventListener('mouseover', function(e) {
      var link = e.target.closest && e.target.closest('.adm-nav-link[data-tip]');
      if (!link || !sidebar.classList.contains('collapsed')) { tip.style.opacity = '0'; return; }
      var rect = link.getBoundingClientRect();
      tip.textContent = link.getAttribute('data-tip');
      tip.style.top = (rect.top + rect.height / 2) + 'px';
      tip.style.left = (rect.right + 10) + 'px';
      tip.style.transform = 'translateY(-50%)';
      tip.style.opacity = '1';
    });

    sidebar.addEventListener('mouseout', function(e) {
      var related = e.relatedTarget;
      if (!related || !related.closest || !related.closest('.adm-nav-link[data-tip]')) {
        tip.style.opacity = '0';
      }
    });

    sidebar.addEventListener('scroll', function() { tip.style.opacity = '0'; });
  })();
  </script>
</body>
</html>
