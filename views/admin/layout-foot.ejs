      </div><!-- .adm-content -->

      <footer class="adm-footer">
        <span>&copy; <%= new Date().getFullYear() %> • Painel Admin</span>
      </footer>
    </div><!-- .adm-main -->
  </div><!-- .adm-layout -->

  <script>
  // Sidebar toggle
  const sidebar = document.getElementById('admSidebar');
  document.getElementById('sidebarToggle')?.addEventListener('click', () => sidebar.classList.toggle('collapsed'));
  document.getElementById('mobileMenu')?.addEventListener('click', () => sidebar.classList.toggle('mobile-open'));
  // Close on outside click (mobile)
  document.addEventListener('click', (e) => {
    if (sidebar.classList.contains('mobile-open') && !sidebar.contains(e.target) && e.target.id !== 'mobileMenu') {
      sidebar.classList.remove('mobile-open');
    }
  });

  // Collapsed sidebar: JS-based fixed tooltip
  (function() {
    var tip = document.createElement('div');
    tip.className = 'adm-sidebar-tooltip';
    document.body.appendChild(tip);

    sidebar.addEventListener('mouseenter', function(e) {
      var link = e.target.closest && e.target.closest('.adm-nav-link[data-tip]');
      if (!link || !sidebar.classList.contains('collapsed')) return;
      var rect = link.getBoundingClientRect();
      tip.textContent = link.getAttribute('data-tip');
      tip.style.top = (rect.top + rect.height / 2) + 'px';
      tip.style.left = (rect.right + 10) + 'px';
      tip.style.transform = 'translateY(-50%)';
      tip.style.opacity = '1';
    }, true);

    sidebar.addEventListener('mouseleave', function(e) {
      var link = e.target.closest && e.target.closest('.adm-nav-link[data-tip]');
      if (link) tip.style.opacity = '0';
    }, true);

    sidebar.addEventListener('mouseover', function(e) {
      var link = e.target.closest && e.target.closest('.adm-nav-link[data-tip]');
      if (!link || !sidebar.classList.contains('collapsed')) { tip.style.opacity = '0'; return; }
      var rect = link.getBoundingClientRect();
      tip.textContent = link.getAttribute('data-tip');
      tip.style.top = (rect.top + rect.height / 2) + 'px';
      tip.style.left = (rect.right + 10) + 'px';
      tip.style.transform = 'translateY(-50%)';
      tip.style.opacity = '1';
    });

    sidebar.addEventListener('mouseout', function(e) {
      var related = e.relatedTarget;
      if (!related || !related.closest || !related.closest('.adm-nav-link[data-tip]')) {
        tip.style.opacity = '0';
      }
    });

    sidebar.addEventListener('scroll', function() { tip.style.opacity = '0'; });
  })();
  </script>
</body>
</html>
