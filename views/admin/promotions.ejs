<%- include('layout-head', { title: 'Promoções', page: 'promotions' }) %>

<div class="adm-page-card" data-page="promotions">
  <div class="adm-page-head">
    <div><h3>Promoções</h3><p class="adm-muted">Bônus, cupons e promoções</p></div>
    <div style="display:flex;gap:8px">
      <button class="adm-btn primary" id="btnAddPromo">+ Nova Promoção</button>
      <button class="adm-btn" data-action="refresh">Atualizar</button>
    </div>
  </div>
  <div class="adm-toolbar">
    <div class="adm-field"><label>Buscar</label><input type="text" placeholder="título / código" data-filter="q" /></div>
    <div class="adm-field"><label>Por página</label><select data-filter="limit"><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option><option value="100">100</option></select></div>
    <div class="adm-field"><label>&nbsp;</label><button class="adm-btn primary" data-action="apply">Aplicar</button></div>
  </div>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead><tr><th>ID</th><th>Título</th><th>Tipo</th><th>Valor</th><th>Código</th><th>Usos</th><th>Ativo</th><th>Expira</th><th>Ações</th></tr></thead>
      <tbody data-tbody></tbody>
    </table>
  </div>
  <div class="adm-pager">
    <div class="adm-muted"><span data-count>0</span> resultados</div>
    <div class="adm-pager-btns">
      <button class="adm-btn" data-action="prev">‹</button>
      <span class="adm-muted">Página <span data-page-num>1</span></span>
      <button class="adm-btn" data-action="next">›</button>
    </div>
  </div>
</div>

<script src="/public/js/admin.js" defer></script>

<!-- ── Modal: Nova Promoção ── -->
<div id="promoModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);align-items:center;justify-content:center">
  <div style="background:linear-gradient(160deg,#111827,#0d1321);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:32px;width:520px;max-width:92vw;box-shadow:0 24px 80px rgba(0,0,0,.6)">
    <h4 style="margin:0 0 24px;color:#fff;font-size:18px;font-weight:700;display:flex;align-items:center;gap:10px">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--adm-green1,#10b981)" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      Nova Promoção
    </h4>
    <div style="display:flex;flex-direction:column;gap:16px">
      <div style="display:flex;flex-direction:column;gap:6px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Título da Promoção *</label>
        <input id="prTitle" placeholder="ex: Bônus de Boas-Vindas" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Tipo</label>
          <select id="prType" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s;cursor:pointer" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
            <option value="bonus" style="background:#1a1f2e">Bônus</option>
            <option value="cashback" style="background:#1a1f2e">Cashback</option>
            <option value="freebet" style="background:#1a1f2e">Freebet</option>
          </select>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Código</label>
          <input id="prCode" placeholder="ex: WELCOME50" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s;text-transform:uppercase" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px">
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Valor (R$)</label>
          <input id="prValue" class="brl-mask" placeholder="R$ 0,00" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
        </div>
        <div style="display:flex;flex-direction:column;gap:6px">
          <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Percentual (%)</label>
          <input id="prValuePct" type="number" placeholder="50 = 50%" value="0" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;max-width:200px">
        <label style="font-size:11px;color:rgba(255,255,255,.45);font-weight:700;text-transform:uppercase;letter-spacing:.5px">Máx. Usos</label>
        <input id="prMaxUses" type="number" placeholder="0 = ilimitado" value="0" style="height:42px;border-radius:12px;border:1px solid rgba(255,255,255,.1);background:rgba(0,0,0,.3);color:#fff;padding:0 14px;outline:none;font-size:13px;font-weight:500;transition:border-color .2s" onfocus="this.style.borderColor='var(--adm-green1)'" onblur="this.style.borderColor='rgba(255,255,255,.1)'">
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-top:24px;justify-content:flex-end">
      <button class="adm-btn" id="prCancel" style="padding:10px 20px;border-radius:10px">Cancelar</button>
      <button class="adm-btn primary" id="prSave" style="padding:10px 24px;border-radius:10px;font-weight:700">Salvar Promoção</button>
    </div>
  </div>
</div>
<script>
function brlMask(input) {
  input.addEventListener('input', function() {
    var v = this.value.replace(/\D/g, '');
    if (!v) { this.value = ''; return; }
    v = (parseInt(v, 10) / 100).toFixed(2);
    this.value = 'R$ ' + v.replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
  });
}
function parseBRL(str) {
  if (!str) return 0;
  var n = str.replace(/[R$\s.]/g, '').replace(',', '.');
  return Math.round(parseFloat(n || 0) * 100);
}
document.querySelectorAll('.brl-mask').forEach(brlMask);

(function(){
  var modal = document.getElementById('promoModal');
  document.getElementById('btnAddPromo').addEventListener('click', function() {
    ['prTitle','prCode'].forEach(function(id){ document.getElementById(id).value=''; });
    document.getElementById('prType').value='bonus';
    document.getElementById('prValue').value='';
    document.getElementById('prValuePct').value='0';
    document.getElementById('prMaxUses').value='0';
    modal.style.display='flex';
  });
  document.getElementById('prCancel').addEventListener('click', function(){ modal.style.display='none'; });
  modal.addEventListener('click', function(e){ if(e.target===modal) modal.style.display='none'; });
  document.getElementById('prSave').addEventListener('click', async function(){
    var title = document.getElementById('prTitle').value.trim();
    if(!title) return alert('Título é obrigatório.');
    var btn=this; btn.disabled=true; btn.textContent='Salvando...';
    try {
      var code = document.getElementById('prCode').value.trim();
      var r = await fetch('/admin/api/promotions', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ title:title, type:document.getElementById('prType').value, code:code||undefined, value_cents:parseBRL(document.getElementById('prValue').value), value_pct:document.getElementById('prValuePct').value, max_uses:document.getElementById('prMaxUses').value }),
        credentials:'same-origin'
      });
      var d = await r.json();
      if(d.ok){ modal.style.display='none'; location.reload(); }
      else alert(d.msg||'Erro');
    } catch{ alert('Erro de rede.'); }
    btn.disabled=false; btn.textContent='Salvar Promoção';
  });
})();
</script>
<%- include('layout-foot') %>
