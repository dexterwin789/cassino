<%- include('layout-head', { title: 'Depósitos', page: 'deposits' }) %>

<div class="adm-page-card" data-page="deposits">
  <div class="adm-page-head">
    <div><h3>Depósitos</h3><p class="adm-muted">Transações do tipo deposit</p></div>
    <button class="adm-btn" data-action="refresh">Atualizar</button>
  </div>
  <div class="adm-toolbar">
    <div class="adm-field"><label>Buscar</label><input type="text" placeholder="id / user_id / ref" data-filter="q" /></div>
    <div class="adm-field"><label>Status</label><select data-filter="status"><option value="">Todos</option><option value="pending">pending</option><option value="paid">paid</option><option value="failed">failed</option><option value="canceled">canceled</option></select></div>
    <div class="adm-field"><label>De</label><input type="date" data-filter="from" /></div>
    <div class="adm-field"><label>Até</label><input type="date" data-filter="to" /></div>
    <div class="adm-field"><label>Por página</label><select data-filter="limit"><option value="10">10</option><option value="25" selected>25</option><option value="50">50</option><option value="100">100</option></select></div>
    <div class="adm-field"><label>&nbsp;</label><button class="adm-btn primary" data-action="apply">Aplicar</button></div>
  </div>
  <div class="adm-table-wrap">
    <table class="adm-table">
      <thead><tr><th>ID</th><th>User</th><th>Valor</th><th>Status</th><th>Provider</th><th>Ref</th><th>Criado</th><th>Atualizado</th></tr></thead>
      <tbody data-tbody></tbody>
    </table>
  </div>
  <div class="adm-pager">
    <div class="adm-muted"><span data-count>0</span> resultados</div>
    <div class="adm-pager-btns">
      <button class="adm-btn" data-action="prev">‹</button>
      <span class="adm-muted">Página <span data-page-num>1</span></span>
      <button class="adm-btn" data-action="next">›</button>
    </div>
  </div>
</div>

<script src="/public/js/admin.js" defer></script>
<%- include('layout-foot') %>
