        <small id="prgmFrenchMsg" class="adm-muted" style="display:block;margin-top:8px;font-size:12px;"></small>
      </div>
      <div class="adm-setting-card">
        <label>Fortune Roulette</label>
        <textarea id="prgmFortune" rows="2" style="width:100%;padding:10px;border-radius:8px;background:#0b0d12;color:#fff;border:1px solid rgba(255,255,255,.12);font-family:monospace;font-size:12px;" placeholder="JSESSIONID=... ou URL inteira"></textarea>
        <button class="adm-btn primary" data-prgm-game="oficial-pragmatic-live-pp-270" data-prgm-input="prgmFortune" style="margin-top:8px;">Salvar e sincronizar</button>
        <small id="prgmFortuneMsg" class="adm-muted" style="display:block;margin-top:8px;font-size:12px;"></small>
      </div>
    </div>
  </div>

  <!-- â”€â”€ Logo do Site â”€â”€ -->
  <div style="margin-top:32px;">
    <h4 style="margin-bottom:4px;">Logo do Site</h4>
    <p class="adm-muted" style="margin-bottom:20px;">Envie logos separadas para tema escuro e claro. Se enviar apenas uma, serÃ¡ usada em ambos.</p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:700px;">
      <!-- Dark Logo -->
      <div style="background:linear-gradient(145deg,rgba(255,255,255,.03),rgba(255,255,255,.01));border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:24px;display:flex;flex-direction:column;align-items:center;gap:14px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.5)" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <span style="font-weight:600;font-size:14px;color:var(--adm-text);">Tema Escuro</span>
        </div>
        <div id="previewDark" style="width:100%;min-height:70px;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.35);border-radius:10px;padding:14px;border:1px dashed rgba(255,255,255,.08);">
          <% if (settings.logo_dark) { %>
            <img src="<%= settings.logo_dark %>" style="max-height:50px;max-width:100%;">
          <% } else { %>
            <span class="adm-muted" style="font-size:12px;">Nenhuma logo enviada</span>
          <% } %>
        </div>
        <div style="display:flex;gap:8px;width:100%;">
          <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:8px 0;background:linear-gradient(135deg,var(--adm-green1),var(--adm-green2));color:#fff;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;transition:opacity .2s;" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            Escolher
            <input type="file" id="fileDark" accept="image/*" style="display:none;">
          </label>
          <% if (settings.logo_dark) { %>
            <button id="btnRemoveDark" style="padding:8px 12px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#ef4444;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;transition:background .2s;" onmouseover="this.style.background='rgba(239,68,68,.22)'" onmouseout="this.style.background='rgba(239,68,68,.12)'">Remover</button>
          <% } %>
        </div>
      </div>

      <!-- Light Logo -->
      <div style="background:linear-gradient(145deg,rgba(255,255,255,.03),rgba(255,255,255,.01));border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:24px;display:flex;flex-direction:column;align-items:center;gap:14px;">
        <div style="display:flex;align-items:center;gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,200,50,.6)" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
          <span style="font-weight:600;font-size:14px;color:var(--adm-text);">Tema Claro</span>
        </div>
        <div id="previewLight" style="width:100%;min-height:70px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.88);border-radius:10px;padding:14px;border:1px dashed rgba(0,0,0,.1);">
          <% if (settings.logo_light) { %>
            <img src="<%= settings.logo_light %>" style="max-height:50px;max-width:100%;">
          <% } else { %>
            <span style="color:#999;font-size:12px;">Nenhuma logo enviada</span>
          <% } %>
        </div>
        <div style="display:flex;gap:8px;width:100%;">
          <label style="flex:1;display:flex;align-items:center;justify-content:center;gap:6px;padding:8px 0;background:linear-gradient(135deg,var(--adm-green1),var(--adm-green2));color:#fff;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;transition:opacity .2s;" onmouseover="this.style.opacity='.85'" onmouseout="this.style.opacity='1'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
            Escolher
            <input type="file" id="fileLight" accept="image/*" style="display:none;">
          </label>
          <% if (settings.logo_light) { %>
            <button id="btnRemoveLight" style="padding:8px 12px;background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25);color:#ef4444;font-size:12px;font-weight:600;border-radius:8px;cursor:pointer;transition:background .2s;" onmouseover="this.style.background='rgba(239,68,68,.22)'" onmouseout="this.style.background='rgba(239,68,68,.12)'">Remover</button>
          <% } %>
        </div>
      </div>
    </div>

    <button class="adm-btn primary" id="btnSaveLogo" style="margin-top:16px;">Salvar Logo(s)</button>
  </div>
</div>

<script>
function formatMoneyFromCents(cents) {
  var n = (parseInt(cents || 0, 10) || 0) / 100;
  return 'R$ ' + n.toFixed(2).replace('.', ',').replace(/\B(?=(\d{3})+(?!\d))/g, '.');
}
function parseMoneyToCents(str) {
  var n = String(str || '').replace(/[R$\s.]/g, '').replace(',', '.');
  return Math.max(0, Math.round(parseFloat(n || 0) * 100));
}
document.querySelectorAll('.money-cents-input').forEach(function(input) {
  input.value = formatMoneyFromCents(input.dataset.initialCents || '0');
  input.addEventListener('input', function() {
    var v = this.value.replace(/\D/g, '');
    if (!v) { this.value = ''; return; }
    this.value = formatMoneyFromCents(parseInt(v, 10));
  });
});
// Settings save
document.getElementById('btnSaveSettings')?.addEventListener('click', async () => {
  const settings = [
    { key: 'site_name', value: document.getElementById('setSiteName').value },
    { key: 'maintenance_mode', value: document.getElementById('setMaintenance').value },
    { key: 'sports_enabled', value: document.getElementById('setSports').value },
    { key: 'bonus_enabled', value: document.getElementById('setBonusEnabled').value },
    { key: 'min_deposit', value: parseMoneyToCents(document.getElementById('setMinDeposit').value) },
    { key: 'min_withdrawal', value: parseMoneyToCents(document.getElementById('setMinWithdrawal').value) }
  ];
  for (const s of settings) {
    await fetch('/admin/api/settings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(s),
      credentials: 'same-origin'
    });
  }
  alert('ConfiguraÃ§Ãµes salvas!');
});

// Logo preview on file select
document.getElementById('fileDark')?.addEventListener('change', function() {
  if (this.files[0]) {
    const url = URL.createObjectURL(this.files[0]);
    document.getElementById('previewDark').innerHTML = '<img src="' + url + '" style="max-height:50px;max-width:100%;">';
  }
});
document.getElementById('fileLight')?.addEventListener('change', function() {
  if (this.files[0]) {
    const url = URL.createObjectURL(this.files[0]);
    document.getElementById('previewLight').innerHTML = '<img src="' + url + '" style="max-height:50px;max-width:100%;">';
  }
});

// Logo upload
document.getElementById('btnSaveLogo')?.addEventListener('click', async () => {
  const darkFile = document.getElementById('fileDark').files[0];
  const lightFile = document.getElementById('fileLight').files[0];
  if (!darkFile && !lightFile) return alert('Selecione ao menos uma imagem.');
  const fd = new FormData();
  if (darkFile) fd.append('logo_dark', darkFile);
  if (lightFile) fd.append('logo_light', lightFile);
  const btn = document.getElementById('btnSaveLogo');
  btn.disabled = true;
  btn.textContent = 'Salvando...';
  try {
    const r = await fetch('/admin/api/settings/logo', { method: 'POST', body: fd, credentials: 'same-origin' });
    const j = await r.json();
    if (j.ok) { alert('Logo(s) salva(s)!'); location.reload(); }
    else alert(j.msg || 'Erro ao salvar.');
  } catch { alert('Erro de rede.'); }
  btn.disabled = false;
  btn.textContent = 'Salvar Logo(s)';
});

// Logo remove
document.getElementById('btnRemoveDark')?.addEventListener('click', async () => {
  if (!confirm('Remover logo do tema escuro?')) return;
  const r = await fetch('/admin/api/settings/logo/dark', { method: 'DELETE', credentials: 'same-origin' });
  const j = await r.json();
  if (j.ok) location.reload();
});
document.getElementById('btnRemoveLight')?.addEventListener('click', async () => {
  if (!confirm('Remover logo do tema claro?')) return;
  const r = await fetch('/admin/api/settings/logo/light', { method: 'DELETE', credentials: 'same-origin' });
  const j = await r.json();
  if (j.ok) location.reload();
});

// Pragmatic JSESSIONID ingest
document.querySelectorAll('[data-prgm-game]').forEach(function(btn) {
  btn.addEventListener('click', async function() {
    var gameCode = btn.getAttribute('data-prgm-game');
    var inputId = btn.getAttribute('data-prgm-input');
    var msgEl = document.getElementById(inputId + 'Msg');
    var raw = (document.getElementById(inputId).value || '').trim();
    if (!raw) { if (msgEl) msgEl.textContent = 'Cole a URL ou a JSESSIONID.'; return; }
    var body = raw.indexOf('JSESSIONID=') >= 0 ? { game_code: gameCode, url: raw } : { game_code: gameCode, jsessionid: raw };
    btn.disabled = true; btn.textContent = 'Sincronizando...';
    try {
      var r = await fetch('/api/roulette/pragmatic/ingest', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
      });
      var j = await r.json();
      if (msgEl) msgEl.textContent = j.ok ? (j.msg || 'OK') + ' (' + (j.count || 0) + ' nÃºmeros)' : (j.msg || 'Erro.');
    } catch (e) {
      if (msgEl) msgEl.textContent = 'Erro de rede.';
    } finally {
      btn.disabled = false; btn.textContent = 'Salvar e sincronizar';
    }
  });
});
</script>

<%- include('layout-foot') %>
