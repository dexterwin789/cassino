<%- include('partials/head') %>

<%- include('partials/topbar') %>

<div class="app-layout" id="appLayout">
  <%- include('partials/sidebar') %>

  <main class="main-content" id="mainContent">
    <div class="main-container">

      <!-- Header -->
      <section class="archive-bar">
        <div class="archive-bar-left">
          <a href="/" class="archive-back" title="Voltar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 8 8 12 12 16"/><line x1="16" y1="12" x2="8" y2="12"/></svg>
          </a>
          <span class="archive-title">Todos os Estúdios / Provedores</span>
        </div>
        <div class="archive-bar-right">
          <div class="archive-search-box">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="providerSearch" placeholder="Buscar provedor..." autocomplete="off">
          </div>
        </div>
      </section>

      <!-- Providers grid -->
      <section class="game-section estudios-section">
        <div class="estudios-grid estudios-grid-wrap" id="providersGrid">
          <% providers.forEach(function(p) { %>
          <a href="/games?provider=<%= encodeURIComponent(p) %>" class="estudio-card" data-provider="<%= p.toLowerCase() %>">
            <% var imgUrl = providerImageMap[p.toUpperCase()] || ('https://imagensfivers.com/Provedores/' + encodeURIComponent(p) + '.webp'); %>
            <img src="<%= imgUrl %>" alt="<%= p %>" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <span class="estudio-fallback" style="display:none;align-items:center;justify-content:center;width:100%;height:100%;font-weight:700;font-size:13px;color:#fff;text-transform:uppercase"><%= p %></span>
            <span class="estudio-badge"><%= gameCounts[p] || 0 %></span>
          </a>
          <% }); %>
        </div>
      </section>

      <%- include('partials/footer') %>

    </div>
  </main>
</div>

<!-- Bottom nav mobile -->
<nav class="bottom-nav">
  <a href="/" class="bnav-item active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    <span>Início</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-search">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <span>Buscar</span>
  </a>
  <button class="bnav-item bnav-deposit" id="bnav-deposit">
    <div class="bnav-deposit-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </div>
    <span>Depositar</span>
  </button>
  <a href="#" class="bnav-item" id="bnav-promos">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12v10H4V12M2 7h20v5H2zM12 22V7M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
    <span>Promoções</span>
  </a>
  <a href="#" class="bnav-item" id="bnav-menu">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
    <span>Menu</span>
  </a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<%- include('partials/login-modal') %>

<div id="toastContainer" class="toast-container"></div>

<script src="/public/js/script.js"></script>
<script>
(function(){
  var searchInput = document.getElementById('providerSearch');
  var cards = document.querySelectorAll('#providersGrid .estudio-card');

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      var q = this.value.trim().toLowerCase();
      cards.forEach(function(card) {
        var name = card.getAttribute('data-provider') || '';
        card.style.display = (!q || name.includes(q)) ? '' : 'none';
      });
    });
  }
})();
</script>

<%- include('partials/foot') %>
