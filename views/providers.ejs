<div class="sidebar-overlay" id="sidebarOverlay"></div>

<%- include('partials/login-modal') %>

<div id="toastContainer" class="toast-container"></div>

<script src="/public/js/script.js"></script>
<script>
(function(){
  var providers = <%- JSON.stringify(providers) %>;
  var gameCounts = <%- JSON.stringify(gameCounts) %>;
  var grid = document.getElementById('providersGrid');
  var searchInput = document.getElementById('providerSearch');

  function renderProviders(filter) {
    var q = (filter || '').trim().toLowerCase();
    var filtered = providers.filter(function(p) {
      return !q || p.toLowerCase().includes(q);
    });
    if (!filtered.length) {
      grid.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-muted);font-size:14px">Nenhum provedor encontrado.</div>';
      return;
    }
    grid.innerHTML = filtered.map(function(p) {
      var count = gameCounts[p] || 0;
      var imgUrl = 'https://imagensfivers.com/Provedores/' + encodeURIComponent(p) + '.webp';
      return '<a href="/games?provider=' + encodeURIComponent(p) + '" class="prov-grid-card">' +
        '<div class="prov-grid-bg">' +
          '<img src="' + imgUrl + '" alt="' + p + '" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">' +
          '<span class="prov-grid-fallback" style="display:none">' + p + '</span>' +
        '</div>' +
        '<span class="prov-grid-badge">' + count + '</span>' +
      '</a>';
    }).join('');
  }

  renderProviders('');

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      renderProviders(this.value);
    });
  }
})();
</script>

<%- include('partials/foot') %>
