# ============================================================
# JSESSIONID Poller - VemNaBet
# Copie este arquivo para .env e preencha os valores
# ============================================================

# URL do seu backend (sem barra final)
BACKEND_URL=https://vemnabet.bet

# Token compartilhado entre poller e backend (defina o MESMO valor
# como variável de ambiente INGEST_TOKEN no Railway)
# Gere um aleatório (qualquer string longa serve), ex.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INGEST_TOKEN=

# Credenciais PlayFivers (mesmas do backend)
PLAYFIVERS_AGENT_TOKEN=
PLAYFIVERS_SECRET_KEY=

# Intervalo entre verificações (default 60s)
POLL_INTERVAL_MS=60000

# Quanto tempo manter a JSESSIONID antes de renovar (default 12 min)
# JSESSIONID da Pragmatic costuma durar ~15-30 min
RENEW_AFTER_MS=720000

# (Opcional, para o futuro) — proxy HTTP/HTTPS para todas as chamadas
# Formato: http://USER:PASS@HOST:PORT
# Deixe vazio para usar o IP local da máquina.
OUTBOUND_PROXY=
